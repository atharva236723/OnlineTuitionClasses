---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import HeroAnimation from '../components/HeroAnimation.astro';

const steps = [
  { num: "1", title: "Select class & subject", desc: "Tell us which class you're in and which subject you need help with." },
  { num: "2", title: "Choose your budget", desc: "Pick a pricing tier that works for you — no hidden fees." },
  { num: "3", title: "Get matched in 24 hours", desc: "We'll connect you with a verified teacher suited to your needs." },
  { num: "4", title: "Start with a free demo", desc: "Attend a free demo class before committing to anything." },
];

const pricing = [
  { range: "Class 1–5",   price: "₹300 – ₹600 / hr" },
  { range: "Class 6–8",   price: "₹500 – ₹900 / hr" },
  { range: "Class 9–10",  price: "₹700 – ₹1,200 / hr" },
  { range: "Class 11–12", price: "₹900 – ₹1,800 / hr" },
];
---

<Layout>

  <Nav />

  <!-- ── HERO ────────────────────────────────────────────── -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text">
        <h1 class="hero-headline">Online Tuition for Class 1–12<br />Verified Teachers.</h1>
        <p class="hero-sub">Choose your subject, your budget, and get matched with a teacher in 24 hours.</p>
        <a href="#find" class="btn-primary">Find a Teacher</a>
      </div>
      <div class="hero-visual">
        <HeroAnimation />
      </div>
    </div>
  </section>

  <!-- ── HOW IT WORKS ─────────────────────────────────────── -->
  <section class="section" id="how">
    <div class="container">
      <h2 class="section-title">How it works</h2>
      <div class="steps-grid">
        {steps.map(s => (
          <div class="step-card">
            <div class="step-num">{s.num}</div>
            <h3 class="step-title">{s.title}</h3>
            <p class="step-desc">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── PRICING ──────────────────────────────────────────── -->
  <section class="section section-alt" id="pricing">
    <div class="container">
      <h2 class="section-title">Pricing</h2>
      <p class="section-sub">Select your class and subject to get started.</p>

      <div class="calc-card">

        <!-- Class slider -->
        <div class="calc-block">
          <div class="calc-label">Class <span id="class-badge" class="class-badge">6</span></div>
          <div class="slider-wrap">
            <div class="slider-track">
              <div class="slider-fill" id="slider-fill"></div>
            </div>
            <input type="range" min="1" max="12" value="6" id="class-slider" class="class-slider" />
            <div class="slider-ticks">
              {Array.from({length: 12}, (_, i) => i + 1).map(n => (
                <span>{n}</span>
              ))}
            </div>
          </div>
        </div>

        <!-- Subjects -->
        <div class="calc-block">
          <div class="calc-label">Subjects <span class="calc-hint">(choose up to 2)</span></div>
          <div class="subject-grid" id="subject-grid"></div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── FIND A TEACHER FORM ──────────────────────────────── -->
  <section class="section" id="find">
    <div class="container form-container">
      <h2 class="section-title">Find a Teacher</h2>
      <p class="section-sub">Fill in the details below and we'll reach out within 24 hours.</p>

      <form class="contact-form" id="find-form" action="https://formspree.io/f/mpqgpdjn" method="POST">
        <input type="hidden" name="_replyto" value="abhinamika@gmail.com" />
        <input type="hidden" name="Class" id="hidden-class" value="" />
        <input type="hidden" name="Subjects" id="hidden-subjects" value="" />

        <div class="form-row">
          <label>
            Your name
            <input type="text" name="name" placeholder="e.g. Priya Sharma" required />
          </label>
          <label>
            Phone / WhatsApp
            <input type="tel" name="phone" placeholder="+91 98765 43210" required />
          </label>
        </div>

        <button type="submit" class="btn-primary btn-full">Request a Match</button>
      </form>

      <div id="form-success" class="form-success hidden">
        Thanks! We'll get back to you within 24 hours.
      </div>
    </div>
  </section>

  <Footer />

</Layout>

<script is:inline>
  document.getElementById('find-form').addEventListener('submit', async function (e) {
    e.preventDefault();

    // Populate hidden fields from calculator state
    document.getElementById('hidden-class').value = 'Class ' + currentClass;
    document.getElementById('hidden-subjects').value = calcSelected.length ? calcSelected.join(', ') : 'None selected';

    var form = this;
    var data = new FormData(form);

    try {
      var res = await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' }
      });
      if (res.ok) {
        form.classList.add('hidden');
        document.getElementById('form-success').classList.remove('hidden');
      } else {
        alert('Something went wrong. Please try again.');
      }
    } catch (_) {
      alert('Network error. Please check your connection and try again.');
    }
  });

  var currentClass = 6;
  var calcSelected = [];

  (function () {
    /* Maths only up to class 10 */
    const SUBJECT_META = {
      Maths:     { color: '#2563eb', icon: '∑', note: 'Class 1–10' },
      Physics:   { color: '#7c3aed', icon: '⚛', note: 'All classes' },
      Chemistry: { color: '#059669', icon: '⚗', note: 'All classes' },
      Biology:   { color: '#dc2626', icon: '🧬', note: 'Class 1–10' },
    };

    const slider      = document.getElementById('class-slider');
    const fill        = document.getElementById('slider-fill');
    const badge       = document.getElementById('class-badge');
    const subjectGrid = document.getElementById('subject-grid');
    const ticks       = document.querySelectorAll('.slider-ticks span');

    function updateFill(val) {
      fill.style.width = ((val - 1) / 11 * 100) + '%';
    }

    function updateTicks(val) {
      ticks.forEach((t, i) => t.classList.toggle('tick-active', i + 1 === val));
    }

    function availableSubjects() {
      /* Maths and Biology only up to class 10 */
      return Object.keys(SUBJECT_META).filter(
        s => (s !== 'Maths' && s !== 'Biology') || currentClass <= 10
      );
    }

    function renderSubjects() {
      const avail = availableSubjects();
      /* drop any selected subject that's no longer available */
      calcSelected = calcSelected.filter(s => avail.includes(s));
      subjectGrid.innerHTML = '';

      avail.forEach(sub => {
        const meta       = SUBJECT_META[sub];
        const isSelected = calcSelected.includes(sub);
        const isDisabled = calcSelected.length >= 2 && !isSelected;

        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'subject-card' +
          (isSelected ? ' selected' : '') +
          (isDisabled ? ' disabled'  : '');
        btn.style.setProperty('--sc', meta.color);

        btn.innerHTML = `
          <span class="sc-icon">${meta.icon}</span>
          <span class="sc-body">
            <span class="sc-name">${sub}</span>
            <span class="sc-note">${meta.note}</span>
          </span>
          <span class="sc-check" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <polyline points="2,7 5.5,10.5 12,3.5" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>`;

        btn.addEventListener('click', () => {
          if (calcSelected.includes(sub)) {
            calcSelected = calcSelected.filter(s => s !== sub);
          } else {
            if (calcSelected.length >= 2) return;
            calcSelected.push(sub);
          }
          renderSubjects();
        });

        subjectGrid.appendChild(btn);
      });
    }

    /* slider */
    slider.addEventListener('input', () => {
      currentClass = Number(slider.value);
      badge.textContent = currentClass;
      badge.style.transform = 'scale(1.25)';
      requestAnimationFrame(() => {
        updateFill(currentClass);
        updateTicks(currentClass);
        setTimeout(() => badge.style.transform = '', 120);
      });
      renderSubjects(); /* may hide/show Maths */
    });

    updateFill(currentClass);
    updateTicks(currentClass);
    renderSubjects();
  })();
</script>

<style>
  /* ── Tokens ────────────────────────────────────────── */
  :root {
    --ink: #171717;
    --ink-2: #4d4d4d;
    --canvas: #ffffff;
    --canvas-soft: #fafafa;
    --border: #e5e5e5;
    --accent: #2563eb;
    --radius-pill: 100px;
    --radius-sm: 6px;
  }

  /* ── Layout ────────────────────────────────────────── */
  .container {
    max-width: 960px;
    margin-inline: auto;
    padding-inline: 24px;
  }

  /* ── Hero ──────────────────────────────────────────── */
  .hero {
    background: var(--ink);
    color: #fff;
    padding: 80px 0 64px;
    overflow: hidden;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }

  .hero-text {
    text-align: left;
  }

  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-headline {
    font-size: clamp(1.8rem, 3.5vw, 2.8rem);
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 1.15;
    margin-bottom: 20px;
  }

  .hero-sub {
    font-size: 1.05rem;
    color: #a3a3a3;
    max-width: 420px;
    margin-bottom: 36px;
    line-height: 1.7;
  }

  @media (max-width: 680px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .hero-text { text-align: center; }
    .hero-sub  { max-width: 100%; }
    .hero-visual { order: -1; }
  }

  /* ── Buttons ───────────────────────────────────────── */
  .btn-primary {
    display: inline-block;
    background: #fff;
    color: var(--ink);
    font-weight: 600;
    font-size: 0.95rem;
    padding: 14px 32px;
    border-radius: var(--radius-pill);
    border: none;
    cursor: pointer;
    transition: opacity 0.15s;
  }

  .btn-primary:hover { opacity: 0.88; }

  .btn-full {
    display: block;
    width: 100%;
    background: var(--ink);
    color: #fff;
    margin-top: 8px;
    text-align: center;
  }

  /* ── Sections ──────────────────────────────────────── */
  .section {
    padding: 80px 0;
    background: var(--canvas);
  }

  .section-alt {
    background: var(--canvas-soft);
  }

  .section-title {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    margin-bottom: 8px;
    text-align: center;
  }

  .section-sub {
    text-align: center;
    color: var(--ink-2);
    margin-bottom: 48px;
  }

  /* ── Steps ─────────────────────────────────────────── */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 24px;
    margin-top: 48px;
  }

  .step-card {
    background: var(--canvas-soft);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px 24px;
    box-shadow: 0 1px 2px rgba(0,0,0,.04), 0 4px 12px rgba(0,0,0,.04);
  }

  .step-num {
    width: 36px;
    height: 36px;
    background: var(--ink);
    color: #fff;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 16px;
  }

  .step-title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .step-desc {
    font-size: 0.9rem;
    color: var(--ink-2);
  }

  /* ── Pricing calculator ────────────────────────────── */
  .calc-card {
    background: var(--canvas);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 40px;
    box-shadow: 0 2px 4px rgba(0,0,0,.04), 0 8px 24px rgba(0,0,0,.06);
    display: flex;
    flex-direction: column;
    gap: 36px;
    max-width: 720px;
    margin-inline: auto;
  }

  @media (max-width: 600px) { .calc-card { padding: 24px 20px; } }

  .calc-block { display: flex; flex-direction: column; gap: 16px; }

  .calc-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--ink-2);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .class-badge {
    background: var(--ink);
    color: #fff;
    font-size: 0.8rem;
    font-weight: 600;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    letter-spacing: 0;
    transition: transform 0.1s;
  }

  .calc-hint {
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    color: var(--ink-2);
    font-size: 0.78rem;
  }

  /* slider */
  .slider-wrap { display: flex; flex-direction: column; gap: 8px; position: relative; }

  .slider-track {
    position: relative;
    height: 4px;
    background: var(--border);
    border-radius: 4px;
    margin: 12px 0 4px;
  }

  .slider-fill {
    position: absolute;
    left: 0; top: 0; bottom: 0;
    background: var(--ink);
    border-radius: 4px;
    /* no transition — must track thumb instantly */
    will-change: width;
    width: 45%;
  }

  .class-slider {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
    width: 100%;
    -webkit-appearance: none;
    appearance: none;
    background: transparent;
    cursor: grab;
    outline: none;
    margin: 0;
    touch-action: none;
  }

  .class-slider:active { cursor: grabbing; }

  .class-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--ink);
    border: 3px solid #fff;
    box-shadow: 0 2px 10px rgba(0,0,0,.3);
    transition: transform 0.12s cubic-bezier(.34,1.56,.64,1), box-shadow 0.12s;
  }

  .class-slider:active::-webkit-slider-thumb {
    transform: scale(1.3);
    box-shadow: 0 4px 20px rgba(0,0,0,.35);
  }

  .class-slider::-moz-range-thumb {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--ink);
    border: 3px solid #fff;
    box-shadow: 0 2px 10px rgba(0,0,0,.3);
    cursor: grab;
  }

  .slider-ticks {
    display: flex;
    justify-content: space-between;
    padding-top: 6px;
  }

  .slider-ticks span {
    font-size: 0.72rem;
    color: var(--ink-2);
    width: 20px;
    text-align: center;
    transition: color 0.15s, font-weight 0.15s;
  }

  .slider-ticks span.tick-active {
    color: var(--ink);
    font-weight: 600;
  }

  /* experience pills */
  .exp-pills {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .exp-pill {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
    padding: 12px 18px;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--canvas);
    cursor: pointer;
    font-family: inherit;
    transition: border-color 0.15s, background 0.15s, transform 0.15s;
  }

  .exp-pill:hover { border-color: #aaa; transform: translateY(-1px); }

  .exp-pill.active {
    border-color: var(--ink);
    background: var(--ink);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(0,0,0,.15);
  }

  .exp-name {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--ink);
  }

  .exp-pill.active .exp-name { color: #fff; }

  .exp-sub {
    font-size: 0.72rem;
    color: var(--ink-2);
  }

  .exp-pill.active .exp-sub { color: rgba(255,255,255,.65); }

  /* subjects — all :global because elements are created in JS */
  .subject-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  @media (max-width: 480px) {
    .subject-grid { grid-template-columns: 1fr; }
  }

  :global(.subject-card) {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 18px;
    border: 1.5px solid #e5e5e5;
    border-radius: 14px;
    background: #fff;
    cursor: pointer;
    font-family: inherit;
    text-align: left;
    transition: border-color 0.18s, background 0.18s, box-shadow 0.18s,
                transform 0.18s cubic-bezier(.34,1.56,.64,1);
    user-select: none;
  }

  :global(.subject-card:hover:not(.disabled)) {
    border-color: var(--sc);
    box-shadow: 0 4px 16px rgba(0,0,0,.08);
    transform: translateY(-2px);
  }

  :global(.subject-card.selected) {
    border-color: var(--sc);
    background: var(--sc);
    box-shadow: 0 6px 20px rgba(0,0,0,.18);
    transform: translateY(-3px);
  }

  :global(.subject-card.disabled) {
    opacity: 0.32;
    cursor: not-allowed;
    transform: none;
    pointer-events: none;
  }

  :global(.sc-icon) {
    font-size: 1.4rem;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(0,0,0,.05);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.18s;
  }

  :global(.subject-card.selected .sc-icon) {
    background: rgba(255,255,255,.18);
  }

  :global(.sc-body) {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
  }

  :global(.sc-name) {
    font-size: 0.95rem;
    font-weight: 600;
    color: #171717;
    transition: color 0.18s;
  }

  :global(.subject-card.selected .sc-name) { color: #fff; }

  :global(.sc-note) {
    font-size: 0.72rem;
    color: #4d4d4d;
    transition: color 0.18s;
  }

  :global(.subject-card.selected .sc-note) { color: rgba(255,255,255,.7); }

  :global(.sc-check) {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    border: 1.5px solid #e5e5e5;
    display: flex;
    align-items: center;
    justify-content: center;
    color: transparent;
    flex-shrink: 0;
    transition: border-color 0.18s, background 0.18s, color 0.18s;
  }

  :global(.subject-card:hover:not(.disabled) .sc-check) {
    border-color: var(--sc);
  }

  :global(.subject-card.selected .sc-check) {
    background: rgba(255,255,255,.25);
    border-color: transparent;
    color: #fff;
  }

  /* result */
  .price-result {
    background: var(--canvas-soft);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 28px 32px;
    text-align: center;
  }

  .price-result-inner {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .price-result-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--ink-2);
  }

  .price-result-amount {
    font-size: 2.4rem;
    font-weight: 600;
    letter-spacing: -0.04em;
    color: var(--ink);
    transition: all 0.25s cubic-bezier(.34,1.56,.64,1);
  }

  .price-result-amount.pop {
    transform: scale(1.08);
  }

  .price-result-unit {
    font-size: 1rem;
    color: var(--ink-2);
    font-weight: 500;
  }

  .price-result-note {
    font-size: 0.78rem;
    color: var(--ink-2);
    margin-top: 10px;
  }

  /* ── Form ──────────────────────────────────────────── */
  .form-container {
    max-width: 640px;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 40px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  @media (max-width: 560px) {
    .form-row { grid-template-columns: 1fr; }
  }

  .contact-form label {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--ink-2);
  }

  .contact-form input,
  .contact-form select {
    padding: 10px 14px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-size: 0.95rem;
    font-family: inherit;
    background: var(--canvas);
    color: var(--ink);
    outline: none;
    transition: border-color 0.15s;
  }

  .contact-form input:focus,
  .contact-form select:focus {
    border-color: var(--ink);
  }

  .form-success {
    text-align: center;
    padding: 32px;
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: 12px;
    color: #166534;
    font-weight: 500;
    margin-top: 40px;
  }

  .hidden { display: none; }

</style>
