  :global(.sc-icon) {
    font-size: 1.4rem;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(0,0,0,.05);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.18s;
