<script is:inline>
/* ── Smart Match Quiz ── */
(function () {
  var answers = {};
  var currentStep = 1;

  var PROFILES = {
    default: {
      title: 'Your ideal teacher profile',
      body: 'Based on your answers, we\'ll match you with a verified teacher who fits your goals, learning style, and schedule. Fill in the form below and we\'ll reach out within 24 hours.'
    }
  };

  function buildProfile(a) {
    var goal  = a[1] || '';
    var style = a[2] || '';
    var body = 'Based on your goal (“' + goal + '”) and preferred learning style (“' + style + '”), we\'ve found the ideal teacher profile for you. Fill in the form below and we\'ll connect you within 24 hours.';
    return { title: 'Your perfect teacher match is ready', body: body };
  }

  function goToStep(step) {
    document.querySelectorAll('.quiz-step').forEach(function(s) { s.classList.remove('active'); });
    var el = document.getElementById('qstep-' + step);
    if (el) el.classList.add('active');

    document.querySelectorAll('.qdot').forEach(function(d) {
      d.classList.toggle('active', parseInt(d.dataset.dot) === step);
    });

    var dots = document.getElementById('quiz-dots');
    if (step === 'result' || step === 'loading') { if (dots) dots.style.display = 'none'; }
    else                                         { if (dots) dots.style.display = ''; }

    currentStep = step;
  }

  function showResult() {
    var p = buildProfile(answers);
    document.getElementById('qr-title').textContent = p.title;
    document.getElementById('qr-body').textContent  = p.body;

    goToStep('loading');
    var ticks = [null,
      document.getElementById('qss-tick-1'),
      document.getElementById('qss-tick-2'),
      document.getElementById('qss-tick-3')
    ];
    var steps = [null,
      document.getElementById('qss-1'),
      document.getElementById('qss-2'),
      document.getElementById('qss-3')
    ];
    steps[1] && steps[1].classList.add('qs-step-active');
    setTimeout(function() {
      ticks[1] && (ticks[1].textContent = '✓');
      steps[1] && steps[1].classList.add('qs-step-done');
      steps[2] && steps[2].classList.add('qs-step-active');
    }, 1500);
    setTimeout(function() {
      ticks[2] && (ticks[2].textContent = '✓');
      steps[2] && steps[2].classList.add('qs-step-done');
      steps[3] && steps[3].classList.add('qs-step-active');
    }, 3000);
    setTimeout(function() {
      ticks[3] && (ticks[3].textContent = '✓');
      steps[3] && steps[3].classList.add('qs-step-done');
      document.getElementById('qs-label').textContent = 'Match found!';
    }, 4500);
    setTimeout(function() {
      goToStep('result');
    }, 5200);
  }

  function resetLoadingState() {
    [1, 2, 3].forEach(function(i) {
      var s = document.getElementById('qss-' + i);
      var t = document.getElementById('qss-tick-' + i);
      if (s) { s.classList.remove('qs-step-active', 'qs-step-done'); }
      if (t) { t.textContent = ''; }
    });
    var label = document.getElementById('qs-label');
    if (label) label.textContent = 'Searching for your perfect teacher…';
  }

  function initQuiz() {
    answers = {};
    resetLoadingState();
    goToStep(1);

    document.querySelectorAll('.quiz-opt').forEach(function(btn) {
      btn.onclick = function() {
        var step = parseInt(this.dataset.step);
        var val  = this.dataset.val;
        answers[step] = val;

        this.closest('.quiz-options').querySelectorAll('.quiz-opt').forEach(function(b) { b.classList.remove('selected'); });
        this.classList.add('selected');

        setTimeout(function() {
          if (step < 2) goToStep(step + 1);
          else showResult();
        }, 250);
      };
    });

    var cta = document.getElementById('quiz-cta');
    if (cta) cta.onclick = function() {
      var findSection = document.getElementById('find');
      if (!findSection) return;
      if (window.lenisInstance) window.lenisInstance.scrollTo(findSection, { offset: -72 });
      else findSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    };

    var restart = document.getElementById('quiz-restart');
    if (restart) restart.onclick = function() {
      answers = {};
      resetLoadingState();
      goToStep(1);
    };
  }

  initQuiz();
  document.addEventListener('astro:after-swap', initQuiz);
})();
</script>

