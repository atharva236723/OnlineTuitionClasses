    display: flex;
    align-items: center;
    justify-content: center;
    color: transparent;
    flex-shrink: 0;
    transition: border-color 0.18s, background 0.18s, color 0.18s;
  }

  :global(.subject-card:hover:not(.disabled) .sc-check) {
    border-color: var(--sc);
  }

  :global(.subject-card.selected .sc-check) {
    background: rgba(255,255,255,.25);
    border-color: transparent;
    color: #fff;
  }

  /* result */
  .price-result {
    background: var(--canvas-soft);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 28px 32px;
    text-align: center;
  }

  .price-result-inner {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .price-result-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
