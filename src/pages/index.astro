  });

  document.getElementById('modal-signup-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    var name  = document.getElementById('msignup-name').value.trim();
    var email = document.getElementById('msignup-email').value.trim();
    var phone = document.getElementById('msignup-phone').value.trim();
    var err   = document.getElementById('msignup-error');

    if (!name)  { err.textContent = 'Please enter your name.';  err.classList.remove('hidden'); return; }
    if (!email || !email.includes('@')) { err.textContent = 'Please enter a valid email.'; err.classList.remove('hidden'); return; }
    if (phone && phone.replace(/\D/g, '').length !== 10) { err.textContent = 'Please enter a valid 10-digit phone number.'; err.classList.remove('hidden'); return; }

    err.classList.add('hidden');
    saveUser({ name: name, email: email, phone: phone });
    closeModal();
    await submitFindForm();
  });

  /* ── Find-form submit ── */
  document.getElementById('find-form').addEventListener('submit', async function (e) {
    e.preventDefault();
    var phoneErrEl = document.getElementById('find-phone-error');
    var phoneVal = (document.querySelector('#find-form [name="phone"]') || {}).value || '';
    var phoneDigits = phoneVal.replace(/\D/g, '');
    if (phoneDigits.length !== 10) {
      phoneErrEl.classList.remove('hidden');
      document.getElementById('calc-error').classList.add('hidden');
      phoneErrEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }
    phoneErrEl.classList.add('hidden');
    var errEl = document.getElementById('calc-error');
    if (calcSelected.length === 0) {
      errEl.classList.remove('hidden');
      errEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }
    errEl.classList.add('hidden');
    var u = getUser();
    if (!u) {
      openModal();
      return;
    }
    await submitFindForm();
  });

  /* Google Sign-In */
  function parseGoogleJwt(credential) {
    var payload = credential.split('.')[1].replace(/-/g, '+').replace(/_/g, '/');
    payload += '=='.slice(0, (4 - payload.length % 4) % 4);
    return JSON.parse(atob(payload));
  }

  async function onGoogleSignIn(response) {
    var data = parseGoogleJwt(response.credential);
    saveUser({ name: data.name, email: data.email, phone: '', picture: data.picture || '' });
    closeModal();
    if (pendingSubmit) await submitFindForm();
  }

  window.addEventListener('load', function () {
    if (typeof google === 'undefined' || !GOOGLE_CLIENT_ID || GOOGLE_CLIENT_ID === 'YOUR_GOOGLE_CLIENT_ID') return;
    google.accounts.id.initialize({ client_id: GOOGLE_CLIENT_ID, callback: onGoogleSignIn });
    google.accounts.id.renderButton(
      document.getElementById('google-btn-modal'),
      { theme: 'outline', size: 'large', width: 360, text: 'continue_with' }
    );
  });

  var currentClass = 6;
  var calcSelected = [];

  (function () {
    /* Maths only up to class 10 */
    const SUBJECT_META = {
      Maths:     { color: '#2563eb', icon: '∑', note: 'Class 1–10' },
      Physics:   { color: '#7c3aed', icon: '⚛', note: 'Coming soon for 11–12' },
      Chemistry: { color: '#059669', icon: '⚗', note: 'All classes' },
      Biology:   { color: '#dc2626', icon: '🧬', note: 'Class 1–10' },
    };

    const slider      = document.getElementById('class-slider');
    const fill        = document.getElementById('slider-fill');
    const badge       = document.getElementById('class-badge');
    const subjectGrid = document.getElementById('subject-grid');
    const ticks       = document.querySelectorAll('.slider-ticks span');

    function updateFill(val) {
      fill.style.width = ((val - 1) / 11 * 100) + '%';
    }

    function updateTicks(val) {
      ticks.forEach((t, i) => t.classList.toggle('tick-active', i + 1 === val));
    }

    function availableSubjects() {
      /* Maths and Biology only up to class 10 */
      return Object.keys(SUBJECT_META).filter(
        s => (s !== 'Maths' && s !== 'Biology') || currentClass <= 10
      );
    }

    function renderSubjects() {
      const avail = availableSubjects();
      /* drop any selected subject that's no longer available or locked */
      calcSelected = calcSelected.filter(s => {
        if (!avail.includes(s)) return false;
        if (s === 'Physics' && currentClass >= 11) return false;
        return true;
      });
      subjectGrid.innerHTML = '';

      avail.forEach(sub => {
        const meta            = SUBJECT_META[sub];
        const isSelected      = calcSelected.includes(sub);
        const isPhysicsLocked = sub === 'Physics' && currentClass >= 11;
        const isDisabled      = isPhysicsLocked || (calcSelected.length >= 2 && !isSelected);

        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'subject-card' +
          (isSelected ? ' selected' : '') +
          (isDisabled ? ' disabled'  : '');
        btn.style.setProperty('--sc', meta.color);

        btn.innerHTML = `
          <span class="sc-icon">${meta.icon}</span>
          <span class="sc-body">
            <span class="sc-name">${sub}</span>
            <span class="sc-note">${meta.note}</span>
          </span>
          <span class="sc-check" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <polyline points="2,7 5.5,10.5 12,3.5" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>`;

        btn.addEventListener('click', () => {
          if (calcSelected.includes(sub)) {
            calcSelected = calcSelected.filter(s => s !== sub);
          } else {
            if (calcSelected.length >= 2) return;
            calcSelected.push(sub);
          }
          if (calcSelected.length > 0) {
            var errEl = document.getElementById('calc-error');
            if (errEl) errEl.classList.add('hidden');
          }
          renderSubjects();
        });

        subjectGrid.appendChild(btn);
      });
    }

    /* slider */
    slider.addEventListener('input', () => {
      currentClass = Number(slider.value);
      badge.textContent = currentClass;
      badge.style.transform = 'scale(1.25)';
      requestAnimationFrame(() => {
        updateFill(currentClass);
        updateTicks(currentClass);
        setTimeout(() => badge.style.transform = '', 120);
      });
      renderSubjects(); /* may hide/show Maths */
    });

    updateFill(currentClass);
    updateTicks(currentClass);
    renderSubjects();
  })();

  /* ── Batch registration ── */
  (function () {
    var batchSize = 2;

    var pillsWrap = document.getElementById('batch-size-pills');
    var extraWrap = document.getElementById('batch-extra-members');
    var batchHiddenSize = document.getElementById('batch-hidden-size');

    function renderExtraMembers() {
      extraWrap.innerHTML = '';
      for (var i = 3; i <= batchSize; i++) {
        var num = i;
        var block = document.createElement('div');
        block.className = 'batch-member-block';
        block.innerHTML =
          '<p class="batch-member-label">Member ' + num + '</p>' +
          '<div class="batch-member-row">' +
            '<label>Name<input type="text" name="member' + num + '_name" placeholder="Friend\'s name" required /></label>' +
            '<label>Phone / WhatsApp<input type="tel" name="member' + num + '_phone" placeholder="+91 98765 43210" required /></label>' +
          '</div>';
        extraWrap.appendChild(block);
      }
    }

    pillsWrap.addEventListener('click', function (e) {
      var pill = e.target.closest('.batch-size-pill');
      if (!pill) return;
      batchSize = Number(pill.dataset.size);
      batchHiddenSize.value = batchSize;
      pillsWrap.querySelectorAll('.batch-size-pill').forEach(function (p) {
        p.classList.toggle('active', Number(p.dataset.size) === batchSize);
      });
      renderExtraMembers();
    });

    document.getElementById('batch-form').addEventListener('submit', async function (e) {
      e.preventDefault();
      var phoneErrEl = document.getElementById('batch-phone-error');
      var telInputs = document.querySelectorAll('#batch-form [type="tel"]');
      var phoneOk = Array.from(telInputs).every(function(inp) {
        return inp.value.replace(/\D/g, '').length === 10;
      });
      if (!phoneOk) {
        phoneErrEl.classList.remove('hidden');
        document.getElementById('batch-error').classList.add('hidden');
        phoneErrEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }
      phoneErrEl.classList.add('hidden');
      var errEl = document.getElementById('batch-error');
      if (calcSelected.length === 0) {
        errEl.classList.remove('hidden');
        errEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }
      errEl.classList.add('hidden');

      document.getElementById('batch-hidden-class').value    = 'Class ' + currentClass;
      document.getElementById('batch-hidden-subjects').value = calcSelected.join(', ');

      var form = document.getElementById('batch-form');
      var data = new FormData(form);

      try {
        var res = await fetch('https://formspree.io/f/mpqgpdjn', {
          method: 'POST', body: data, headers: { Accept: 'application/json' }
        });
        if (res.ok) {
          form.classList.add('hidden');
          document.getElementById('batch-success').classList.remove('hidden');
        } else {
          alert('Something went wrong. Please try again.');
        }
      } catch (_) {
        alert('Network error. Please check your connection and try again.');
      }
    });

    renderExtraMembers();
  })();
</script>

<style>
  /* ── Tokens ────────────────────────────────────────── */
  :root {
    --accent: #2563eb;
  }

  /* ── Layout ────────────────────────────────────────── */
  .container {
    max-width: 960px;
    margin-inline: auto;
    padding-inline: 24px;
  }

  /* ── Hero ──────────────────────────────────────────── */
  .hero {
    background: var(--surface-dark, #171717);
    color: #fff;
    padding: clamp(48px, 8vw, 96px) 0 clamp(40px, 6vw, 72px);
    overflow: hidden;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }

  .hero-text {
    text-align: left;
  }

  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-headline {
    font-size: clamp(1.75rem, 4vw, 2.8rem);
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 1.15;
    margin-bottom: 20px;
  }

  .hero-sub {
    font-size: clamp(0.95rem, 2vw, 1.05rem);
    color: #a3a3a3;
    max-width: 420px;
    margin-bottom: 36px;
    line-height: 1.7;
  }

  @media (max-width: 680px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .hero-text { text-align: center; }
    .hero-sub  { max-width: 100%; margin-inline: auto; }
    .hero-visual { order: -1; }
  }

  /* ── Buttons ───────────────────────────────────────── */
  .btn-primary {
    display: inline-block;
    background: #fff;
    color: #171717;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 14px 32px;
    border-radius: var(--radius-pill);
    border: none;
    cursor: pointer;
    transition: opacity 0.15s, transform 0.15s cubic-bezier(.34,1.56,.64,1);
  }

  .btn-primary:hover  { opacity: 0.88; transform: translateY(-2px); }
  .btn-primary:active { transform: scale(0.97); }

  .btn-full {
    display: block;
    width: 100%;
    background: var(--ink);
    color: var(--canvas);
    margin-top: 8px;
    text-align: center;
  }

  /* ── Sections ──────────────────────────────────────── */
  .section {
    padding: clamp(48px, 8vw, 80px) 0;
    background: var(--canvas);
  }

  .section-alt {
    background: var(--canvas-soft);
  }

  .section-title {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    margin-bottom: 8px;
    text-align: center;
  }

  .section-sub {
    text-align: center;
    color: var(--ink-2);
    margin-bottom: 48px;
  }

  /* ── Steps ─────────────────────────────────────────── */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 24px;
    margin-top: 48px;
  }

  .step-card {
    background: var(--canvas-soft);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px 24px;
    box-shadow: 0 1px 2px rgba(0,0,0,.04), 0 4px 12px rgba(0,0,0,.04);
    transition: transform 0.2s cubic-bezier(.34,1.56,.64,1), box-shadow 0.2s;
  }
  .step-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 2px 4px rgba(0,0,0,.06), 0 12px 28px rgba(0,0,0,.1);
  }

  .step-num {
    width: 36px;
    height: 36px;
    background: var(--ink);
    color: var(--canvas);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 16px;
  }

  .step-title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .step-desc {
    font-size: 0.9rem;
    color: var(--ink-2);
  }

  /* ── Pricing calculator ────────────────────────────── */
  .calc-card {
    background: var(--canvas);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 40px;
    box-shadow: 0 2px 4px rgba(0,0,0,.04), 0 8px 24px rgba(0,0,0,.06);
    display: flex;
    flex-direction: column;
    gap: 36px;
    max-width: 720px;
    margin-inline: auto;
  }

  @media (max-width: 600px) { .calc-card { padding: 24px 20px; } }

  .calc-block { display: flex; flex-direction: column; gap: 16px; }

  .calc-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--ink-2);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .class-badge {
    background: var(--ink);
    color: var(--canvas);
    font-size: 0.8rem;
    font-weight: 600;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    letter-spacing: 0;
    transition: transform 0.1s;
  }

  .calc-hint {
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    color: var(--ink-2);
    font-size: 0.78rem;
  }

  /* slider */
  .slider-wrap { display: flex; flex-direction: column; gap: 8px; position: relative; }

  .slider-track {
    position: relative;
    height: 4px;
    background: var(--border);
    border-radius: 4px;
    margin: 12px 0 4px;
  }

  .slider-fill {
    position: absolute;
    left: 0; top: 0; bottom: 0;
    background: var(--ink);
    border-radius: 4px;
    /* no transition — must track thumb instantly */
    will-change: width;
    width: 45%;
  }

  .class-slider {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
    width: 100%;
    -webkit-appearance: none;
    appearance: none;
    background: transparent;
    cursor: grab;
    outline: none;
    margin: 0;
    touch-action: none;
  }

  .class-slider:active { cursor: grabbing; }

  .class-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--ink);
    border: 3px solid #fff;
    box-shadow: 0 2px 10px rgba(0,0,0,.3);
    transition: transform 0.12s cubic-bezier(.34,1.56,.64,1), box-shadow 0.12s;
  }

  .class-slider:active::-webkit-slider-thumb {
    transform: scale(1.3);
    box-shadow: 0 4px 20px rgba(0,0,0,.35);
  }

  .class-slider::-moz-range-thumb {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--ink);
    border: 3px solid #fff;
    box-shadow: 0 2px 10px rgba(0,0,0,.3);
    cursor: grab;
  }

  .slider-ticks {
    display: flex;
    justify-content: space-between;
    padding-top: 6px;
  }

  .slider-ticks span {
    font-size: 0.72rem;
    color: var(--ink-2);
    width: 20px;
    text-align: center;
    transition: color 0.15s, font-weight 0.15s;
  }

  .slider-ticks span.tick-active {
    color: var(--ink);
    font-weight: 600;
  }

  /* experience pills */
  .exp-pills {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .exp-pill {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
    padding: 12px 18px;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--canvas);
    cursor: pointer;
    font-family: inherit;
    transition: border-color 0.15s, background 0.15s, transform 0.15s;
  }

  .exp-pill:hover { border-color: #aaa; transform: translateY(-1px); }

  .exp-pill.active {
    border-color: var(--ink);
    background: var(--ink);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(0,0,0,.15);
  }

  .exp-name {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--ink);
  }

  .exp-pill.active .exp-name { color: #fff; }

  .exp-sub {
    font-size: 0.72rem;
    color: var(--ink-2);
  }

  .exp-pill.active .exp-sub { color: rgba(255,255,255,.65); }

  /* subjects — all :global because elements are created in JS */
  .subject-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  @media (max-width: 480px) {
    .subject-grid { grid-template-columns: 1fr; }
  }

  :global(.subject-card) {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 18px;
    border: 1.5px solid var(--border);
    border-radius: 14px;
    background: var(--canvas);
