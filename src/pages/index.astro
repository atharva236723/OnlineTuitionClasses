---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import HeroAnimation from '../components/HeroAnimation.astro';

const steps = [
  { num: "1", title: "Select class & subject", desc: "Tell us which class you're in and which subject you need help with." },
  { num: "2", title: "Choose your budget", desc: "Pick a pricing tier that works for you — no hidden fees." },
  { num: "3", title: "Get matched in 24 hours", desc: "We'll connect you with a verified teacher suited to your needs." },
  { num: "4", title: "Start with a free demo", desc: "Attend a free demo class before committing to anything." },
];

const pricing = [
  { range: "Class 1–5",   price: "₹300 – ₹600 / hr" },
  { range: "Class 6–8",   price: "₹500 – ₹900 / hr" },
  { range: "Class 9–10",  price: "₹700 – ₹1,200 / hr" },
  { range: "Class 11–12", price: "₹900 – ₹1,800 / hr" },
];
---

<Layout>

  <Nav />

  <!-- ── HERO ────────────────────────────────────────────── -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text reveal">
        <h1 class="hero-headline">Online Tuition for Class 1–12<br />Verified Teachers.</h1>
        <p class="hero-sub">Choose your subject, your budget, and get matched with a teacher in 24 hours.</p>
        <a href="#find" class="btn-primary">Find a Teacher</a>
      </div>
      <div class="hero-visual reveal" style="transition-delay:0.12s">
        <HeroAnimation />
      </div>
    </div>
  </section>

  <!-- ── HOW IT WORKS ─────────────────────────────────────── -->
  <section class="section" id="how">
    <div class="container">
      <h2 class="section-title reveal">How it works</h2>
      <div class="steps-grid reveal-stagger reveal">
        {steps.map(s => (
          <div class="step-card">
            <div class="step-num">{s.num}</div>
            <h3 class="step-title">{s.title}</h3>
            <p class="step-desc">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── PRICING ──────────────────────────────────────────── -->
  <section class="section section-alt" id="pricing">
    <div class="container">
      <h2 class="section-title reveal">Pricing</h2>
      <p class="section-sub reveal">Select your class and subject to get started.</p>

      <div class="calc-card reveal">

        <!-- Class slider -->
        <div class="calc-block">
          <div class="calc-label">Class <span id="class-badge" class="class-badge">6</span></div>
          <div class="slider-wrap">
            <div class="slider-track">
              <div class="slider-fill" id="slider-fill"></div>
              <input type="range" min="1" max="12" value="6" id="class-slider" class="class-slider" />
            </div>
            <div class="slider-ticks">
              {Array.from({length: 12}, (_, i) => i + 1).map(n => (
                <span>{n}</span>
              ))}
            </div>
          </div>
        </div>

        <!-- Subjects -->
        <div class="calc-block">
          <div class="calc-label">Subjects <span class="calc-hint">(choose up to 2)</span></div>
          <div class="subject-grid" id="subject-grid"></div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── FIND A TEACHER FORM ──────────────────────────────── -->
  <section class="section" id="find">
    <div class="container form-container">
      <h2 class="section-title reveal">Find a Teacher</h2>
      <p class="section-sub reveal">Fill in the details below and we'll reach out within 24 hours.</p>

      <form class="contact-form reveal" id="find-form" action="https://formspree.io/f/mpqgpdjn" method="POST">
        <input type="hidden" name="_replyto" value="abhinamika@gmail.com" />
        <input type="hidden" name="Class" id="hidden-class" value="" />
        <input type="hidden" name="Subjects" id="hidden-subjects" value="" />
        <input type="hidden" name="UserName" id="hidden-username" value="" />
        <input type="hidden" name="UserEmail" id="hidden-useremail" value="" />

        <div class="form-row">
          <label>
            Your name
            <input type="text" name="name" placeholder="e.g. Priya Sharma" required />
          </label>
          <label>
            Phone / WhatsApp
            <input type="tel" name="phone" placeholder="+91 98765 43210" required />
          </label>
        </div>

        <div id="find-phone-error" class="calc-error hidden" role="alert">
          Please enter a valid 10-digit phone number.
        </div>
        <div id="calc-error" class="calc-error hidden" role="alert">
          Please select your class and at least one subject above before requesting a match.
        </div>
        <button type="submit" class="btn-primary btn-full">Request a Match</button>
      </form>

      <div id="form-success" class="form-success hidden" aria-live="polite">
        <div class="fs-icon">
          <svg viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle class="fs-circle" cx="26" cy="26" r="24" stroke="currentColor" stroke-width="2.5" fill="none"/>
            <path class="fs-check" d="M14 26.5l8.5 8.5 15-16" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="fs-title">Request sent!</h3>
        <p class="fs-body">We'll match you with a verified teacher and reach out within <strong>24 hours</strong>.</p>
        <p class="fs-sub">Check your WhatsApp and email for updates.</p>
      </div>
    </div>
  </section>

  <!-- ── BATCH REGISTRATION ────────────────────────────── -->
  <section class="section section-alt" id="batch">
    <div class="container">
      <h2 class="section-title reveal">Study in a batch</h2>
      <p class="section-sub reveal">Have friends who want to learn the same subject? Register as a group — same verified teacher, one shared schedule, lower cost per student.</p>

      <div class="batch-layout">

        <!-- Benefits -->
        <div class="batch-benefits reveal-stagger reveal">
          <div class="batch-benefit">
            <div class="bb-icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2a8 8 0 1 0 0 16A8 8 0 0 0 10 2zm0 14.5a6.5 6.5 0 1 1 0-13 6.5 6.5 0 0 1 0 13zm-.75-9.5v3.19l2.72 1.63-.56.93-3.16-1.9V7h1z" fill="currentColor"/></svg>
            </div>
            <div>
              <p class="bb-title">One teacher, one schedule</p>
              <p class="bb-desc">All batch members attend the same live sessions — no coordination chaos.</p>
            </div>
          </div>
          <div class="batch-benefit">
            <div class="bb-icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M13 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0zM5 8a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm14 0a2 2 0 1 1-4 0 2 2 0 0 1 4 0zM1 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1H1zm7 0h4a4.98 4.98 0 0 0-.98-2.63C10.43 10.5 9.24 10 8 10s-2.43.5-3.02 1.37A4.98 4.98 0 0 0 4 14h4zm5.35-1.22C14.07 13.26 15 13.8 15 14h4s1 0 1-1-1-4-6-4c-1.08 0-2.04.24-2.84.62.52.6.89 1.33 1.19 2.16z" fill="currentColor"/></svg>
            </div>
            <div>
              <p class="bb-title">2 to 5 students</p>
              <p class="bb-desc">Small group, big impact. Minimum 2, maximum 5 students per batch.</p>
            </div>
          </div>
          <div class="batch-benefit">
            <div class="bb-icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M9 2a7 7 0 1 0 0 14A7 7 0 0 0 9 2zm1 10.5H8V9h2v3.5zm0-5H8V5.5h2V7.5z" fill="currentColor"/></svg>
            </div>
            <div>
              <p class="bb-title">Uses your class &amp; subject</p>
              <p class="bb-desc">Batch registration uses the class and subjects you selected in the pricing section above.</p>
            </div>
          </div>
        </div>

        <!-- Form card -->
        <div class="batch-card reveal" style="transition-delay:0.1s">

          <!-- Batch size picker -->
          <div class="batch-size-row">
            <p class="batch-field-label">Batch size</p>
            <div class="batch-size-pills" id="batch-size-pills">
              {[2, 3, 4, 5].map(n => (
                <button type="button" class:list={['batch-size-pill', n === 2 && 'active']} data-size={n}>
                  <span class="bsp-num">{n}</span>
                  <span class="bsp-label">student{n > 1 ? 's' : ''}</span>
                </button>
              ))}
            </div>
          </div>

          <form id="batch-form" class="batch-form-inner" novalidate>
            <input type="hidden" name="_replyto" value="abhinamika@gmail.com" />
            <input type="hidden" name="Type"     value="Batch Registration" />
            <input type="hidden" name="BatchSize" id="batch-hidden-size"     value="2" />
            <input type="hidden" name="Class"    id="batch-hidden-class"    value="" />
            <input type="hidden" name="Subjects" id="batch-hidden-subjects" value="" />

            <!-- Organizer (always shown) -->
            <div class="batch-member-block">
              <p class="batch-member-label">You (organiser)</p>
              <div class="batch-member-row">
                <label>
                  Name
                  <input type="text"  name="member1_name"  placeholder="Your name"  required />
                </label>
                <label>
                  Phone / WhatsApp
                  <input type="tel"   name="member1_phone" placeholder="+91 98765 43210" required />
                </label>
              </div>
            </div>

            <!-- Member 2 (always shown, min batch = 2) -->
            <div class="batch-member-block">
              <p class="batch-member-label">Member 2</p>
              <div class="batch-member-row">
                <label>
                  Name
                  <input type="text"  name="member2_name"  placeholder="Friend's name"  required />
                </label>
                <label>
                  Phone / WhatsApp
                  <input type="tel"   name="member2_phone" placeholder="+91 98765 43210" required />
                </label>
              </div>
            </div>

            <!-- Members 3-5 revealed dynamically by JS -->
            <div id="batch-extra-members"></div>

            <div id="batch-phone-error" class="calc-error hidden" role="alert">
              Please enter valid 10-digit phone numbers for all members.
            </div>
            <div id="batch-error" class="calc-error hidden" role="alert">
              Please select a class and at least one subject in the Pricing section above before registering.
            </div>

            <button type="submit" class="btn-primary btn-full">Register for batch</button>
          </form>

          <div id="batch-success" class="form-success hidden" aria-live="polite">
            <div class="fs-icon">
              <svg viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle class="fs-circle" cx="26" cy="26" r="24" stroke="currentColor" stroke-width="2.5" fill="none"/>
                <path class="fs-check" d="M14 26.5l8.5 8.5 15-16" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="fs-title">Batch registered!</h3>
            <p class="fs-body">We'll match your group with a verified teacher and reach out within <strong>24 hours</strong>.</p>
            <p class="fs-sub">Check your WhatsApp and email for updates.</p>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- ── AUTH MODAL ─────────────────────────────────────── -->
  <div id="auth-modal" class="modal-backdrop hidden" role="dialog" aria-modal="true" aria-labelledby="modal-title">
    <div class="modal-card">
      <button class="modal-close" id="modal-close" aria-label="Close">&times;</button>
      <p class="modal-eyebrow">One more step</p>
      <h2 class="modal-title" id="modal-title">Sign in to continue</h2>
      <p class="modal-sub">Create a free account or log in to request a teacher match.</p>

      <!-- Google Sign-In -->
      <div id="google-btn-modal" class="google-btn-wrap"></div>
      <div class="auth-divider"><span>or</span></div>

      <div class="auth-tabs">
        <button class="auth-tab active" id="mtab-login" type="button">Log in</button>
        <button class="auth-tab" id="mtab-signup" type="button">Sign up</button>
      </div>

      <!-- Modal login form -->
      <form id="modal-login-form" class="auth-form" novalidate>
        <label>
          Email address
          <input type="email" id="mlogin-email" placeholder="you@example.com" required />
        </label>
        <p class="auth-error hidden" id="mlogin-error">No account found with that email.</p>
        <button type="submit" class="btn-primary btn-full-dark">Log in &amp; submit</button>
        <p class="auth-switch">
          No account?
          <button type="button" class="link-btn" id="mgo-signup">Sign up instead</button>
        </p>
      </form>

      <!-- Modal signup form -->
      <form id="modal-signup-form" class="auth-form hidden" novalidate>
        <div class="mform-row">
          <label>
            Full name
            <input type="text" id="msignup-name" placeholder="Priya Sharma" required />
          </label>
          <label>
            Email
            <input type="email" id="msignup-email" placeholder="you@example.com" required />
          </label>
        </div>
        <label>
          Phone / WhatsApp <span class="opt">(optional)</span>
          <input type="tel" id="msignup-phone" placeholder="+91 98765 43210" />
        </label>
        <p class="auth-error hidden" id="msignup-error"></p>
        <button type="submit" class="btn-primary btn-full-dark">Create account &amp; submit</button>
        <p class="auth-switch">
          Already have an account?
          <button type="button" class="link-btn" id="mgo-login">Log in</button>
        </p>
      </form>
    </div>
  </div>

  <Footer />

</Layout>

<script src="https://accounts.google.com/gsi/client" async></script>
<script is:inline>
  var GOOGLE_CLIENT_ID = '945888240197-9in6fs6u0gmtuib5b3de70ek7ceam4j4.apps.googleusercontent.com';
  var USER_KEY = 'otc_user';

  function getUser() {
    try { return JSON.parse(localStorage.getItem(USER_KEY)); } catch (_) { return null; }
  }
  function saveUser(u) {
    localStorage.setItem(USER_KEY, JSON.stringify(u));
    window.dispatchEvent(new Event('otc-auth-change'));
  }

  async function submitFindForm() {
    var u = getUser();
    document.getElementById('hidden-class').value    = 'Class ' + currentClass;
    document.getElementById('hidden-subjects').value = calcSelected.length ? calcSelected.join(', ') : 'None selected';
    if (u) {
      document.getElementById('hidden-username').value  = u.name  || '';
      document.getElementById('hidden-useremail').value = u.email || '';
    }

    var form = document.getElementById('find-form');
    var data = new FormData(form);

    try {
      var res = await fetch(form.action, { method: 'POST', body: data, headers: { Accept: 'application/json' } });
      if (res.ok) {
        form.classList.add('hidden');
        document.getElementById('form-success').classList.remove('hidden');
      } else {
        alert('Something went wrong. Please try again.');
      }
    } catch (_) {
      alert('Network error. Please check your connection and try again.');
    }
  }

  /* ── Auth modal logic ── */
  var pendingSubmit = false;

  function openModal() {
    var modal = document.getElementById('auth-modal');
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    var modal = document.getElementById('auth-modal');
    modal.classList.add('hidden');
    document.body.style.overflow = '';
    pendingSubmit = false;
  }

  function switchModalTab(show) {
    var lf = document.getElementById('modal-login-form');
    var sf = document.getElementById('modal-signup-form');
    var tl = document.getElementById('mtab-login');
    var ts = document.getElementById('mtab-signup');
    if (show === 'login') {
      lf.classList.remove('hidden'); sf.classList.add('hidden');
      tl.classList.add('active');    ts.classList.remove('active');
    } else {
      sf.classList.remove('hidden'); lf.classList.add('hidden');
      ts.classList.add('active');    tl.classList.remove('active');
    }
  }

  document.getElementById('modal-close').addEventListener('click', closeModal);
  document.getElementById('auth-modal').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
  });
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeModal(); });

  document.getElementById('mtab-login').addEventListener('click',  function() { switchModalTab('login'); });
  document.getElementById('mtab-signup').addEventListener('click', function() { switchModalTab('signup'); });
  document.getElementById('mgo-signup').addEventListener('click',  function() { switchModalTab('signup'); });
  document.getElementById('mgo-login').addEventListener('click',   function() { switchModalTab('login'); });

  document.getElementById('modal-login-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    var email = document.getElementById('mlogin-email').value.trim().toLowerCase();
    var err   = document.getElementById('mlogin-error');
    var u     = getUser();
    if (u && u.email.toLowerCase() === email) {
      err.classList.add('hidden');
      closeModal();
      await submitFindForm();
    } else {
      err.classList.remove('hidden');
    }
  });

  document.getElementById('modal-signup-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    var name  = document.getElementById('msignup-name').value.trim();
    var email = document.getElementById('msignup-email').value.trim();
    var phone = document.getElementById('msignup-phone').value.trim();
    var err   = document.getElementById('msignup-error');

    if (!name)  { err.textContent = 'Please enter your name.';  err.classList.remove('hidden'); return; }
    if (!email || !email.includes('@')) { err.textContent = 'Please enter a valid email.'; err.classList.remove('hidden'); return; }
    if (phone && phone.replace(/\D/g, '').length !== 10) { err.textContent = 'Please enter a valid 10-digit phone number.'; err.classList.remove('hidden'); return; }

    err.classList.add('hidden');
    saveUser({ name: name, email: email, phone: phone });
    closeModal();
    await submitFindForm();
  });

  /* ── Find-form submit ── */
  document.getElementById('find-form').addEventListener('submit', async function (e) {
    e.preventDefault();
    var phoneErrEl = document.getElementById('find-phone-error');
    var phoneVal = (document.querySelector('#find-form [name="phone"]') || {}).value || '';
    var phoneDigits = phoneVal.replace(/\D/g, '');
    if (phoneDigits.length !== 10) {
      phoneErrEl.classList.remove('hidden');
      document.getElementById('calc-error').classList.add('hidden');
      phoneErrEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }
    phoneErrEl.classList.add('hidden');
    var errEl = document.getElementById('calc-error');
    if (calcSelected.length === 0) {
      errEl.classList.remove('hidden');
      errEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }
    errEl.classList.add('hidden');
    var u = getUser();
    if (!u) {
      openModal();
      return;
    }
    await submitFindForm();
  });

  /* Google Sign-In */
  function parseGoogleJwt(credential) {
    var payload = credential.split('.')[1].replace(/-/g, '+').replace(/_/g, '/');
    return JSON.parse(atob(payload));
  }

  async function onGoogleSignIn(response) {
    var data = parseGoogleJwt(response.credential);
    saveUser({ name: data.name, email: data.email, phone: '', picture: data.picture || '' });
    closeModal();
    if (pendingSubmit) await submitFindForm();
  }

  window.addEventListener('load', function () {
    if (typeof google === 'undefined' || !GOOGLE_CLIENT_ID || GOOGLE_CLIENT_ID === 'YOUR_GOOGLE_CLIENT_ID') return;
    google.accounts.id.initialize({ client_id: GOOGLE_CLIENT_ID, callback: onGoogleSignIn });
    google.accounts.id.renderButton(
      document.getElementById('google-btn-modal'),
      { theme: 'outline', size: 'large', width: 360, text: 'continue_with' }
    );
  });

  var currentClass = 6;
  var calcSelected = [];

  (function () {
    /* Maths only up to class 10 */
    const SUBJECT_META = {
      Maths:     { color: '#2563eb', icon: '∑', note: 'Class 1–10' },
      Physics:   { color: '#7c3aed', icon: '⚛', note: 'Coming soon for 11–12' },
      Chemistry: { color: '#059669', icon: '⚗', note: 'All classes' },
      Biology:   { color: '#dc2626', icon: '🧬', note: 'Class 1–10' },
    };

    const slider      = document.getElementById('class-slider');
    const fill        = document.getElementById('slider-fill');
    const badge       = document.getElementById('class-badge');
    const subjectGrid = document.getElementById('subject-grid');
    const ticks       = document.querySelectorAll('.slider-ticks span');

    function updateFill(val) {
      fill.style.width = ((val - 1) / 11 * 100) + '%';
    }

    function updateTicks(val) {
      ticks.forEach((t, i) => t.classList.toggle('tick-active', i + 1 === val));
    }

    function availableSubjects() {
      /* Maths and Biology only up to class 10 */
      return Object.keys(SUBJECT_META).filter(
        s => (s !== 'Maths' && s !== 'Biology') || currentClass <= 10
      );
    }

    function renderSubjects() {
      const avail = availableSubjects();
      /* drop any selected subject that's no longer available or locked */
      calcSelected = calcSelected.filter(s => {
        if (!avail.includes(s)) return false;
        if (s === 'Physics' && currentClass >= 11) return false;
        return true;
      });
      subjectGrid.innerHTML = '';

      avail.forEach(sub => {
        const meta            = SUBJECT_META[sub];
        const isSelected      = calcSelected.includes(sub);
        const isPhysicsLocked = sub === 'Physics' && currentClass >= 11;
        const isDisabled      = isPhysicsLocked || (calcSelected.length >= 2 && !isSelected);

        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'subject-card' +
          (isSelected ? ' selected' : '') +
          (isDisabled ? ' disabled'  : '');
        btn.style.setProperty('--sc', meta.color);

        btn.innerHTML = `
          <span class="sc-icon">${meta.icon}</span>
          <span class="sc-body">
            <span class="sc-name">${sub}</span>
            <span class="sc-note">${meta.note}</span>
          </span>
          <span class="sc-check" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <polyline points="2,7 5.5,10.5 12,3.5" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>`;

        btn.addEventListener('click', () => {
          if (calcSelected.includes(sub)) {
            calcSelected = calcSelected.filter(s => s !== sub);
          } else {
            if (calcSelected.length >= 2) return;
            calcSelected.push(sub);
          }
          if (calcSelected.length > 0) {
            var errEl = document.getElementById('calc-error');
            if (errEl) errEl.classList.add('hidden');
          }
          renderSubjects();
        });

        subjectGrid.appendChild(btn);
      });
    }

    /* slider */
    slider.addEventListener('input', () => {
      currentClass = Number(slider.value);
      badge.textContent = currentClass;
      badge.style.transform = 'scale(1.25)';
      requestAnimationFrame(() => {
        updateFill(currentClass);
        updateTicks(currentClass);
        setTimeout(() => badge.style.transform = '', 120);
      });
      renderSubjects(); /* may hide/show Maths */
    });

    updateFill(currentClass);
    updateTicks(currentClass);
    renderSubjects();
  })();

  /* ── Batch registration ── */
  (function () {
    var batchSize = 2;

    var pillsWrap = document.getElementById('batch-size-pills');
    var extraWrap = document.getElementById('batch-extra-members');
    var batchHiddenSize = document.getElementById('batch-hidden-size');

    function renderExtraMembers() {
      extraWrap.innerHTML = '';
      for (var i = 3; i <= batchSize; i++) {
        var num = i;
        var block = document.createElement('div');
        block.className = 'batch-member-block';
        block.innerHTML =
          '<p class="batch-member-label">Member ' + num + '</p>' +
          '<div class="batch-member-row">' +
            '<label>Name<input type="text" name="member' + num + '_name" placeholder="Friend\'s name" required /></label>' +
            '<label>Phone / WhatsApp<input type="tel" name="member' + num + '_phone" placeholder="+91 98765 43210" required /></label>' +
          '</div>';
        extraWrap.appendChild(block);
      }
    }

    pillsWrap.addEventListener('click', function (e) {
      var pill = e.target.closest('.batch-size-pill');
      if (!pill) return;
      batchSize = Number(pill.dataset.size);
      batchHiddenSize.value = batchSize;
      pillsWrap.querySelectorAll('.batch-size-pill').forEach(function (p) {
        p.classList.toggle('active', Number(p.dataset.size) === batchSize);
      });
      renderExtraMembers();
    });

    document.getElementById('batch-form').addEventListener('submit', async function (e) {
      e.preventDefault();
      var phoneErrEl = document.getElementById('batch-phone-error');
      var telInputs = document.querySelectorAll('#batch-form [type="tel"]');
      var phoneOk = Array.from(telInputs).every(function(inp) {
        return inp.value.replace(/\D/g, '').length === 10;
      });
      if (!phoneOk) {
        phoneErrEl.classList.remove('hidden');
        document.getElementById('batch-error').classList.add('hidden');
        phoneErrEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }
      phoneErrEl.classList.add('hidden');
      var errEl = document.getElementById('batch-error');
      if (calcSelected.length === 0) {
        errEl.classList.remove('hidden');
        errEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }
      errEl.classList.add('hidden');

      document.getElementById('batch-hidden-class').value    = 'Class ' + currentClass;
      document.getElementById('batch-hidden-subjects').value = calcSelected.join(', ');

      var form = document.getElementById('batch-form');
      var data = new FormData(form);

      try {
        var res = await fetch('https://formspree.io/f/mpqgpdjn', {
          method: 'POST', body: data, headers: { Accept: 'application/json' }
        });
        if (res.ok) {
          form.classList.add('hidden');
          document.getElementById('batch-success').classList.remove('hidden');
        } else {
          alert('Something went wrong. Please try again.');
        }
      } catch (_) {
        alert('Network error. Please check your connection and try again.');
      }
    });

    renderExtraMembers();
  })();
</script>

