  :global(.sc-name) {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--ink);
    transition: color 0.18s;
  }

  :global(.subject-card.selected .sc-name) { color: #fff; }

  :global(.sc-note) {
    font-size: 0.72rem;
    color: var(--ink-2);
    transition: color 0.18s;
  }

  :global(.subject-card.selected .sc-note) { color: rgba(255,255,255,.7); }

  :global(.sc-check) {
