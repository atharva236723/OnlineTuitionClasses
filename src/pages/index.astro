    color: var(--ink-2);
    margin-top: 10px;
  }

  /* ── Form ──────────────────────────────────────────── */
  .form-container {
    max-width: 640px;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 40px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  @media (max-width: 560px) {
    .form-row { grid-template-columns: 1fr; }
  }

  .contact-form label {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--ink-2);
  }

  .contact-form input,
  .contact-form select {
    padding: 10px 14px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-size: 0.95rem;
    font-family: inherit;
    background: var(--canvas);
    color: var(--ink);
    outline: none;
    transition: border-color 0.15s;
  }

  .contact-form input:focus,
  .contact-form select:focus {
    border-color: var(--ink);
  }

  /* ── Calc validation error ── */
  .calc-error {
    background: rgba(251,191,36,.1);
    border: 1px solid rgba(251,191,36,.4);
    border-radius: 8px;
    color: var(--ink);
    font-size: 0.875rem;
    font-weight: 500;
    padding: 12px 16px;
    margin-bottom: 12px;
    animation: shake 0.4s cubic-bezier(.36,.07,.19,.97) both;
  }
  @keyframes shake {
    10%, 90% { transform: translateX(-2px); }
    20%, 80% { transform: translateX(3px); }
    30%, 50%, 70% { transform: translateX(-4px); }
    40%, 60% { transform: translateX(4px); }
  }

  /* ── Form success state ── */
  .form-success {
    text-align: center;
    padding: 48px 32px;
    border-radius: 16px;
    background: var(--canvas);
    border: 1px solid var(--border);
    box-shadow: 0 2px 8px rgba(0,0,0,.04), 0 8px 32px rgba(0,0,0,.06);
    margin-top: 40px;
    animation: fsIn 0.5s cubic-bezier(.34,1.56,.64,1) both;
  }
  @keyframes fsIn {
    from { opacity: 0; transform: translateY(16px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0)    scale(1); }
  }

  .fs-icon {
    width: 64px;
    height: 64px;
    margin: 0 auto 20px;
    color: #16a34a;
  }
  .fs-icon svg { width: 100%; height: 100%; }

  .fs-circle {
    stroke-dasharray: 157;
    stroke-dashoffset: 157;
    animation: drawCircle 0.5s 0.1s cubic-bezier(.4,0,.2,1) forwards;
  }
  @keyframes drawCircle {
    to { stroke-dashoffset: 0; }
  }

  .fs-check {
    stroke-dasharray: 36;
    stroke-dashoffset: 36;
    animation: drawCheck 0.35s 0.55s cubic-bezier(.4,0,.2,1) forwards;
  }
  @keyframes drawCheck {
    to { stroke-dashoffset: 0; }
  }

  .fs-title {
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 8px;
    letter-spacing: -0.02em;
  }
  .fs-body {
    color: var(--ink-2);
    font-size: 0.95rem;
    margin: 0 0 6px;
  }
  .fs-sub {
    color: var(--ink-2);
    font-size: 0.82rem;
    margin: 0;
    opacity: 0.7;
  }

  /* ── Batch section ─────────────────────────────────── */
  .batch-layout {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: 48px;
    align-items: start;
    margin-top: 48px;
  }

  @media (max-width: 720px) {
    .batch-layout { grid-template-columns: 1fr; gap: 32px; }
  }

  .batch-benefits {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .batch-benefit {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .bb-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--ink);
    color: var(--canvas);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .bb-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 4px;
  }

  .bb-desc {
    font-size: 0.85rem;
    color: var(--ink-2);
    margin: 0;
    line-height: 1.55;
  }

  .batch-card {
    background: var(--canvas);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 32px;
    box-shadow: 0 2px 4px rgba(0,0,0,.04), 0 8px 24px rgba(0,0,0,.06);
  }

  @media (max-width: 600px) { .batch-card { padding: 20px 16px; } }

  .batch-size-row {
    margin-bottom: 28px;
  }

  .batch-field-label {
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--ink-2);
    margin: 0 0 12px;
  }

  .batch-size-pills {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .batch-size-pill {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    padding: 10px 18px;
    border: 1.5px solid var(--border);
    border-radius: 12px;
    background: var(--canvas);
    cursor: pointer;
    font-family: inherit;
    transition: border-color 0.15s, background 0.15s, transform 0.15s cubic-bezier(.34,1.56,.64,1), box-shadow 0.15s;
    user-select: none;
  }

  .batch-size-pill:hover {
    border-color: #aaa;
    transform: translateY(-1px);
  }

  .batch-size-pill.active {
    border-color: var(--ink);
    background: var(--ink);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(0,0,0,.15);
  }

  .bsp-num {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--ink);
    line-height: 1;
    transition: color 0.15s;
  }

  .batch-size-pill.active .bsp-num { color: #fff; }

  .bsp-label {
    font-size: 0.68rem;
    color: var(--ink-2);
    transition: color 0.15s;
  }

  .batch-size-pill.active .bsp-label { color: rgba(255,255,255,.65); }

  .batch-form-inner {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  :global(.batch-member-block) {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 16px;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--canvas-soft);
    animation: memberIn 0.25s cubic-bezier(.34,1.56,.64,1) both;
  }

  @keyframes memberIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: none; }
  }

  :global(.batch-member-label) {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--ink-2);
    margin: 0;
  }

  :global(.batch-member-row) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  @media (max-width: 520px) {
    :global(.batch-member-row) { grid-template-columns: 1fr; }
  }

  :global(.batch-form-inner label) {
    display: flex;
    flex-direction: column;
    gap: 5px;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--ink-2);
  }

  :global(.batch-form-inner input) {
    padding: 9px 12px;
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 0.9rem;
    font-family: inherit;
    background: var(--canvas);
    color: var(--ink);
    outline: none;
    transition: border-color 0.15s;
  }

  :global(.batch-form-inner input:focus) { border-color: var(--ink); }

  /* ── Stats bar ────────────────────────────────────────── */
  .stats-bar {
    background: var(--surface-dark);
    padding: 28px 0;
  }

  .stats-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    flex-wrap: wrap;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 8px 40px;
    gap: 4px;
  }

  .stat-num {
    font-size: 1.55rem;
    font-weight: 600;
    color: #fff;
    letter-spacing: -0.03em;
  }

  .stat-label {
    font-size: 0.78rem;
    color: rgba(255,255,255,.5);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: rgba(255,255,255,.12);
  }

  @media (max-width: 600px) {
    .stat-divider { display: none; }
    .stat-item { padding: 8px 24px; }
    .stats-inner { gap: 4px; }
  }

  /* ── Smart Match Quiz ──────────────────────────────────── */
  .section-dark {
    background: var(--surface-dark, #171717);
    color: #fff;
  }

  .eyebrow-light {
    text-align: center;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,.45);
    margin-bottom: 12px;
  }

  .section-title-light {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    text-align: center;
    color: #fff;
    margin-bottom: 8px;
  }

  .section-sub-light {
    text-align: center;
    color: rgba(255,255,255,.5);
    margin-bottom: 48px;
    font-size: 0.95rem;
  }

  .quiz-card {
    max-width: 640px;
    margin-inline: auto;
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.12);
    border-radius: 20px;
    padding: 36px;
    position: relative;
  }

  .quiz-step { display: none; }
  .quiz-step.active { display: block; }

  .quiz-q {
    font-size: 1.15rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 24px;
    text-align: center;
  }

  .quiz-options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .quiz-opt {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 16px 12px;
    background: rgba(255,255,255,.05);
    border: 1px solid rgba(255,255,255,.12);
    border-radius: 12px;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, transform 0.15s cubic-bezier(.34,1.56,.64,1);
    color: #fff;
  }

  .quiz-opt:hover {
    background: rgba(255,255,255,.12);
    border-color: rgba(255,255,255,.3);
    transform: translateY(-2px);
  }

  .quiz-opt.selected {
    background: rgba(255,255,255,.15);
    border-color: rgba(255,255,255,.5);
  }

  .qo-icon { font-size: 1.5rem; }

  .qo-label {
    font-size: 0.82rem;
    font-weight: 500;
    text-align: center;
    line-height: 1.35;
  }

  .quiz-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 28px;
  }

  .qdot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255,255,255,.2);
    transition: background 0.2s, transform 0.2s;
  }

  .qdot.active {
    background: #fff;
    transform: scale(1.25);
  }

  .quiz-result {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
  }

  /* ── Quiz searching animation ── */
  .quiz-searching {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
    padding: 12px 0 8px;
  }

  .qs-spinner {
    position: relative;
    width: 72px;
    height: 72px;
  }

  .qs-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 3px solid transparent;
    border-top-color: #fff;
    animation: qs-spin 1.2s linear infinite;
  }
  .qs-ring-2 {
    inset: 10px;
    border-top-color: rgba(255,255,255,0.55);
    animation-duration: 1.8s;
    animation-direction: reverse;
  }
  .qs-ring-3 {
    inset: 20px;
    border-top-color: rgba(255,255,255,0.25);
    animation-duration: 2.4s;
  }

  @keyframes qs-spin {
    to { transform: rotate(360deg); }
  }

  .qs-label {
    font-size: 1.05rem;
    font-weight: 600;
    color: #fff;
    letter-spacing: -0.02em;
    transition: opacity 0.3s;
  }

  .qs-steps {
    display: flex;
    flex-direction: column;
    gap: 14px;
    width: 100%;
    max-width: 280px;
  }

  .qs-step {
    display: flex;
    align-items: center;
    gap: 10px;
    opacity: 0.3;
    transition: opacity 0.4s;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.85);
  }
  .qs-step-active { opacity: 1; }
  .qs-step-done   { opacity: 0.6; }

  .qs-step-icon { font-size: 1rem; width: 20px; text-align: center; flex-shrink: 0; }
  .qs-step-text { flex: 1; }
  .qs-step-tick {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: rgba(255,255,255,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    color: #fff;
    flex-shrink: 0;
    transition: background 0.3s;
  }
  .qs-step-done .qs-step-tick {
    background: rgba(255,255,255,0.5);
  }

  /* ── End quiz searching animation ── */

  .qr-badge {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: #fff;
    color: #171717;
    font-size: 1.6rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
  }

  .qr-title {
    font-size: 1.2rem;
    font-weight: 600;
    color: #fff;
  }

  .qr-body {
    font-size: 0.92rem;
    color: rgba(255,255,255,.7);
    max-width: 440px;
    line-height: 1.6;
  }

  .btn-quiz-cta {
    background: #fff;
    color: #171717;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 13px 32px;
    border-radius: 100px;
    border: none;
    cursor: pointer;
    transition: opacity 0.15s, transform 0.15s cubic-bezier(.34,1.56,.64,1);
    margin-top: 4px;
  }

  .btn-quiz-cta:hover { opacity: 0.88; transform: translateY(-2px); }

  .quiz-restart {
    background: none;
    border: none;
    color: rgba(255,255,255,.45);
    font-size: 0.82rem;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .quiz-restart:hover { color: rgba(255,255,255,.7); }

  @media (max-width: 520px) {
    .quiz-card { padding: 24px 16px; }
    .quiz-options { grid-template-columns: 1fr; }
  }

  /* ── FAQ ───────────────────────────────────────────────── */
  .faq-container { max-width: 720px; }

  .faq-list {
    margin-top: 40px;
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
  }

  .faq-item {
    border-bottom: 1px solid var(--border);
  }

  .faq-item:last-child { border-bottom: none; }

  .faq-q {
    list-style: none;
    padding: 18px 20px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    transition: background 0.15s;
  }

  .faq-q::-webkit-details-marker { display: none; }

  .faq-q::after {
    content: '+';
    font-size: 1.2rem;
    font-weight: 400;
    color: var(--ink-2);
    flex-shrink: 0;
    transition: transform 0.2s;
  }

  .faq-item[open] .faq-q::after { transform: rotate(45deg); }

  .faq-item[open] .faq-q { background: var(--canvas-soft); }

  .faq-a {
    padding: 0 20px 18px;
    font-size: 0.9rem;
    color: var(--ink-2);
    line-height: 1.65;
  }

  .hidden { display: none !important; }

  /* ── Auth modal ─────────────────────────────────────── */
  .modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.45);
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
  }

  .modal-card {
    background: var(--canvas);
    border-radius: 16px;
    padding: 24px 24px 20px;
    max-width: 380px;
    width: 100%;
    position: relative;
    box-shadow: 0 8px 32px rgba(0,0,0,.18);
    animation: modal-in 0.16s ease-out;
    max-height: 90vh;
    overflow-y: auto;
  }

  @keyframes modal-in {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: none; }
  }

  .modal-close {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: var(--canvas-soft);
    color: var(--ink-2);
    font-size: 1rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }

  .modal-close:hover { background: var(--border); }

  .modal-eyebrow { display: none; }

  .modal-title {
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 4px;
    padding-right: 32px;
  }

  .modal-sub {
    font-size: 0.82rem;
    color: var(--ink-2);
    margin-bottom: 16px;
    line-height: 1.5;
  }

  .auth-tabs {
    display: flex;
    gap: 3px;
    background: var(--canvas-soft);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 3px;
    margin-bottom: 16px;
  }

  .auth-tab {
    flex: 1;
    padding: 7px 12px;
    border: none;
    border-radius: 6px;
    background: transparent;
    font-family: inherit;
    font-size: 0.83rem;
    font-weight: 500;
    color: var(--ink-2);
    cursor: pointer;
    transition: background 0.12s, color 0.12s, box-shadow 0.12s;
  }

  .auth-tab.active {
    background: var(--canvas);
    color: var(--ink);
    box-shadow: 0 1px 3px rgba(0,0,0,.1);
  }

  .auth-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .auth-form label {
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--ink-2);
  }

  .auth-form input {
    padding: 8px 11px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-size: 0.88rem;
    font-family: inherit;
    background: var(--canvas);
    color: var(--ink);
    outline: none;
    transition: border-color 0.15s;
  }

  .auth-form input:focus { border-color: var(--ink); }

  .auth-error {
    font-size: 0.78rem;
    color: #dc2626;
    margin-top: -2px;
  }

  .auth-switch {
    text-align: center;
    font-size: 0.78rem;
    color: var(--ink-2);
  }

  .link-btn {
    background: none;
    border: none;
    font-family: inherit;
    font-size: inherit;
    color: var(--ink);
    font-weight: 600;
    cursor: pointer;
    text-decoration: underline;
    padding: 0;
  }

  .opt { font-weight: 400; color: #999; }

  .btn-full-dark {
    display: block;
    width: 100%;
    background: var(--ink);
    color: var(--canvas);
    padding: 10px 20px;
    border-radius: var(--radius-pill);
    border: none;
    cursor: pointer;
    font-family: inherit;
    font-size: 0.88rem;
    font-weight: 600;
    text-align: center;
    transition: opacity 0.15s;
  }

  .btn-full-dark:hover { opacity: 0.85; }

  .mform-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
  }

  @media (max-width: 440px) { .mform-row { grid-template-columns: 1fr; } }

  /* Google Sign-In */
  :global(.google-btn-wrap) {
    display: flex;
    justify-content: center;
    min-height: 44px;
  }

  :global(.auth-divider) {
    display: flex;
    align-items: center;
    gap: 12px;
    color: #999;
    font-size: 0.8rem;
    margin: 4px 0;
  }

  :global(.auth-divider::before),
  :global(.auth-divider::after) {
    content: '';
    flex: 1;
    height: 1px;
    background: var(--border);
  }

  /* ── SEO FAQ Section ────────────────────────────── */
  .seo-faq-section {
    background: var(--canvas);
    border-top: 1px solid var(--border);
  }

  .seo-faq-container {
    max-width: 800px;
  }

  .seo-faq-grid {
    margin-top: 40px;
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }

  .seo-faq-item {
    border-bottom: 1px solid var(--border);
    background: var(--canvas);
    transition: background 0.15s;
  }

  .seo-faq-item:last-child {
    border-bottom: none;
  }

  .seo-faq-item[open] {
    background: var(--canvas-soft);
  }

  .seo-faq-q {
    cursor: pointer;
    padding: 18px 48px 18px 20px;
    font-weight: 600;
    font-size: 0.95rem;
    color: var(--ink);
    list-style: none;
    position: relative;
    user-select: none;
    line-height: 1.4;
  }

  .seo-faq-q::-webkit-details-marker { display: none; }

  .seo-faq-q::after {
    content: '+';
    position: absolute;
    right: 20px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 1.25rem;
    font-weight: 400;
    color: var(--ink-2);
    transition: transform 0.2s cubic-bezier(.4,0,.2,1);
    line-height: 1;
  }

  .seo-faq-item[open] .seo-faq-q::after {
    transform: translateY(-50%) rotate(45deg);
  }

  .seo-faq-a {
    padding: 0 20px 18px;
    font-size: 0.9rem;
    color: var(--ink-2);
    line-height: 1.75;
  }

  .seo-faq-a strong { color: var(--ink); font-weight: 600; }
  .seo-faq-a em { font-style: italic; }
  .seo-faq-a a { color: var(--ink); text-decoration: underline; text-underline-offset: 3px; }

  /* ── SEO Content Section ─────────────────────────── */
  .seo-section {
    background: var(--canvas-soft);
    border-top: 1px solid var(--border);
  }

  .seo-container {
    max-width: 800px;
  }

  .seo-heading {
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    font-weight: 600;
    letter-spacing: -0.03em;
