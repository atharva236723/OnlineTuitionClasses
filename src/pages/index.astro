---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import HeroAnimation from '../components/HeroAnimation.astro';

const steps = [
  { num: "1", title: "Select class & subject", desc: "Tell us which class you're in and which subject you need help with." },
  { num: "2", title: "Choose your budget", desc: "Pick a pricing tier that works for you — no hidden fees." },
  { num: "3", title: "Get matched in 24 hours", desc: "We'll connect you with a verified teacher suited to your needs." },
  { num: "4", title: "Start with a free demo", desc: "Attend a free demo class before committing to anything." },
];

const pricing = [
  { range: "Class 1–5",   price: "₹300 – ₹600 / hr" },
  { range: "Class 6–8",   price: "₹500 – ₹900 / hr" },
  { range: "Class 9–10",  price: "₹700 – ₹1,200 / hr" },
  { range: "Class 11–12", price: "₹900 – ₹1,800 / hr" },
];
---

<Layout>

  <Nav />

  <!-- ── HERO ────────────────────────────────────────────── -->
  <section class="hero">
    <div class="container hero-inner">
      <div class="hero-text reveal">
        <h1 class="hero-headline">Online Tuition for Class 1–12<br />Verified Teachers.</h1>
        <p class="hero-sub">Choose your subject, your budget, and get matched with a teacher in 24 hours.</p>
        <a href="#find" class="btn-primary">Find a Teacher</a>
      </div>
      <div class="hero-visual reveal" style="transition-delay:0.12s">
        <HeroAnimation />
      </div>
    </div>
  </section>

  <!-- ── HOW IT WORKS ─────────────────────────────────────── -->
  <section class="section" id="how">
    <div class="container">
      <h2 class="section-title reveal">How it works</h2>
      <div class="steps-grid reveal-stagger reveal">
        {steps.map(s => (
          <div class="step-card">
            <div class="step-num">{s.num}</div>
            <h3 class="step-title">{s.title}</h3>
            <p class="step-desc">{s.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── SMART MATCH QUIZ ────────────────────────────────── -->
  <section class="section section-dark" id="quiz">
    <div class="container">
      <p class="eyebrow-light reveal">Only on OTC</p>
      <h2 class="section-title-light reveal">Find your perfect teacher in 60 seconds</h2>
      <p class="section-sub-light reveal">Answer 3 quick questions — we'll tell you exactly what kind of teacher to look for.</p>

      <div class="quiz-card reveal" id="quiz-card">

        <!-- Step 1 -->
        <div class="quiz-step active" id="qstep-1">
          <p class="quiz-q">What's the main goal?</p>
          <div class="quiz-options">
            <button class="quiz-opt" data-step="1" data-val="Improve grades">
              <span class="qo-icon">📈</span>
              <span class="qo-label">Improve grades</span>
            </button>
            <button class="quiz-opt" data-step="1" data-val="Exam preparation">
              <span class="qo-icon">🎯</span>
              <span class="qo-label">Exam prep (Board exams)</span>
            </button>
            <button class="quiz-opt" data-step="1" data-val="Build strong foundation">
              <span class="qo-icon">🏗️</span>
              <span class="qo-label">Build strong foundation</span>
            </button>
            <button class="quiz-opt" data-step="1" data-val="Catch up on missed topics">
              <span class="qo-icon">⏩</span>
              <span class="qo-label">Catch up on missed topics</span>
            </button>
          </div>
        </div>

        <!-- Step 2 -->
        <div class="quiz-step" id="qstep-2">
          <p class="quiz-q">How does the student learn best?</p>
          <div class="quiz-options">
            <button class="quiz-opt" data-step="2" data-val="Visual explanations">
              <span class="qo-icon">👁️</span>
              <span class="qo-label">Visual explanations & diagrams</span>
            </button>
            <button class="quiz-opt" data-step="2" data-val="Lots of practice problems">
              <span class="qo-icon">✏️</span>
              <span class="qo-label">Lots of practice problems</span>
            </button>
            <button class="quiz-opt" data-step="2" data-val="Concept-first, then examples">
              <span class="qo-icon">💡</span>
              <span class="qo-label">Concept-first, then examples</span>
            </button>
            <button class="quiz-opt" data-step="2" data-val="Q&A style interaction">
              <span class="qo-icon">💬</span>
              <span class="qo-label">Q&A style — ask freely</span>
            </button>
          </div>
        </div>


        <!-- Loading -->
        <div class="quiz-step" id="qstep-loading">
          <div class="quiz-searching">
            <div class="qs-spinner">
              <div class="qs-ring"></div>
              <div class="qs-ring qs-ring-2"></div>
              <div class="qs-ring qs-ring-3"></div>
            </div>
            <p class="qs-label" id="qs-label">Searching for your perfect teacher…</p>
            <div class="qs-steps">
              <div class="qs-step" id="qss-1">
                <span class="qs-step-icon">🔍</span>
                <span class="qs-step-text">Analysing your learning profile</span>
                <span class="qs-step-tick" id="qss-tick-1"></span>
              </div>
              <div class="qs-step" id="qss-2">
                <span class="qs-step-icon">📚</span>
                <span class="qs-step-text">Matching with verified teachers</span>
                <span class="qs-step-tick" id="qss-tick-2"></span>
              </div>
              <div class="qs-step" id="qss-3">
                <span class="qs-step-icon">✅</span>
                <span class="qs-step-text">Finding your best match</span>
                <span class="qs-step-tick" id="qss-tick-3"></span>
              </div>
            </div>
          </div>
        </div>

        <!-- Result -->
        <div class="quiz-step" id="qstep-result">
          <div class="quiz-result">
            <div class="qr-badge" id="qr-badge">✓</div>
            <h3 class="qr-title" id="qr-title">Your ideal teacher profile</h3>
            <p class="qr-body" id="qr-body"></p>
            <button class="btn-quiz-cta" id="quiz-cta">Find this teacher →</button>
            <button class="quiz-restart" id="quiz-restart">Retake quiz</button>
          </div>
        </div>

        <!-- Progress dots -->
        <div class="quiz-dots" id="quiz-dots">
          <span class="qdot active" data-dot="1"></span>
          <span class="qdot" data-dot="2"></span>
        </div>

      </div>
    </div>
  </section>

  <!-- ── PRICING ──────────────────────────────────────────── -->
  <section class="section section-alt" id="pricing">
    <div class="container">
      <h2 class="section-title reveal">Pricing</h2>
      <p class="section-sub reveal">Select your class and subject to get started.</p>

      <div class="calc-card reveal">

        <!-- Class slider -->
        <div class="calc-block">
          <div class="calc-label">Class <span id="class-badge" class="class-badge">6</span></div>
          <div class="slider-wrap">
            <div class="slider-track">
              <div class="slider-fill" id="slider-fill"></div>
              <input type="range" min="1" max="12" value="6" id="class-slider" class="class-slider" />
            </div>
            <div class="slider-ticks">
              {Array.from({length: 12}, (_, i) => i + 1).map(n => (
                <span>{n}</span>
              ))}
            </div>
          </div>
        </div>

        <!-- Subjects -->
        <div class="calc-block">
          <div class="calc-label">Subjects <span class="calc-hint">(choose up to 2)</span></div>
          <div class="subject-grid" id="subject-grid"></div>
        </div>

      </div>
    </div>
  </section>

  <!-- ── FIND A TEACHER FORM ──────────────────────────────── -->
  <section class="section" id="find">
    <div class="container form-container">
      <h2 class="section-title reveal">Find a Teacher</h2>
      <p class="section-sub reveal">Fill in the details below and we'll reach out within 24 hours.</p>

      <form class="contact-form reveal" id="find-form" action="https://formspree.io/f/mpqgpdjn" method="POST">
        <input type="hidden" name="_replyto" value="abhinamika@gmail.com" />
        <input type="hidden" name="Class" id="hidden-class" value="" />
        <input type="hidden" name="Subjects" id="hidden-subjects" value="" />
        <input type="hidden" name="UserName" id="hidden-username" value="" />
        <input type="hidden" name="UserEmail" id="hidden-useremail" value="" />

        <div class="form-row">
          <label>
            Your name
            <input type="text" name="name" placeholder="e.g. Priya Sharma" required />
          </label>
          <label>
            Phone / WhatsApp
            <input type="tel" name="phone" placeholder="+91 98765 43210" required />
          </label>
        </div>

        <div id="find-phone-error" class="calc-error hidden" role="alert">
          Please enter a valid 10-digit phone number.
        </div>
        <div id="calc-error" class="calc-error hidden" role="alert">
          Please select your class and at least one subject above before requesting a match.
        </div>
        <button type="submit" class="btn-primary btn-full">Request a Match</button>
      </form>

      <div id="form-success" class="form-success hidden" aria-live="polite">
        <div class="fs-icon">
          <svg viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle class="fs-circle" cx="26" cy="26" r="24" stroke="currentColor" stroke-width="2.5" fill="none"/>
            <path class="fs-check" d="M14 26.5l8.5 8.5 15-16" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <h3 class="fs-title">Request sent!</h3>
        <p class="fs-body">We'll match you with a verified teacher and reach out within <strong>24 hours</strong>.</p>
        <p class="fs-sub">Check your WhatsApp and email for updates.</p>
      </div>
    </div>
  </section>



  <!-- ── BATCH REGISTRATION ────────────────────────────── -->
  <section class="section section-alt" id="batch">
    <div class="container">
      <h2 class="section-title reveal">Study in a batch</h2>
      <p class="section-sub reveal">Have friends who want to learn the same subject? Register as a group — same verified teacher, one shared schedule, lower cost per student.</p>

      <div class="batch-layout">

        <!-- Benefits -->
        <div class="batch-benefits reveal-stagger reveal">
          <div class="batch-benefit">
            <div class="bb-icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M10 2a8 8 0 1 0 0 16A8 8 0 0 0 10 2zm0 14.5a6.5 6.5 0 1 1 0-13 6.5 6.5 0 0 1 0 13zm-.75-9.5v3.19l2.72 1.63-.56.93-3.16-1.9V7h1z" fill="currentColor"/></svg>
            </div>
            <div>
              <p class="bb-title">One teacher, one schedule</p>
              <p class="bb-desc">All batch members attend the same live sessions — no coordination chaos.</p>
            </div>
          </div>
          <div class="batch-benefit">
            <div class="bb-icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M13 6a3 3 0 1 1-6 0 3 3 0 0 1 6 0zM5 8a2 2 0 1 1-4 0 2 2 0 0 1 4 0zm14 0a2 2 0 1 1-4 0 2 2 0 0 1 4 0zM1 14s-1 0-1-1 1-4 6-4 6 3 6 4-1 1-1 1H1zm7 0h4a4.98 4.98 0 0 0-.98-2.63C10.43 10.5 9.24 10 8 10s-2.43.5-3.02 1.37A4.98 4.98 0 0 0 4 14h4zm5.35-1.22C14.07 13.26 15 13.8 15 14h4s1 0 1-1-1-4-6-4c-1.08 0-2.04.24-2.84.62.52.6.89 1.33 1.19 2.16z" fill="currentColor"/></svg>
            </div>
            <div>
              <p class="bb-title">2 to 5 students</p>
              <p class="bb-desc">Small group, big impact. Minimum 2, maximum 5 students per batch.</p>
            </div>
          </div>
          <div class="batch-benefit">
            <div class="bb-icon">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none"><path d="M9 2a7 7 0 1 0 0 14A7 7 0 0 0 9 2zm1 10.5H8V9h2v3.5zm0-5H8V5.5h2V7.5z" fill="currentColor"/></svg>
            </div>
            <div>
              <p class="bb-title">Uses your class &amp; subject</p>
              <p class="bb-desc">Batch registration uses the class and subjects you selected in the pricing section above.</p>
            </div>
          </div>
        </div>

        <!-- Form card -->
        <div class="batch-card reveal" style="transition-delay:0.1s">

          <!-- Batch size picker -->
          <div class="batch-size-row">
            <p class="batch-field-label">Batch size</p>
            <div class="batch-size-pills" id="batch-size-pills">
              {[2, 3, 4, 5].map(n => (
                <button type="button" class:list={['batch-size-pill', n === 2 && 'active']} data-size={n}>
                  <span class="bsp-num">{n}</span>
                  <span class="bsp-label">student{n > 1 ? 's' : ''}</span>
                </button>
              ))}
            </div>
          </div>

          <form id="batch-form" class="batch-form-inner" novalidate>
            <input type="hidden" name="_replyto" value="abhinamika@gmail.com" />
            <input type="hidden" name="Type"     value="Batch Registration" />
            <input type="hidden" name="BatchSize" id="batch-hidden-size"     value="2" />
            <input type="hidden" name="Class"    id="batch-hidden-class"    value="" />
            <input type="hidden" name="Subjects" id="batch-hidden-subjects" value="" />

            <!-- Organizer (always shown) -->
            <div class="batch-member-block">
              <p class="batch-member-label">You (organiser)</p>
              <div class="batch-member-row">
                <label>
                  Name
                  <input type="text"  name="member1_name"  placeholder="Your name"  required />
                </label>
                <label>
                  Phone / WhatsApp
                  <input type="tel"   name="member1_phone" placeholder="+91 98765 43210" required />
                </label>
              </div>
            </div>

            <!-- Member 2 (always shown, min batch = 2) -->
            <div class="batch-member-block">
              <p class="batch-member-label">Member 2</p>
              <div class="batch-member-row">
                <label>
                  Name
                  <input type="text"  name="member2_name"  placeholder="Friend's name"  required />
                </label>
                <label>
                  Phone / WhatsApp
                  <input type="tel"   name="member2_phone" placeholder="+91 98765 43210" required />
                </label>
              </div>
            </div>

            <!-- Members 3-5 revealed dynamically by JS -->
            <div id="batch-extra-members"></div>

            <div id="batch-phone-error" class="calc-error hidden" role="alert">
              Please enter valid 10-digit phone numbers for all members.
            </div>
            <div id="batch-error" class="calc-error hidden" role="alert">
              Please select a class and at least one subject in the Pricing section above before registering.
            </div>

            <button type="submit" class="btn-primary btn-full">Register for batch</button>
          </form>

          <div id="batch-success" class="form-success hidden" aria-live="polite">
            <div class="fs-icon">
              <svg viewBox="0 0 52 52" fill="none" xmlns="http://www.w3.org/2000/svg">
                <circle class="fs-circle" cx="26" cy="26" r="24" stroke="currentColor" stroke-width="2.5" fill="none"/>
                <path class="fs-check" d="M14 26.5l8.5 8.5 15-16" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3 class="fs-title">Batch registered!</h3>
            <p class="fs-body">We'll match your group with a verified teacher and reach out within <strong>24 hours</strong>.</p>
            <p class="fs-sub">Check your WhatsApp and email for updates.</p>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- ── FAQ ──────────────────────────────────────────────── -->
  <section class="section" id="faq">
    <div class="container faq-container">
      <h2 class="section-title reveal">Common questions</h2>
      <p class="section-sub reveal">Everything parents and students ask before getting started.</p>
      <div class="faq-list reveal">

        <details class="faq-item">
          <summary class="faq-q">How quickly will I be matched with a teacher?</summary>
          <p class="faq-a">We match you within 24 hours of receiving your request. In most cases it's faster — you'll get a WhatsApp message as soon as we find the right teacher for you.</p>
        </details>

        <details class="faq-item">
          <summary class="faq-q">Is the demo class really free?</summary>
          <p class="faq-a">Yes, completely free and with no obligation. You attend one full demo session with your matched teacher before deciding. If you're not happy with the match, we'll find you another teacher at no cost.</p>
        </details>

        <details class="faq-item">
          <summary class="faq-q">How are teachers verified?</summary>
          <p class="faq-a">Every teacher goes through a three-step process: document verification (degree certificate, ID), a demo session reviewed by our team, and regular student feedback checks. Teachers with declining ratings are reviewed and removed.</p>
        </details>

        <details class="faq-item">
          <summary class="faq-q">What subjects and classes do you cover?</summary>
          <p class="faq-a">We cover Maths (Class 1–10), Physics, Chemistry, and Biology for Class 6–12. Physics for Class 11–12 is coming soon. More subjects are added regularly — contact us if you need something not listed.</p>
        </details>

        <details class="faq-item">
          <summary class="faq-q">What is a batch and how does it save money?</summary>
          <p class="faq-a">A batch is 2–5 students who share the same teacher and schedule. Because the teacher's time is shared, the per-student cost drops significantly — typically 30–50% less than a 1-on-1 session.</p>
        </details>

        <details class="faq-item">
          <summary class="faq-q">Do sessions happen on a fixed schedule or can I reschedule?</summary>
          <p class="faq-a">Your teacher sets a recurring weekly schedule that suits both sides. Rescheduling is possible with at least 12 hours' notice — just message the teacher directly on WhatsApp.</p>
        </details>

        <details class="faq-item">
          <summary class="faq-q">Is there a registration fee or platform fee?</summary>
          <p class="faq-a">No registration fee, no platform fee, no hidden charges. You pay only for the sessions you attend, directly to your teacher as agreed.</p>
        </details>

      </div>
    </div>
  </section>

  <!-- ── AUTH MODAL ─────────────────────────────────────── -->
  <div id="auth-modal" class="modal-backdrop hidden" role="dialog" aria-modal="true" aria-labelledby="modal-title">
    <div class="modal-card">
      <button class="modal-close" id="modal-close" aria-label="Close">&times;</button>
      <p class="modal-eyebrow">One more step</p>
      <h2 class="modal-title" id="modal-title">Sign in to continue</h2>
      <p class="modal-sub">Create a free account or log in to request a teacher match.</p>

      <!-- Google Sign-In -->
      <div id="google-btn-modal" class="google-btn-wrap"></div>
      <div class="auth-divider"><span>or</span></div>

      <div class="auth-tabs">
        <button class="auth-tab active" id="mtab-login" type="button">Log in</button>
        <button class="auth-tab" id="mtab-signup" type="button">Sign up</button>
      </div>

      <!-- Modal login form -->
      <form id="modal-login-form" class="auth-form" novalidate>
        <label>
          Email address
          <input type="email" id="mlogin-email" placeholder="you@example.com" required />
        </label>
        <p class="auth-error hidden" id="mlogin-error">No account found with that email.</p>
        <button type="submit" class="btn-primary btn-full-dark">Log in &amp; submit</button>
        <p class="auth-switch">
          No account?
          <button type="button" class="link-btn" id="mgo-signup">Sign up instead</button>
        </p>
      </form>

      <!-- Modal signup form -->
      <form id="modal-signup-form" class="auth-form hidden" novalidate>
        <div class="mform-row">
          <label>
            Full name
            <input type="text" id="msignup-name" placeholder="Priya Sharma" required />
          </label>
          <label>
            Email
            <input type="email" id="msignup-email" placeholder="you@example.com" required />
          </label>
        </div>
        <label>
          Phone / WhatsApp <span class="opt">(optional)</span>
          <input type="tel" id="msignup-phone" placeholder="+91 98765 43210" />
        </label>
        <p class="auth-error hidden" id="msignup-error"></p>
        <button type="submit" class="btn-primary btn-full-dark">Create account &amp; submit</button>
        <p class="auth-switch">
          Already have an account?
          <button type="button" class="link-btn" id="mgo-login">Log in</button>
        </p>
      </form>
    </div>
  </div>

  <Footer />

</Layout>

<script is:inline>
/* ── Smart Match Quiz ── */
(function () {
  var answers = {};
  var currentStep = 1;

  var PROFILES = {
    default: {
      title: 'Your ideal teacher profile',
      body: 'Based on your answers, we\'ll match you with a verified teacher who fits your goals, learning style, and schedule. Fill in the form below and we\'ll reach out within 24 hours.'
    }
  };

  function buildProfile(a) {
    var goal  = a[1] || '';
    var style = a[2] || '';
    var body = 'Based on your goal (“' + goal + '”) and preferred learning style (“' + style + '”), we\'ve found the ideal teacher profile for you. Fill in the form below and we\'ll connect you within 24 hours.';
    return { title: 'Your perfect teacher match is ready', body: body };
  }

  function goToStep(step) {
    document.querySelectorAll('.quiz-step').forEach(function(s) { s.classList.remove('active'); });
    var el = document.getElementById('qstep-' + step);
    if (el) el.classList.add('active');

    document.querySelectorAll('.qdot').forEach(function(d) {
      d.classList.toggle('active', parseInt(d.dataset.dot) === step);
    });

    var dots = document.getElementById('quiz-dots');
    if (step === 'result' || step === 'loading') { if (dots) dots.style.display = 'none'; }
    else                                         { if (dots) dots.style.display = ''; }

    currentStep = step;
  }

  function showResult() {
    var p = buildProfile(answers);
    document.getElementById('qr-title').textContent = p.title;
    document.getElementById('qr-body').textContent  = p.body;

    goToStep('loading');
    var ticks = [null,
      document.getElementById('qss-tick-1'),
      document.getElementById('qss-tick-2'),
      document.getElementById('qss-tick-3')
    ];
    var steps = [null,
      document.getElementById('qss-1'),
      document.getElementById('qss-2'),
      document.getElementById('qss-3')
    ];
    steps[1] && steps[1].classList.add('qs-step-active');
    setTimeout(function() {
      ticks[1] && (ticks[1].textContent = '✓');
      steps[1] && steps[1].classList.add('qs-step-done');
      steps[2] && steps[2].classList.add('qs-step-active');
    }, 1500);
    setTimeout(function() {
      ticks[2] && (ticks[2].textContent = '✓');
      steps[2] && steps[2].classList.add('qs-step-done');
      steps[3] && steps[3].classList.add('qs-step-active');
    }, 3000);
    setTimeout(function() {
      ticks[3] && (ticks[3].textContent = '✓');
      steps[3] && steps[3].classList.add('qs-step-done');
      document.getElementById('qs-label').textContent = 'Match found!';
    }, 4500);
    setTimeout(function() {
      goToStep('result');
    }, 5200);
  }

  function resetLoadingState() {
    [1, 2, 3].forEach(function(i) {
      var s = document.getElementById('qss-' + i);
      var t = document.getElementById('qss-tick-' + i);
      if (s) { s.classList.remove('qs-step-active', 'qs-step-done'); }
      if (t) { t.textContent = ''; }
    });
    var label = document.getElementById('qs-label');
    if (label) label.textContent = 'Searching for your perfect teacher…';
  }

  function initQuiz() {
    answers = {};
    resetLoadingState();
    goToStep(1);

    document.querySelectorAll('.quiz-opt').forEach(function(btn) {
      btn.onclick = function() {
        var step = parseInt(this.dataset.step);
        var val  = this.dataset.val;
        answers[step] = val;

        this.closest('.quiz-options').querySelectorAll('.quiz-opt').forEach(function(b) { b.classList.remove('selected'); });
        this.classList.add('selected');

        setTimeout(function() {
          if (step < 2) goToStep(step + 1);
          else showResult();
        }, 250);
      };
    });

    var cta = document.getElementById('quiz-cta');
    if (cta) cta.onclick = function() {
      var findSection = document.getElementById('find');
      if (!findSection) return;
      if (window.lenisInstance) window.lenisInstance.scrollTo(findSection, { offset: -72 });
      else findSection.scrollIntoView({ behavior: 'smooth', block: 'start' });
    };

    var restart = document.getElementById('quiz-restart');
    if (restart) restart.onclick = function() {
      answers = {};
      resetLoadingState();
      goToStep(1);
    };
  }

  initQuiz();
  document.addEventListener('astro:after-swap', initQuiz);
})();
</script>

<script src="https://accounts.google.com/gsi/client" async></script>
<script is:inline>
  var GOOGLE_CLIENT_ID = '945888240197-9in6fs6u0gmtuib5b3de70ek7ceam4j4.apps.googleusercontent.com';
  var USER_KEY = 'otc_user';

  function getUser() {
    try { return JSON.parse(localStorage.getItem(USER_KEY)); } catch (_) { return null; }
  }
  function saveUser(u) {
    localStorage.setItem(USER_KEY, JSON.stringify(u));
    window.dispatchEvent(new Event('otc-auth-change'));
  }

  async function submitFindForm() {
    var u = getUser();
    document.getElementById('hidden-class').value    = 'Class ' + currentClass;
    document.getElementById('hidden-subjects').value = calcSelected.length ? calcSelected.join(', ') : 'None selected';
    if (u) {
      document.getElementById('hidden-username').value  = u.name  || '';
      document.getElementById('hidden-useremail').value = u.email || '';
    }

    var form = document.getElementById('find-form');
    var data = new FormData(form);

    try {
      var res = await fetch(form.action, { method: 'POST', body: data, headers: { Accept: 'application/json' } });
      if (res.ok) {
        form.classList.add('hidden');
        document.getElementById('form-success').classList.remove('hidden');
      } else {
        alert('Something went wrong. Please try again.');
      }
    } catch (_) {
      alert('Network error. Please check your connection and try again.');
    }
  }

  /* ── Auth modal logic ── */
  var pendingSubmit = false;

  function openModal() {
    var modal = document.getElementById('auth-modal');
    modal.classList.remove('hidden');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    var modal = document.getElementById('auth-modal');
    modal.classList.add('hidden');
    document.body.style.overflow = '';
    pendingSubmit = false;
  }

  function switchModalTab(show) {
    var lf = document.getElementById('modal-login-form');
    var sf = document.getElementById('modal-signup-form');
    var tl = document.getElementById('mtab-login');
    var ts = document.getElementById('mtab-signup');
    if (show === 'login') {
      lf.classList.remove('hidden'); sf.classList.add('hidden');
      tl.classList.add('active');    ts.classList.remove('active');
    } else {
      sf.classList.remove('hidden'); lf.classList.add('hidden');
      ts.classList.add('active');    tl.classList.remove('active');
    }
  }

  document.getElementById('modal-close').addEventListener('click', closeModal);
  document.getElementById('auth-modal').addEventListener('click', function(e) {
    if (e.target === this) closeModal();
  });
  document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeModal(); });

  document.getElementById('mtab-login').addEventListener('click',  function() { switchModalTab('login'); });
  document.getElementById('mtab-signup').addEventListener('click', function() { switchModalTab('signup'); });
  document.getElementById('mgo-signup').addEventListener('click',  function() { switchModalTab('signup'); });
  document.getElementById('mgo-login').addEventListener('click',   function() { switchModalTab('login'); });

  document.getElementById('modal-login-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    var email = document.getElementById('mlogin-email').value.trim().toLowerCase();
    var err   = document.getElementById('mlogin-error');
    var u     = getUser();
    if (u && u.email.toLowerCase() === email) {
      err.classList.add('hidden');
      closeModal();
      await submitFindForm();
    } else {
      err.classList.remove('hidden');
    }
  });

  document.getElementById('modal-signup-form').addEventListener('submit', async function(e) {
    e.preventDefault();
    var name  = document.getElementById('msignup-name').value.trim();
    var email = document.getElementById('msignup-email').value.trim();
    var phone = document.getElementById('msignup-phone').value.trim();
    var err   = document.getElementById('msignup-error');

    if (!name)  { err.textContent = 'Please enter your name.';  err.classList.remove('hidden'); return; }
    if (!email || !email.includes('@')) { err.textContent = 'Please enter a valid email.'; err.classList.remove('hidden'); return; }
    if (phone && phone.replace(/\D/g, '').length !== 10) { err.textContent = 'Please enter a valid 10-digit phone number.'; err.classList.remove('hidden'); return; }

    err.classList.add('hidden');
    saveUser({ name: name, email: email, phone: phone });
    closeModal();
    await submitFindForm();
  });

  /* ── Find-form submit ── */
  document.getElementById('find-form').addEventListener('submit', async function (e) {
    e.preventDefault();
    var phoneErrEl = document.getElementById('find-phone-error');
    var phoneVal = (document.querySelector('#find-form [name="phone"]') || {}).value || '';
    var phoneDigits = phoneVal.replace(/\D/g, '');
    if (phoneDigits.length !== 10) {
      phoneErrEl.classList.remove('hidden');
      document.getElementById('calc-error').classList.add('hidden');
      phoneErrEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }
    phoneErrEl.classList.add('hidden');
    var errEl = document.getElementById('calc-error');
    if (calcSelected.length === 0) {
      errEl.classList.remove('hidden');
      errEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
      return;
    }
    errEl.classList.add('hidden');
    var u = getUser();
    if (!u) {
      openModal();
      return;
    }
    await submitFindForm();
  });

  /* Google Sign-In */
  function parseGoogleJwt(credential) {
    var payload = credential.split('.')[1].replace(/-/g, '+').replace(/_/g, '/');
    payload += '=='.slice(0, (4 - payload.length % 4) % 4);
    return JSON.parse(atob(payload));
  }

  async function onGoogleSignIn(response) {
    var data = parseGoogleJwt(response.credential);
    saveUser({ name: data.name, email: data.email, phone: '', picture: data.picture || '' });
    closeModal();
    if (pendingSubmit) await submitFindForm();
  }

  window.addEventListener('load', function () {
    if (typeof google === 'undefined' || !GOOGLE_CLIENT_ID || GOOGLE_CLIENT_ID === 'YOUR_GOOGLE_CLIENT_ID') return;
    google.accounts.id.initialize({ client_id: GOOGLE_CLIENT_ID, callback: onGoogleSignIn });
    google.accounts.id.renderButton(
      document.getElementById('google-btn-modal'),
      { theme: 'outline', size: 'large', width: 360, text: 'continue_with' }
    );
  });

  var currentClass = 6;
  var calcSelected = [];

  (function () {
    /* Maths only up to class 10 */
    const SUBJECT_META = {
      Maths:     { color: '#2563eb', icon: '∑', note: 'Class 1–10' },
      Physics:   { color: '#7c3aed', icon: '⚛', note: 'Coming soon for 11–12' },
      Chemistry: { color: '#059669', icon: '⚗', note: 'All classes' },
      Biology:   { color: '#dc2626', icon: '🧬', note: 'Class 1–10' },
    };

    const slider      = document.getElementById('class-slider');
    const fill        = document.getElementById('slider-fill');
    const badge       = document.getElementById('class-badge');
    const subjectGrid = document.getElementById('subject-grid');
    const ticks       = document.querySelectorAll('.slider-ticks span');

    function updateFill(val) {
      fill.style.width = ((val - 1) / 11 * 100) + '%';
    }

    function updateTicks(val) {
      ticks.forEach((t, i) => t.classList.toggle('tick-active', i + 1 === val));
    }

    function availableSubjects() {
      /* Maths and Biology only up to class 10 */
      return Object.keys(SUBJECT_META).filter(
        s => (s !== 'Maths' && s !== 'Biology') || currentClass <= 10
      );
    }

    function renderSubjects() {
      const avail = availableSubjects();
      /* drop any selected subject that's no longer available or locked */
      calcSelected = calcSelected.filter(s => {
        if (!avail.includes(s)) return false;
        if (s === 'Physics' && currentClass >= 11) return false;
        return true;
      });
      subjectGrid.innerHTML = '';

      avail.forEach(sub => {
        const meta            = SUBJECT_META[sub];
        const isSelected      = calcSelected.includes(sub);
        const isPhysicsLocked = sub === 'Physics' && currentClass >= 11;
        const isDisabled      = isPhysicsLocked || (calcSelected.length >= 2 && !isSelected);

        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'subject-card' +
          (isSelected ? ' selected' : '') +
          (isDisabled ? ' disabled'  : '');
        btn.style.setProperty('--sc', meta.color);

        btn.innerHTML = `
          <span class="sc-icon">${meta.icon}</span>
          <span class="sc-body">
            <span class="sc-name">${sub}</span>
            <span class="sc-note">${meta.note}</span>
          </span>
          <span class="sc-check" aria-hidden="true">
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
              <polyline points="2,7 5.5,10.5 12,3.5" stroke="currentColor" stroke-width="2"
                stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>`;

        btn.addEventListener('click', () => {
          if (calcSelected.includes(sub)) {
            calcSelected = calcSelected.filter(s => s !== sub);
          } else {
            if (calcSelected.length >= 2) return;
            calcSelected.push(sub);
          }
          if (calcSelected.length > 0) {
            var errEl = document.getElementById('calc-error');
            if (errEl) errEl.classList.add('hidden');
          }
          renderSubjects();
        });

        subjectGrid.appendChild(btn);
      });
    }

    /* slider */
    slider.addEventListener('input', () => {
      currentClass = Number(slider.value);
      badge.textContent = currentClass;
      badge.style.transform = 'scale(1.25)';
      requestAnimationFrame(() => {
        updateFill(currentClass);
        updateTicks(currentClass);
        setTimeout(() => badge.style.transform = '', 120);
      });
      renderSubjects(); /* may hide/show Maths */
    });

    updateFill(currentClass);
    updateTicks(currentClass);
    renderSubjects();
  })();

  /* ── Batch registration ── */
  (function () {
    var batchSize = 2;

    var pillsWrap = document.getElementById('batch-size-pills');
    var extraWrap = document.getElementById('batch-extra-members');
    var batchHiddenSize = document.getElementById('batch-hidden-size');

    function renderExtraMembers() {
      extraWrap.innerHTML = '';
      for (var i = 3; i <= batchSize; i++) {
        var num = i;
        var block = document.createElement('div');
        block.className = 'batch-member-block';
        block.innerHTML =
          '<p class="batch-member-label">Member ' + num + '</p>' +
          '<div class="batch-member-row">' +
            '<label>Name<input type="text" name="member' + num + '_name" placeholder="Friend\'s name" required /></label>' +
            '<label>Phone / WhatsApp<input type="tel" name="member' + num + '_phone" placeholder="+91 98765 43210" required /></label>' +
          '</div>';
        extraWrap.appendChild(block);
      }
    }

    pillsWrap.addEventListener('click', function (e) {
      var pill = e.target.closest('.batch-size-pill');
      if (!pill) return;
      batchSize = Number(pill.dataset.size);
      batchHiddenSize.value = batchSize;
      pillsWrap.querySelectorAll('.batch-size-pill').forEach(function (p) {
        p.classList.toggle('active', Number(p.dataset.size) === batchSize);
      });
      renderExtraMembers();
    });

    document.getElementById('batch-form').addEventListener('submit', async function (e) {
      e.preventDefault();
      var phoneErrEl = document.getElementById('batch-phone-error');
      var telInputs = document.querySelectorAll('#batch-form [type="tel"]');
      var phoneOk = Array.from(telInputs).every(function(inp) {
        return inp.value.replace(/\D/g, '').length === 10;
      });
      if (!phoneOk) {
        phoneErrEl.classList.remove('hidden');
        document.getElementById('batch-error').classList.add('hidden');
        phoneErrEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }
      phoneErrEl.classList.add('hidden');
      var errEl = document.getElementById('batch-error');
      if (calcSelected.length === 0) {
        errEl.classList.remove('hidden');
        errEl.scrollIntoView({ behavior: 'smooth', block: 'center' });
        return;
      }
      errEl.classList.add('hidden');

      document.getElementById('batch-hidden-class').value    = 'Class ' + currentClass;
      document.getElementById('batch-hidden-subjects').value = calcSelected.join(', ');

      var form = document.getElementById('batch-form');
      var data = new FormData(form);

      try {
        var res = await fetch('https://formspree.io/f/mpqgpdjn', {
          method: 'POST', body: data, headers: { Accept: 'application/json' }
        });
        if (res.ok) {
          form.classList.add('hidden');
          document.getElementById('batch-success').classList.remove('hidden');
        } else {
          alert('Something went wrong. Please try again.');
        }
      } catch (_) {
        alert('Network error. Please check your connection and try again.');
      }
    });

    renderExtraMembers();
  })();
</script>

<style>
  /* ── Tokens ────────────────────────────────────────── */
  :root {
    --accent: #2563eb;
  }

  /* ── Layout ────────────────────────────────────────── */
  .container {
    max-width: 960px;
    margin-inline: auto;
    padding-inline: 24px;
  }

  /* ── Hero ──────────────────────────────────────────── */
  .hero {
    background: var(--surface-dark, #171717);
    color: #fff;
    padding: clamp(48px, 8vw, 96px) 0 clamp(40px, 6vw, 72px);
    overflow: hidden;
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 48px;
    align-items: center;
  }

  .hero-text {
    text-align: left;
  }

  .hero-visual {
    display: flex;
    justify-content: center;
    align-items: center;
  }

  .hero-headline {
    font-size: clamp(1.75rem, 4vw, 2.8rem);
    font-weight: 600;
    letter-spacing: -0.04em;
    line-height: 1.15;
    margin-bottom: 20px;
  }

  .hero-sub {
    font-size: clamp(0.95rem, 2vw, 1.05rem);
    color: #a3a3a3;
    max-width: 420px;
    margin-bottom: 36px;
    line-height: 1.7;
  }

  @media (max-width: 680px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .hero-text { text-align: center; }
    .hero-sub  { max-width: 100%; margin-inline: auto; }
    .hero-visual { order: -1; }
  }

  /* ── Buttons ───────────────────────────────────────── */
  .btn-primary {
    display: inline-block;
    background: #fff;
    color: #171717;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 14px 32px;
    border-radius: var(--radius-pill);
    border: none;
    cursor: pointer;
    transition: opacity 0.15s, transform 0.15s cubic-bezier(.34,1.56,.64,1);
  }

  .btn-primary:hover  { opacity: 0.88; transform: translateY(-2px); }
  .btn-primary:active { transform: scale(0.97); }

  .btn-full {
    display: block;
    width: 100%;
    background: var(--ink);
    color: var(--canvas);
    margin-top: 8px;
    text-align: center;
  }

  /* ── Sections ──────────────────────────────────────── */
  .section {
    padding: clamp(48px, 8vw, 80px) 0;
    background: var(--canvas);
  }

  .section-alt {
    background: var(--canvas-soft);
  }

  .section-title {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    margin-bottom: 8px;
    text-align: center;
  }

  .section-sub {
    text-align: center;
    color: var(--ink-2);
    margin-bottom: 48px;
  }

  /* ── Steps ─────────────────────────────────────────── */
  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 24px;
    margin-top: 48px;
  }

  .step-card {
    background: var(--canvas-soft);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px 24px;
    box-shadow: 0 1px 2px rgba(0,0,0,.04), 0 4px 12px rgba(0,0,0,.04);
    transition: transform 0.2s cubic-bezier(.34,1.56,.64,1), box-shadow 0.2s;
  }
  .step-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 2px 4px rgba(0,0,0,.06), 0 12px 28px rgba(0,0,0,.1);
  }

  .step-num {
    width: 36px;
    height: 36px;
    background: var(--ink);
    color: var(--canvas);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 600;
    font-size: 0.9rem;
    margin-bottom: 16px;
  }

  .step-title {
    font-size: 1rem;
    font-weight: 600;
    margin-bottom: 8px;
  }

  .step-desc {
    font-size: 0.9rem;
    color: var(--ink-2);
  }

  /* ── Pricing calculator ────────────────────────────── */
  .calc-card {
    background: var(--canvas);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 40px;
    box-shadow: 0 2px 4px rgba(0,0,0,.04), 0 8px 24px rgba(0,0,0,.06);
    display: flex;
    flex-direction: column;
    gap: 36px;
    max-width: 720px;
    margin-inline: auto;
  }

  @media (max-width: 600px) { .calc-card { padding: 24px 20px; } }

  .calc-block { display: flex; flex-direction: column; gap: 16px; }

  .calc-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--ink-2);
    display: flex;
    align-items: center;
    gap: 10px;
  }

  .class-badge {
    background: var(--ink);
    color: var(--canvas);
    font-size: 0.8rem;
    font-weight: 600;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    letter-spacing: 0;
    transition: transform 0.1s;
  }

  .calc-hint {
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    color: var(--ink-2);
    font-size: 0.78rem;
  }

  /* slider */
  .slider-wrap { display: flex; flex-direction: column; gap: 8px; position: relative; }

  .slider-track {
    position: relative;
    height: 4px;
    background: var(--border);
    border-radius: 4px;
    margin: 12px 0 4px;
  }

  .slider-fill {
    position: absolute;
    left: 0; top: 0; bottom: 0;
    background: var(--ink);
    border-radius: 4px;
    /* no transition — must track thumb instantly */
    will-change: width;
    width: 45%;
  }

  .class-slider {
    position: absolute;
    top: 50%;
    left: 0;
    transform: translateY(-50%);
    width: 100%;
    -webkit-appearance: none;
    appearance: none;
    background: transparent;
    cursor: grab;
    outline: none;
    margin: 0;
    touch-action: none;
  }

  .class-slider:active { cursor: grabbing; }

  .class-slider::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--ink);
    border: 3px solid #fff;
    box-shadow: 0 2px 10px rgba(0,0,0,.3);
    transition: transform 0.12s cubic-bezier(.34,1.56,.64,1), box-shadow 0.12s;
  }

  .class-slider:active::-webkit-slider-thumb {
    transform: scale(1.3);
    box-shadow: 0 4px 20px rgba(0,0,0,.35);
  }

  .class-slider::-moz-range-thumb {
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--ink);
    border: 3px solid #fff;
    box-shadow: 0 2px 10px rgba(0,0,0,.3);
    cursor: grab;
  }

  .slider-ticks {
    display: flex;
    justify-content: space-between;
    padding-top: 6px;
  }

  .slider-ticks span {
    font-size: 0.72rem;
    color: var(--ink-2);
    width: 20px;
    text-align: center;
    transition: color 0.15s, font-weight 0.15s;
  }

  .slider-ticks span.tick-active {
    color: var(--ink);
    font-weight: 600;
  }

  /* experience pills */
  .exp-pills {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .exp-pill {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 2px;
    padding: 12px 18px;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--canvas);
    cursor: pointer;
    font-family: inherit;
    transition: border-color 0.15s, background 0.15s, transform 0.15s;
  }

  .exp-pill:hover { border-color: #aaa; transform: translateY(-1px); }

  .exp-pill.active {
    border-color: var(--ink);
    background: var(--ink);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(0,0,0,.15);
  }

  .exp-name {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--ink);
  }

  .exp-pill.active .exp-name { color: #fff; }

  .exp-sub {
    font-size: 0.72rem;
    color: var(--ink-2);
  }

  .exp-pill.active .exp-sub { color: rgba(255,255,255,.65); }

  /* subjects — all :global because elements are created in JS */
  .subject-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;
  }

  @media (max-width: 480px) {
    .subject-grid { grid-template-columns: 1fr; }
  }

  :global(.subject-card) {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 16px 18px;
    border: 1.5px solid var(--border);
    border-radius: 14px;
    background: var(--canvas);
    cursor: pointer;
    font-family: inherit;
    text-align: left;
    transition: border-color 0.18s, background 0.18s, box-shadow 0.18s,
                transform 0.18s cubic-bezier(.34,1.56,.64,1);
    user-select: none;
  }

  :global(.subject-card:hover:not(.disabled)) {
    border-color: var(--sc);
    box-shadow: 0 4px 16px rgba(0,0,0,.08);
    transform: translateY(-2px);
  }

  :global(.subject-card.selected) {
    border-color: var(--sc);
    background: var(--sc);
    box-shadow: 0 6px 20px rgba(0,0,0,.18);
    transform: translateY(-3px);
  }

  :global(.subject-card.disabled) {
    opacity: 0.32;
    cursor: not-allowed;
    transform: none;
    pointer-events: none;
  }

  :global(.sc-icon) {
    font-size: 1.4rem;
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: rgba(0,0,0,.05);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: background 0.18s;
  }

  :global(.subject-card.selected .sc-icon) {
    background: rgba(255,255,255,.18);
  }

  :global(.sc-body) {
    display: flex;
    flex-direction: column;
    gap: 2px;
    flex: 1;
  }

  :global(.sc-name) {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--ink);
    transition: color 0.18s;
  }

  :global(.subject-card.selected .sc-name) { color: #fff; }

  :global(.sc-note) {
    font-size: 0.72rem;
    color: var(--ink-2);
    transition: color 0.18s;
  }

  :global(.subject-card.selected .sc-note) { color: rgba(255,255,255,.7); }

  :global(.sc-check) {
    width: 22px;
    height: 22px;
    border-radius: 50%;
    border: 1.5px solid var(--border);
    display: flex;
    align-items: center;
    justify-content: center;
    color: transparent;
    flex-shrink: 0;
    transition: border-color 0.18s, background 0.18s, color 0.18s;
  }

  :global(.subject-card:hover:not(.disabled) .sc-check) {
    border-color: var(--sc);
  }

  :global(.subject-card.selected .sc-check) {
    background: rgba(255,255,255,.25);
    border-color: transparent;
    color: #fff;
  }

  /* result */
  .price-result {
    background: var(--canvas-soft);
    border: 1px solid var(--border);
    border-radius: 14px;
    padding: 28px 32px;
    text-align: center;
  }

  .price-result-inner {
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 10px;
    flex-wrap: wrap;
  }

  .price-result-label {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--ink-2);
  }

  .price-result-amount {
    font-size: 2.4rem;
    font-weight: 600;
    letter-spacing: -0.04em;
    color: var(--ink);
    transition: all 0.25s cubic-bezier(.34,1.56,.64,1);
  }

  .price-result-amount.pop {
    transform: scale(1.08);
  }

  .price-result-unit {
    font-size: 1rem;
    color: var(--ink-2);
    font-weight: 500;
  }

  .price-result-note {
    font-size: 0.78rem;
    color: var(--ink-2);
    margin-top: 10px;
  }

  /* ── Form ──────────────────────────────────────────── */
  .form-container {
    max-width: 640px;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 40px;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  @media (max-width: 560px) {
    .form-row { grid-template-columns: 1fr; }
  }

  .contact-form label {
    display: flex;
    flex-direction: column;
    gap: 6px;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--ink-2);
  }

  .contact-form input,
  .contact-form select {
    padding: 10px 14px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-size: 0.95rem;
    font-family: inherit;
    background: var(--canvas);
    color: var(--ink);
    outline: none;
    transition: border-color 0.15s;
  }

  .contact-form input:focus,
  .contact-form select:focus {
    border-color: var(--ink);
  }

  /* ── Calc validation error ── */
  .calc-error {
    background: rgba(251,191,36,.1);
    border: 1px solid rgba(251,191,36,.4);
    border-radius: 8px;
    color: var(--ink);
    font-size: 0.875rem;
    font-weight: 500;
    padding: 12px 16px;
    margin-bottom: 12px;
    animation: shake 0.4s cubic-bezier(.36,.07,.19,.97) both;
  }
  @keyframes shake {
    10%, 90% { transform: translateX(-2px); }
    20%, 80% { transform: translateX(3px); }
    30%, 50%, 70% { transform: translateX(-4px); }
    40%, 60% { transform: translateX(4px); }
  }

  /* ── Form success state ── */
  .form-success {
    text-align: center;
    padding: 48px 32px;
    border-radius: 16px;
    background: var(--canvas);
    border: 1px solid var(--border);
    box-shadow: 0 2px 8px rgba(0,0,0,.04), 0 8px 32px rgba(0,0,0,.06);
    margin-top: 40px;
    animation: fsIn 0.5s cubic-bezier(.34,1.56,.64,1) both;
  }
  @keyframes fsIn {
    from { opacity: 0; transform: translateY(16px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0)    scale(1); }
  }

  .fs-icon {
    width: 64px;
    height: 64px;
    margin: 0 auto 20px;
    color: #16a34a;
  }
  .fs-icon svg { width: 100%; height: 100%; }

  .fs-circle {
    stroke-dasharray: 157;
    stroke-dashoffset: 157;
    animation: drawCircle 0.5s 0.1s cubic-bezier(.4,0,.2,1) forwards;
  }
  @keyframes drawCircle {
    to { stroke-dashoffset: 0; }
  }

  .fs-check {
    stroke-dasharray: 36;
    stroke-dashoffset: 36;
    animation: drawCheck 0.35s 0.55s cubic-bezier(.4,0,.2,1) forwards;
  }
  @keyframes drawCheck {
    to { stroke-dashoffset: 0; }
  }

  .fs-title {
    font-size: 1.35rem;
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 8px;
    letter-spacing: -0.02em;
  }
  .fs-body {
    color: var(--ink-2);
    font-size: 0.95rem;
    margin: 0 0 6px;
  }
  .fs-sub {
    color: var(--ink-2);
    font-size: 0.82rem;
    margin: 0;
    opacity: 0.7;
  }

  /* ── Batch section ─────────────────────────────────── */
  .batch-layout {
    display: grid;
    grid-template-columns: 1fr 1.6fr;
    gap: 48px;
    align-items: start;
    margin-top: 48px;
  }

  @media (max-width: 720px) {
    .batch-layout { grid-template-columns: 1fr; gap: 32px; }
  }

  .batch-benefits {
    display: flex;
    flex-direction: column;
    gap: 24px;
  }

  .batch-benefit {
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .bb-icon {
    width: 40px;
    height: 40px;
    border-radius: 10px;
    background: var(--ink);
    color: var(--canvas);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .bb-title {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--ink);
    margin: 0 0 4px;
  }

  .bb-desc {
    font-size: 0.85rem;
    color: var(--ink-2);
    margin: 0;
    line-height: 1.55;
  }

  .batch-card {
    background: var(--canvas);
    border: 1px solid var(--border);
    border-radius: 20px;
    padding: 32px;
    box-shadow: 0 2px 4px rgba(0,0,0,.04), 0 8px 24px rgba(0,0,0,.06);
  }

  @media (max-width: 600px) { .batch-card { padding: 20px 16px; } }

  .batch-size-row {
    margin-bottom: 28px;
  }

  .batch-field-label {
    font-size: 0.78rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--ink-2);
    margin: 0 0 12px;
  }

  .batch-size-pills {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  .batch-size-pill {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
    padding: 10px 18px;
    border: 1.5px solid var(--border);
    border-radius: 12px;
    background: var(--canvas);
    cursor: pointer;
    font-family: inherit;
    transition: border-color 0.15s, background 0.15s, transform 0.15s cubic-bezier(.34,1.56,.64,1), box-shadow 0.15s;
    user-select: none;
  }

  .batch-size-pill:hover {
    border-color: #aaa;
    transform: translateY(-1px);
  }

  .batch-size-pill.active {
    border-color: var(--ink);
    background: var(--ink);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(0,0,0,.15);
  }

  .bsp-num {
    font-size: 1.1rem;
    font-weight: 600;
    color: var(--ink);
    line-height: 1;
    transition: color 0.15s;
  }

  .batch-size-pill.active .bsp-num { color: #fff; }

  .bsp-label {
    font-size: 0.68rem;
    color: var(--ink-2);
    transition: color 0.15s;
  }

  .batch-size-pill.active .bsp-label { color: rgba(255,255,255,.65); }

  .batch-form-inner {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  :global(.batch-member-block) {
    display: flex;
    flex-direction: column;
    gap: 8px;
    padding: 16px;
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--canvas-soft);
    animation: memberIn 0.25s cubic-bezier(.34,1.56,.64,1) both;
  }

  @keyframes memberIn {
    from { opacity: 0; transform: translateY(8px); }
    to   { opacity: 1; transform: none; }
  }

  :global(.batch-member-label) {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.07em;
    color: var(--ink-2);
    margin: 0;
  }

  :global(.batch-member-row) {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  @media (max-width: 520px) {
    :global(.batch-member-row) { grid-template-columns: 1fr; }
  }

  :global(.batch-form-inner label) {
    display: flex;
    flex-direction: column;
    gap: 5px;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--ink-2);
  }

  :global(.batch-form-inner input) {
    padding: 9px 12px;
    border: 1px solid var(--border);
    border-radius: 6px;
    font-size: 0.9rem;
    font-family: inherit;
    background: var(--canvas);
    color: var(--ink);
    outline: none;
    transition: border-color 0.15s;
  }

  :global(.batch-form-inner input:focus) { border-color: var(--ink); }

  /* ── Stats bar ────────────────────────────────────────── */
  .stats-bar {
    background: var(--surface-dark);
    padding: 28px 0;
  }

  .stats-inner {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
    flex-wrap: wrap;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding: 8px 40px;
    gap: 4px;
  }

  .stat-num {
    font-size: 1.55rem;
    font-weight: 600;
    color: #fff;
    letter-spacing: -0.03em;
  }

  .stat-label {
    font-size: 0.78rem;
    color: rgba(255,255,255,.5);
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  .stat-divider {
    width: 1px;
    height: 40px;
    background: rgba(255,255,255,.12);
  }

  @media (max-width: 600px) {
    .stat-divider { display: none; }
    .stat-item { padding: 8px 24px; }
    .stats-inner { gap: 4px; }
  }

  /* ── Smart Match Quiz ──────────────────────────────────── */
  .section-dark {
    background: var(--surface-dark, #171717);
    color: #fff;
  }

  .eyebrow-light {
    text-align: center;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: rgba(255,255,255,.45);
    margin-bottom: 12px;
  }

  .section-title-light {
    font-size: clamp(1.4rem, 3vw, 2rem);
    font-weight: 600;
    letter-spacing: -0.03em;
    text-align: center;
    color: #fff;
    margin-bottom: 8px;
  }

  .section-sub-light {
    text-align: center;
    color: rgba(255,255,255,.5);
    margin-bottom: 48px;
    font-size: 0.95rem;
  }

  .quiz-card {
    max-width: 640px;
    margin-inline: auto;
    background: rgba(255,255,255,.06);
    border: 1px solid rgba(255,255,255,.12);
    border-radius: 20px;
    padding: 36px;
    position: relative;
  }

  .quiz-step { display: none; }
  .quiz-step.active { display: block; }

  .quiz-q {
    font-size: 1.15rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 24px;
    text-align: center;
  }

  .quiz-options {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
  }

  .quiz-opt {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    padding: 16px 12px;
    background: rgba(255,255,255,.05);
    border: 1px solid rgba(255,255,255,.12);
    border-radius: 12px;
    cursor: pointer;
    transition: background 0.15s, border-color 0.15s, transform 0.15s cubic-bezier(.34,1.56,.64,1);
    color: #fff;
  }

  .quiz-opt:hover {
    background: rgba(255,255,255,.12);
    border-color: rgba(255,255,255,.3);
    transform: translateY(-2px);
  }

  .quiz-opt.selected {
    background: rgba(255,255,255,.15);
    border-color: rgba(255,255,255,.5);
  }

  .qo-icon { font-size: 1.5rem; }

  .qo-label {
    font-size: 0.82rem;
    font-weight: 500;
    text-align: center;
    line-height: 1.35;
  }

  .quiz-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 28px;
  }

  .qdot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: rgba(255,255,255,.2);
    transition: background 0.2s, transform 0.2s;
  }

  .qdot.active {
    background: #fff;
    transform: scale(1.25);
  }

  .quiz-result {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 16px;
  }

  /* ── Quiz searching animation ── */
  .quiz-searching {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 28px;
    padding: 12px 0 8px;
  }

  .qs-spinner {
    position: relative;
    width: 72px;
    height: 72px;
  }

  .qs-ring {
    position: absolute;
    inset: 0;
    border-radius: 50%;
    border: 3px solid transparent;
    border-top-color: #fff;
    animation: qs-spin 1.2s linear infinite;
  }
  .qs-ring-2 {
    inset: 10px;
    border-top-color: rgba(255,255,255,0.55);
    animation-duration: 1.8s;
    animation-direction: reverse;
  }
  .qs-ring-3 {
    inset: 20px;
    border-top-color: rgba(255,255,255,0.25);
    animation-duration: 2.4s;
  }

  @keyframes qs-spin {
    to { transform: rotate(360deg); }
  }

  .qs-label {
    font-size: 1.05rem;
    font-weight: 600;
    color: #fff;
    letter-spacing: -0.02em;
    transition: opacity 0.3s;
  }

  .qs-steps {
    display: flex;
    flex-direction: column;
    gap: 14px;
    width: 100%;
    max-width: 280px;
  }

  .qs-step {
    display: flex;
    align-items: center;
    gap: 10px;
    opacity: 0.3;
    transition: opacity 0.4s;
    font-size: 0.875rem;
    color: rgba(255,255,255,0.85);
  }
  .qs-step-active { opacity: 1; }
  .qs-step-done   { opacity: 0.6; }

  .qs-step-icon { font-size: 1rem; width: 20px; text-align: center; flex-shrink: 0; }
  .qs-step-text { flex: 1; }
  .qs-step-tick {
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: rgba(255,255,255,0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    color: #fff;
    flex-shrink: 0;
    transition: background 0.3s;
  }
  .qs-step-done .qs-step-tick {
    background: rgba(255,255,255,0.5);
  }

  /* ── End quiz searching animation ── */

  .qr-badge {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: #fff;
    color: #171717;
    font-size: 1.6rem;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: 700;
  }

  .qr-title {
    font-size: 1.2rem;
    font-weight: 600;
    color: #fff;
  }

  .qr-body {
    font-size: 0.92rem;
    color: rgba(255,255,255,.7);
    max-width: 440px;
    line-height: 1.6;
  }

  .btn-quiz-cta {
    background: #fff;
    color: #171717;
    font-weight: 600;
    font-size: 0.95rem;
    padding: 13px 32px;
    border-radius: 100px;
    border: none;
    cursor: pointer;
    transition: opacity 0.15s, transform 0.15s cubic-bezier(.34,1.56,.64,1);
    margin-top: 4px;
  }

  .btn-quiz-cta:hover { opacity: 0.88; transform: translateY(-2px); }

  .quiz-restart {
    background: none;
    border: none;
    color: rgba(255,255,255,.45);
    font-size: 0.82rem;
    cursor: pointer;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .quiz-restart:hover { color: rgba(255,255,255,.7); }

  @media (max-width: 520px) {
    .quiz-card { padding: 24px 16px; }
    .quiz-options { grid-template-columns: 1fr; }
  }

  /* ── FAQ ───────────────────────────────────────────────── */
  .faq-container { max-width: 720px; }

  .faq-list {
    margin-top: 40px;
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid var(--border);
    border-radius: 16px;
    overflow: hidden;
  }

  .faq-item {
    border-bottom: 1px solid var(--border);
  }

  .faq-item:last-child { border-bottom: none; }

  .faq-q {
    list-style: none;
    padding: 18px 20px;
    font-weight: 600;
    font-size: 0.95rem;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    transition: background 0.15s;
  }

  .faq-q::-webkit-details-marker { display: none; }

  .faq-q::after {
    content: '+';
    font-size: 1.2rem;
    font-weight: 400;
    color: var(--ink-2);
    flex-shrink: 0;
    transition: transform 0.2s;
  }

  .faq-item[open] .faq-q::after { transform: rotate(45deg); }

  .faq-item[open] .faq-q { background: var(--canvas-soft); }

  .faq-a {
    padding: 0 20px 18px;
    font-size: 0.9rem;
    color: var(--ink-2);
    line-height: 1.65;
  }

  .hidden { display: none !important; }

  /* ── Auth modal ─────────────────────────────────────── */
  .modal-backdrop {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,.45);
    z-index: 100;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 16px;
  }

  .modal-card {
    background: var(--canvas);
    border-radius: 16px;
    padding: 24px 24px 20px;
    max-width: 380px;
    width: 100%;
    position: relative;
    box-shadow: 0 8px 32px rgba(0,0,0,.18);
    animation: modal-in 0.16s ease-out;
    max-height: 90vh;
    overflow-y: auto;
  }

  @keyframes modal-in {
    from { opacity: 0; transform: translateY(10px); }
    to   { opacity: 1; transform: none; }
  }

  .modal-close {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 1px solid var(--border);
    background: var(--canvas-soft);
    color: var(--ink-2);
    font-size: 1rem;
    line-height: 1;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }

  .modal-close:hover { background: var(--border); }

  .modal-eyebrow { display: none; }

  .modal-title {
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: -0.02em;
    margin-bottom: 4px;
    padding-right: 32px;
  }

  .modal-sub {
    font-size: 0.82rem;
    color: var(--ink-2);
    margin-bottom: 16px;
    line-height: 1.5;
  }

  .auth-tabs {
    display: flex;
    gap: 3px;
    background: var(--canvas-soft);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 3px;
    margin-bottom: 16px;
  }

  .auth-tab {
    flex: 1;
    padding: 7px 12px;
    border: none;
    border-radius: 6px;
    background: transparent;
    font-family: inherit;
    font-size: 0.83rem;
    font-weight: 500;
    color: var(--ink-2);
    cursor: pointer;
    transition: background 0.12s, color 0.12s, box-shadow 0.12s;
  }

  .auth-tab.active {
    background: var(--canvas);
    color: var(--ink);
    box-shadow: 0 1px 3px rgba(0,0,0,.1);
  }

  .auth-form {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .auth-form label {
    display: flex;
    flex-direction: column;
    gap: 4px;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--ink-2);
  }

  .auth-form input {
    padding: 8px 11px;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-size: 0.88rem;
    font-family: inherit;
    background: var(--canvas);
    color: var(--ink);
    outline: none;
    transition: border-color 0.15s;
  }

  .auth-form input:focus { border-color: var(--ink); }

  .auth-error {
    font-size: 0.78rem;
