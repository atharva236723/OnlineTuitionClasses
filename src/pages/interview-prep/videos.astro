---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const videos = [
  {
    category: "confidence",
    label: "Confidence",
    items: [
      { id: "Ks-_Mh1QhMc", title: "Your Body Language Shapes Who You Are", author: "Amy Cuddy · TED", duration: "21 min" },
      { id: "lmyZMtPVodo", title: "Why Good Leaders Make You Feel Safe", author: "Simon Sinek · TED", duration: "12 min" },
    ]
  },
  {
    category: "communication",
    label: "Communication",
    items: [
      { id: "eIho2S0ZahI", title: "How to Speak So People Want to Listen", author: "Julian Treasure · TED", duration: "10 min" },
      { id: "HAnw168huqA", title: "The Secret Structure of Great Talks", author: "Nancy Duarte · TED", duration: "18 min" },
    ]
  },
  {
    category: "mindset",
    label: "Mindset",
    items: [
      { id: "pN34FNbOKXc", title: "The Power of Believing You Can Improve", author: "Carol Dweck · TED", duration: "10 min" },
      { id: "H14bBuluwB8", title: "Grit — the Power of Passion and Perseverance", author: "Angela Duckworth · TED", duration: "6 min" },
    ]
  },
  {
    category: "technique",
    label: "Interview Technique",
    items: [
      { id: "KWNvKp_FD-I", title: "How to Answer 'Tell Me About Yourself'", author: "Interview Prep · Career Tips", duration: "8 min" },
      { id: "1mHjMNZZvFo", title: "The STAR Method — Answer Any Question", author: "Self Improvement · Tips", duration: "7 min" },
    ]
  },
];

const whyWatch = [
  { icon: "💪", title: "Confidence", desc: "See what real confident body language looks like — and how to embody it in under a week." },
  { icon: "🎙️", title: "Communication", desc: "Learn the vocal patterns and structural habits that make people want to keep listening." },
  { icon: "🧠", title: "Mindset", desc: "Understand why effort matters more than talent — and how to make yourself believe it." },
  { icon: "🎯", title: "Technique", desc: "Watch real examples of STAR answers so you know what good actually sounds like." },
];
---

<Layout
  title="Interview Prep Video Hub — Watch & Learn | Online Tuition Classes"
  description="Curated YouTube videos on interview tips, common interview questions, what to wear to an interview, and how to write a thank you email after interview. Free video library in 4 categories."
  keywords="interview tips, job interview questions, what to wear to an interview, thank you email after interview, how to prepare for an interview, interview"
  ogTitle="Interview Prep Video Hub — 8 Curated Videos in 4 Categories"
  ogDescription="Watch curated interview preparation videos covering tips, body language, common questions, and post-interview follow-up. Free resource from OTC."
  ogUrl="https://onlinetuitionclasses.com/interview-prep/videos"
  canonical="https://onlinetuitionclasses.com/interview-prep/videos"
>
  <Nav activePage="interview-prep" />

  <section class="ip-sub-hero">
    <div class="ip-container">
      <a href="/interview-prep" class="ip-breadcrumb">← Interview Prep Hub</a>
      <p class="ip-eyebrow">Module 5 of 5</p>
      <h1 class="ip-sub-title">Video <span class="ip-gradient-text">Hub</span></h1>
      <p class="ip-sub-desc">Hand-picked talks from world-class communicators and thinkers. Each one is directly applicable to your next interview. Watch. Learn. Apply.</p>
    </div>
  </section>

  <div class="ip-module-nav-wrap">
    <div class="ip-container">
      <nav class="ip-module-nav">
        <a href="/interview-prep/compare" class="ip-mn-link">⚡ Mindset</a>
        <a href="/interview-prep/frameworks" class="ip-mn-link">🧱 Frameworks</a>
        <a href="/interview-prep/questions" class="ip-mn-link">💬 Questions</a>
        <a href="/interview-prep/plan" class="ip-mn-link">📅 Plan</a>
        <a href="/interview-prep/videos" class="ip-mn-link active">▶ Videos</a>
      </nav>
    </div>
  </div>

  <!-- ── WHY WATCH ── -->
  <section class="ip-section ip-section-alt" id="why">
    <div class="ip-container">
      <p class="ip-section-eye reveal">Why these videos</p>
      <h2 class="ip-section-title reveal">Four areas. Eight talks.<br />All directly applicable.</h2>
      <div class="ip-why-grid">
        {whyWatch.map((w, i) => (
          <div class="ip-why-card reveal" style={`transition-delay:${i * 0.08}s`}>
            <span class="ip-why-icon">{w.icon}</span>
            <h3 class="ip-why-title">{w.title}</h3>
            <p class="ip-why-desc">{w.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── VIDEO HUB ── -->
  <section class="ip-section" id="videos">
    <div class="ip-container">
      <p class="ip-section-eye reveal">The playlist</p>
      <h2 class="ip-section-title reveal">Watch. Learn. Apply.</h2>
      <p class="ip-section-sub reveal">Use the tabs to jump between categories. Click any card to watch the video in a focused player.</p>

      <div class="ip-video-tabs reveal" id="video-tabs">
        {videos.map((v, i) => (
          <button class:list={["ip-vtab", i === 0 && "active"]} data-cat={v.category}>{v.label}</button>
        ))}
      </div>

      {videos.map((v, vi) => (
        <div class:list={["ip-video-panel", vi === 0 && "active"]} data-panel={v.category} id={`panel-${v.category}`}>
          <div class="ip-video-grid">
            {v.items.map((vid, vi2) => (
              <div class="ip-video-card reveal" style={`transition-delay:${vi2 * 0.1}s`}>
                <div class="ip-video-thumb" data-videoid={vid.id}>
                  <img src={`https://img.youtube.com/vi/${vid.id}/hqdefault.jpg`} alt={vid.title} class="ip-thumb-img" loading="lazy" />
                  <div class="ip-play-btn" aria-label="Play video">
                    <svg width="28" height="28" viewBox="0 0 24 24" fill="white"><path d="M8 5v14l11-7z"/></svg>
                  </div>
                  <div class="ip-video-duration">{vid.duration}</div>
                </div>
                <div class="ip-video-info">
                  <h3 class="ip-video-title">{vid.title}</h3>
                  <p class="ip-video-author">{vid.author}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── VIDEO MODAL ── -->
  <div id="ip-video-modal" class="ip-modal-backdrop hidden" role="dialog" aria-modal="true">
    <div class="ip-modal-body">
      <button class="ip-modal-close" id="ip-modal-close" aria-label="Close">&times;</button>
      <div class="ip-modal-frame">
        <iframe id="ip-video-iframe" src="" allow="autoplay; encrypted-media" allowfullscreen loading="lazy" title="Interview prep video"></iframe>
      </div>
    </div>
  </div>

  <div class="ip-page-nav">
    <div class="ip-container">
      <a href="/interview-prep/plan" class="ip-pnav-back">← 14-Day Plan</a>
      <a href="/interview-prep" class="ip-pnav-next">Back to hub ↑</a>
    </div>
  </div>

  <Footer />
</Layout>

<script is:inline>
  function initVideoTabs() {
    var tabs = document.querySelectorAll('.ip-vtab');
    var panels = document.querySelectorAll('.ip-video-panel');
    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        tabs.forEach(function(t) { t.classList.remove('active'); });
        panels.forEach(function(p) { p.classList.remove('active'); });
        tab.classList.add('active');
        var panel = document.getElementById('panel-' + tab.getAttribute('data-cat'));
        if (panel) panel.classList.add('active');
      });
    });
  }
  initVideoTabs();
  document.addEventListener('astro:after-swap', initVideoTabs);

  function initVideoModal() {
    var modal = document.getElementById('ip-video-modal');
    var iframe = document.getElementById('ip-video-iframe');
    var closeBtn = document.getElementById('ip-modal-close');
    if (!modal || !iframe || !closeBtn) return;
    document.querySelectorAll('.ip-video-thumb').forEach(function(thumb) {
      thumb.addEventListener('click', function() {
        var vid = thumb.getAttribute('data-videoid');
        iframe.src = 'https://www.youtube-nocookie.com/embed/' + vid + '?autoplay=1&rel=0';
        modal.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      });
    });
    function closeModal() { modal.classList.add('hidden'); iframe.src = ''; document.body.style.overflow = ''; }
    closeBtn.addEventListener('click', closeModal);
    modal.addEventListener('click', function(e) { if (e.target === modal) closeModal(); });
    document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeModal(); });
  }
  initVideoModal();
  document.addEventListener('astro:after-swap', initVideoModal);
</script>

<style>
  :root {
    --ip-dark: #0a0a0a; --ip-ink: #171717; --ip-muted: #6b7280;
    --ip-purple: #7c3aed; --ip-border: #e5e5e5;
    --ip-gradient: linear-gradient(135deg, #7c3aed 0%, #3b82f6 50%, #06b6d4 100%);
  }
  .ip-container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
  .ip-section { padding: 80px 0; }
  .ip-section-alt { background: #f8f8f8; }
  .ip-gradient-text { background: var(--ip-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

  .ip-sub-hero { background: var(--ip-dark); padding: 80px 24px 56px; text-align: center; }
  .ip-breadcrumb { font-size: 0.8rem; color: #6b7280; display: inline-block; margin-bottom: 20px; transition: color 0.2s; }
  .ip-breadcrumb:hover { color: #9ca3af; }
  .ip-eyebrow { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ip-purple); margin-bottom: 12px; }
  .ip-sub-title { font-size: clamp(2rem, 4vw, 3.2rem); font-weight: 600; letter-spacing: -0.04em; color: #fff; line-height: 1.1; margin-bottom: 16px; }
  .ip-sub-desc { font-size: 1rem; color: #9ca3af; max-width: 560px; margin: 0 auto; line-height: 1.7; }

  .ip-module-nav-wrap { background: #fff; border-bottom: 1px solid var(--ip-border); position: sticky; top: 64px; z-index: 40; }
  .ip-module-nav { display: flex; gap: 0; overflow-x: auto; scrollbar-width: none; }
  .ip-module-nav::-webkit-scrollbar { display: none; }
  .ip-mn-link { font-size: 0.82rem; font-weight: 500; color: var(--ip-muted); padding: 14px 20px; white-space: nowrap; border-bottom: 2px solid transparent; transition: color 0.2s, border-color 0.2s; }
  .ip-mn-link:hover { color: var(--ip-ink); }
  .ip-mn-link.active { color: var(--ip-purple); border-bottom-color: var(--ip-purple); font-weight: 600; }

  .ip-section-eye { font-size: 0.75rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ip-purple); margin-bottom: 12px; display: block; }
  .ip-section-title { font-size: clamp(1.8rem, 3.5vw, 2.4rem); font-weight: 600; letter-spacing: -0.03em; line-height: 1.2; color: var(--ip-ink); margin-bottom: 16px; }
  .ip-section-sub { font-size: 1rem; color: var(--ip-muted); max-width: 580px; line-height: 1.7; margin-bottom: 40px; }

  /* Why watch */
  .ip-why-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px; margin-top: 40px; }
  .ip-why-card { background: #fff; border: 1px solid var(--ip-border); border-radius: 16px; padding: 24px; transition: box-shadow 0.2s, transform 0.2s; }
  .ip-why-card:hover { box-shadow: 0 6px 20px rgba(0,0,0,0.08); transform: translateY(-2px); }
  .ip-why-icon { font-size: 1.6rem; display: block; margin-bottom: 10px; }
  .ip-why-title { font-size: 0.95rem; font-weight: 600; color: var(--ip-ink); margin-bottom: 6px; }
  .ip-why-desc { font-size: 0.82rem; color: var(--ip-muted); line-height: 1.55; }

  /* Video tabs */
  .ip-video-tabs { display: flex; gap: 8px; margin-bottom: 36px; flex-wrap: wrap; }
  .ip-vtab { font-size: 0.875rem; font-weight: 500; padding: 8px 20px; border-radius: 100px; border: 1.5px solid var(--ip-border); background: transparent; color: var(--ip-muted); cursor: pointer; transition: all 0.2s; }
  .ip-vtab:hover { border-color: var(--ip-purple); color: var(--ip-purple); }
  .ip-vtab.active { background: var(--ip-ink); color: #fff; border-color: var(--ip-ink); }
  .ip-video-panel { display: none; }
  .ip-video-panel.active { display: block; }

  .ip-video-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 24px; }
  .ip-video-card { border-radius: 16px; overflow: hidden; background: #fff; border: 1px solid var(--ip-border); box-shadow: 0 2px 8px rgba(0,0,0,0.04); transition: transform 0.25s, box-shadow 0.25s; }
  .ip-video-card:hover { transform: translateY(-4px); box-shadow: 0 8px 32px rgba(0,0,0,0.12); }
  .ip-video-thumb { position: relative; aspect-ratio: 16/9; overflow: hidden; cursor: pointer; background: #111; }
  .ip-thumb-img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.3s, opacity 0.3s; }
  .ip-video-thumb:hover .ip-thumb-img { transform: scale(1.05); opacity: 0.8; }
  .ip-play-btn { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; }
  .ip-play-btn > * { width: 56px; height: 56px; border-radius: 50%; background: rgba(0,0,0,0.7); display: flex; align-items: center; justify-content: center; backdrop-filter: blur(4px); transition: transform 0.2s, background 0.2s; }
  .ip-video-thumb:hover .ip-play-btn > * { transform: scale(1.1); background: var(--ip-purple); }
  .ip-video-duration { position: absolute; bottom: 8px; right: 8px; background: rgba(0,0,0,0.75); color: #fff; font-size: 0.72rem; font-weight: 600; padding: 2px 7px; border-radius: 4px; }
  .ip-video-info { padding: 16px 18px 18px; }
  .ip-video-title { font-size: 0.95rem; font-weight: 600; color: var(--ip-ink); line-height: 1.4; margin-bottom: 4px; }
  .ip-video-author { font-size: 0.8rem; color: var(--ip-muted); }

  /* Modal */
  .ip-modal-backdrop { position: fixed; inset: 0; z-index: 200; background: rgba(0,0,0,0.85); backdrop-filter: blur(8px); display: flex; align-items: center; justify-content: center; padding: 24px; }
  .ip-modal-backdrop.hidden { display: none; }
  .ip-modal-body { position: relative; width: 100%; max-width: 900px; }
  .ip-modal-close { position: absolute; top: -44px; right: 0; width: 36px; height: 36px; border-radius: 50%; background: rgba(255,255,255,0.1); border: none; color: #fff; font-size: 1.4rem; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background 0.2s; }
  .ip-modal-close:hover { background: rgba(255,255,255,0.2); }
  .ip-modal-frame { position: relative; aspect-ratio: 16/9; border-radius: 12px; overflow: hidden; background: #000; }
  .ip-modal-frame iframe { position: absolute; inset: 0; width: 100%; height: 100%; border: none; }

  /* Page nav */
  .ip-page-nav { background: #f8f8f8; border-top: 1px solid var(--ip-border); padding: 24px; }
  .ip-page-nav .ip-container { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px; }
  .ip-pnav-back { font-size: 0.875rem; color: var(--ip-muted); font-weight: 500; transition: color 0.2s; }
  .ip-pnav-back:hover { color: var(--ip-ink); }
  .ip-pnav-next { font-size: 0.875rem; font-weight: 600; color: var(--ip-purple); transition: color 0.2s; }
  .ip-pnav-next:hover { color: #6d28d9; }

  @media (max-width: 600px) { .ip-video-grid { grid-template-columns: 1fr; } }
</style>
