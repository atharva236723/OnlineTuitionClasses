---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const frameworks = [
  {
    name: "STAR",
    full: "Situation · Task · Action · Result",
    color: "#7c3aed",
    bg: "rgba(124,58,237,0.07)",
    border: "rgba(124,58,237,0.22)",
    best: "Best for: behavioral & teamwork questions",
    example: "\"Tell me about a time you worked in a team.\"",
    steps: [
      { label: "S", word: "Situation", desc: "Set the scene briefly — what was happening and who was involved?" },
      { label: "T", word: "Task", desc: "What was your specific responsibility or goal in that situation?" },
      { label: "A", word: "Action", desc: "What did YOU do? Focus on your specific choices and steps." },
      { label: "R", word: "Result", desc: "What happened? Quantify if possible. What did you learn?" },
    ],
    tip: "Keep S + T brief — your audience wants to hear A + R. Spend 70% of your response on what you did and what changed.",
  },
  {
    name: "CAR",
    full: "Challenge · Action · Result",
    color: "#3b82f6",
    bg: "rgba(59,130,246,0.07)",
    border: "rgba(59,130,246,0.22)",
    best: "Best for: failure, difficulty & growth questions",
    example: "\"Tell me about a time you failed or made a mistake.\"",
    steps: [
      { label: "C", word: "Challenge", desc: "What was the specific problem, obstacle, or failure you faced?" },
      { label: "A", word: "Action", desc: "How did you respond? Walk through your thinking and steps." },
      { label: "R", word: "Result", desc: "What changed? What did you learn? How did it shape you?" },
    ],
    tip: "CAR is STAR without the Task — use it when the obstacle itself is the focus. Be honest about the failure; shine on the recovery.",
  },
  {
    name: "SOAR",
    full: "Situation · Obstacle · Action · Result",
    color: "#0ea5e9",
    bg: "rgba(14,165,233,0.07)",
    border: "rgba(14,165,233,0.22)",
    best: "Best for: resilience, pressure & adaptability questions",
    example: "\"Describe a time things didn't go to plan.\"",
    steps: [
      { label: "S", word: "Situation", desc: "Where were you and what were you originally trying to achieve?" },
      { label: "O", word: "Obstacle", desc: "What went wrong, changed, or blocked your original plan?" },
      { label: "A", word: "Action", desc: "How did you pivot or push through? Be specific about your choices." },
      { label: "R", word: "Result", desc: "What was the final outcome? What does this say about you?" },
    ],
    tip: "SOAR emphasises the pivot — the moment you adapted. That's what reveals character: proof you don't break under pressure.",
  },
];

const quickRef = [
  { q: "Tell me about yourself", framework: "None — use your 30-sec pitch: Name → Strength → Direction" },
  { q: "Tell me about a time you worked in a team", framework: "STAR" },
  { q: "Describe a failure or mistake", framework: "CAR" },
  { q: "Tell me about a challenge you overcame", framework: "SOAR" },
  { q: "What are your strengths?", framework: "One strength + brief STAR example" },
  { q: "What is your weakness?", framework: "CAR: the weakness → what you did → how you improved" },
  { q: "Where do you see yourself in 5 years?", framework: "None — direction + motivation, no rigid plan" },
  { q: "Why do you want to join this institution?", framework: "None — research + personal connection + specific opportunity" },
];
---

<Layout
  title="STAR, CAR & SOAR Communication Frameworks — Personality Development | Online Tuition Classes"
  description="Master STAR, CAR, and SOAR communication frameworks to express yourself with confidence and clarity. Learn how to structure memorable, structured responses for any situation."
  keywords="communication frameworks, STAR method, personality development, confidence building, communication skills, self-expression, personal growth"
  ogTitle="STAR / CAR / SOAR Frameworks — Communicate with Confidence"
  ogDescription="Three proven communication frameworks that make every response clear, structured, and confident. Free guide with examples for students."
  ogUrl="https://onlinetuitionclasses.com/personality-dev/frameworks"
  canonical="https://onlinetuitionclasses.com/personality-dev/frameworks"
>
  <Nav activePage="personality-dev" />

  <section class="ip-sub-hero">
    <div class="ip-container">
      <a href="/personality-dev" class="ip-breadcrumb">← Personality Development Hub</a>
      <p class="ip-eyebrow">Module 2 of 4</p>
      <h1 class="ip-sub-title">Communication <span class="ip-gradient-text">Frameworks</span></h1>
      <p class="ip-sub-desc">Three structural formulas that make every response clear, confident, and memorable. Pick the right one for the situation.</p>
    </div>
  </section>

  <div class="ip-module-nav-wrap">
    <div class="ip-container">
      <nav class="ip-module-nav">
        <a href="/personality-dev/compare" class="ip-mn-link">⚡ Mindset</a>
        <a href="/personality-dev/frameworks" class="ip-mn-link active">🧱 Frameworks</a>
        <a href="/personality-dev/questions" class="ip-mn-link">💬 Questions</a>
        <a href="/personality-dev/plan" class="ip-mn-link">📅 Plan</a>
      </nav>
    </div>
  </div>

  <!-- ── FRAMEWORK CARDS ── -->
  <section class="ip-section" id="frameworks">
    <div class="ip-container">
      <div class="ip-fw-list">
        {frameworks.map((fw, i) => (
          <div class="ip-fw-block reveal" style={`transition-delay:${i * 0.1}s; --fw-color:${fw.color}; --fw-bg:${fw.bg}; --fw-border:${fw.border}`}>
            <div class="ip-fw-head">
              <div>
                <span class="ip-fw-name" style={`color:${fw.color}`}>{fw.name}</span>
                <span class="ip-fw-full">{fw.full}</span>
              </div>
              <span class="ip-fw-best">{fw.best}</span>
            </div>
            <p class="ip-fw-example">Use when asked: {fw.example}</p>
            <div class="ip-fw-steps">
              {fw.steps.map((s) => (
                <div class="ip-fw-step">
                  <span class="ip-fw-letter" style={`background:${fw.color}`}>{s.label}</span>
                  <div class="ip-fw-step-body">
                    <span class="ip-fw-word">{s.word}</span>
                    <p class="ip-fw-desc">{s.desc}</p>
                  </div>
                </div>
              ))}
            </div>
            <div class="ip-fw-tip">
              <span class="ip-tip-label">💡 Pro tip</span>
              <p class="ip-tip-text">{fw.tip}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ── QUICK REFERENCE TABLE ── -->
  <section class="ip-section ip-section-alt" id="quick-ref">
    <div class="ip-container">
      <p class="ip-section-eye reveal">Quick reference</p>
      <h2 class="ip-section-title reveal">Which framework for which question?</h2>
      <p class="ip-section-sub reveal">Use this table when practising so you always reach for the right structure instinctively.</p>
      <div class="ip-ref-table-wrap reveal">
        <table class="ip-ref-table">
          <thead>
            <tr>
              <th>Question</th>
              <th>Best approach</th>
            </tr>
          </thead>
          <tbody>
            {quickRef.map((r) => (
              <tr>
                <td class="ip-ref-q">"{r.q}"</td>
                <td class="ip-ref-fw">{r.framework}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <div class="ip-page-nav">
    <div class="ip-container">
      <a href="/personality-dev/compare" class="ip-pnav-back">← Mediocre vs Pro</a>
      <a href="/personality-dev/questions" class="ip-pnav-next">Next: Self-Reflection Questions →</a>
    </div>
  </div>

  <Footer />
</Layout>

<style>
  :root {
    --ip-dark: #0a0a0a; --ip-ink: #171717; --ip-muted: #6b7280;
    --ip-purple: #7c3aed; --ip-border: #e5e5e5;
    --ip-gradient: linear-gradient(135deg, #7c3aed 0%, #3b82f6 50%, #06b6d4 100%);
  }
  .ip-container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
  .ip-section { padding: 80px 0; }
  .ip-section-alt { background: #f8f8f8; }
  .ip-gradient-text { background: var(--ip-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

  .ip-sub-hero { background: var(--ip-dark); padding: 80px 24px 56px; text-align: center; }
  .ip-breadcrumb { font-size: 0.8rem; color: #6b7280; display: inline-block; margin-bottom: 20px; transition: color 0.2s; }
  .ip-breadcrumb:hover { color: #9ca3af; }
  .ip-eyebrow { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ip-purple); margin-bottom: 12px; }
  .ip-sub-title { font-size: clamp(2rem, 4vw, 3.2rem); font-weight: 600; letter-spacing: -0.04em; color: #fff; line-height: 1.1; margin-bottom: 16px; }
  .ip-sub-desc { font-size: 1rem; color: #9ca3af; max-width: 560px; margin: 0 auto; line-height: 1.7; }

  .ip-module-nav-wrap { background: #fff; border-bottom: 1px solid var(--ip-border); position: sticky; top: 64px; z-index: 40; }
  .ip-module-nav { display: flex; gap: 0; overflow-x: auto; scrollbar-width: none; }
  .ip-module-nav::-webkit-scrollbar { display: none; }
  .ip-mn-link { font-size: 0.82rem; font-weight: 500; color: var(--ip-muted); padding: 14px 20px; white-space: nowrap; border-bottom: 2px solid transparent; transition: color 0.2s, border-color 0.2s; }
  .ip-mn-link:hover { color: var(--ip-ink); }
  .ip-mn-link.active { color: var(--ip-purple); border-bottom-color: var(--ip-purple); font-weight: 600; }

  /* Framework blocks */
  .ip-fw-list { display: flex; flex-direction: column; gap: 32px; }

  .ip-fw-block {
    background: var(--fw-bg, rgba(124,58,237,0.07));
    border: 1px solid var(--fw-border, rgba(124,58,237,0.22));
    border-radius: 20px;
    padding: 36px;
  }

  .ip-fw-head {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 20px;
    margin-bottom: 8px;
    flex-wrap: wrap;
  }
  .ip-fw-name { font-size: 2rem; font-weight: 700; letter-spacing: -0.03em; display: block; margin-bottom: 4px; }
  .ip-fw-full { font-size: 0.82rem; color: #6b7280; font-weight: 500; display: block; }
  .ip-fw-best { font-size: 0.78rem; color: var(--fw-color, #7c3aed); font-weight: 600; background: white; border: 1px solid var(--fw-border); border-radius: 100px; padding: 5px 14px; white-space: nowrap; align-self: flex-start; }
  .ip-fw-example { font-size: 0.88rem; color: #6b7280; font-style: italic; margin-bottom: 28px; padding-bottom: 24px; border-bottom: 1px solid var(--fw-border); }

  .ip-fw-steps { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 20px; margin-bottom: 24px; }
  .ip-fw-step { display: flex; gap: 14px; align-items: flex-start; }
  .ip-fw-letter { width: 32px; height: 32px; border-radius: 8px; color: #fff; font-size: 0.9rem; font-weight: 700; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 2px; }
  .ip-fw-word { font-size: 0.9rem; font-weight: 600; color: var(--ip-ink); display: block; margin-bottom: 4px; }
  .ip-fw-desc { font-size: 0.82rem; color: #4b5563; line-height: 1.55; }

  .ip-fw-tip { background: rgba(255,255,255,0.6); border-radius: 12px; padding: 16px 20px; border: 1px solid var(--fw-border); }
  .ip-tip-label { font-size: 0.78rem; font-weight: 700; color: var(--fw-color, #7c3aed); display: block; margin-bottom: 6px; }
  .ip-tip-text { font-size: 0.85rem; color: #374151; line-height: 1.6; }

  /* Section labels */
  .ip-section-eye { font-size: 0.75rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ip-purple); margin-bottom: 12px; display: block; }
  .ip-section-title { font-size: clamp(1.8rem, 3.5vw, 2.4rem); font-weight: 600; letter-spacing: -0.03em; line-height: 1.2; color: var(--ip-ink); margin-bottom: 16px; }
  .ip-section-sub { font-size: 1rem; color: var(--ip-muted); max-width: 580px; line-height: 1.7; margin-bottom: 40px; }

  /* Quick ref table */
  .ip-ref-table-wrap { overflow-x: auto; border-radius: 16px; border: 1px solid var(--ip-border); box-shadow: 0 2px 8px rgba(0,0,0,0.04); }
  .ip-ref-table { width: 100%; border-collapse: collapse; background: #fff; }
  .ip-ref-table thead tr { background: #f9fafb; border-bottom: 1px solid var(--ip-border); }
  .ip-ref-table th { text-align: left; padding: 14px 20px; font-size: 0.78rem; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: #9ca3af; }
  .ip-ref-table td { padding: 14px 20px; border-bottom: 1px solid #f3f4f6; vertical-align: top; }
  .ip-ref-table tr:last-child td { border-bottom: none; }
  .ip-ref-q { font-size: 0.875rem; color: var(--ip-ink); font-style: italic; width: 55%; }
  .ip-ref-fw { font-size: 0.875rem; color: var(--ip-purple); font-weight: 600; }

  /* Page nav */
  .ip-page-nav { background: #f8f8f8; border-top: 1px solid var(--ip-border); padding: 24px; }
  .ip-page-nav .ip-container { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px; }
  .ip-pnav-back { font-size: 0.875rem; color: var(--ip-muted); font-weight: 500; transition: color 0.2s; }
  .ip-pnav-back:hover { color: var(--ip-ink); }
  .ip-pnav-next { font-size: 0.875rem; font-weight: 600; color: var(--ip-purple); transition: color 0.2s; }
  .ip-pnav-next:hover { color: #6d28d9; }

  @media (max-width: 640px) {
    .ip-fw-block { padding: 24px; }
    .ip-fw-steps { grid-template-columns: 1fr; }
    .ip-fw-head { flex-direction: column; }
  }
</style>
