---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Footer from '../../components/Footer.astro';

const faqCategories = [
  {
    category: "general",
    label: "General",
    faqs: [
      { q: "How do I introduce myself confidently?", mediocre: "Listing every fact about yourself from birth — name, city, school, hobbies, pets...", pro: "A structured 30-second pitch: who you are → what you're good at → where you're headed. Practice it until it sounds natural, not rehearsed." },
      { q: "What if I don't know the answer to a question?", mediocre: "Going blank, saying 'I don't know' and waiting in silence.", pro: "Say 'Let me think through that.' Reason aloud. Show your process. Intellectual honesty beats nervous silence every time." },
      { q: "How do I deal with nerves before a presentation?", mediocre: "Trying to 'not be nervous' — which is impossible and makes it worse.", pro: "Reframe: nerves = excitement + readiness. Take slow breaths beforehand. Focus on the moment in front of you, not the outcome." },
      { q: "How should I present myself?", mediocre: "Last-minute outfit and no thought given to first impressions.", pro: "Dress intentionally and appropriately. When you look prepared, you feel prepared — and others notice." },
      { q: "How do I leave a strong lasting impression?", mediocre: "Finishing abruptly and walking away without acknowledgment.", pro: "Ask one thoughtful question. Close warmly: 'Thank you — I genuinely enjoyed this conversation.' Leave them with your energy, not just your words." },
    ],
  },
  {
    category: "academic",
    label: "Academic & Goals",
    faqs: [
      { q: "Why do you want to study this subject / join this institution?", mediocre: "'Because it's a good college and my parents told me to apply.'", pro: "Connect a specific experience or insight to the subject — then tie it to what this institution uniquely offers. Show you've researched them, not just applied randomly." },
      { q: "What is your favourite subject and why?", mediocre: "Picking whichever subject you scored highest in and just stating the name.", pro: "Pick a subject you genuinely enjoy. Explain what specifically excites you — a concept, a problem you solved, a moment it clicked. Passion is audible." },
      { q: "Where do you see yourself in 5 years?", mediocre: "'I want to be successful and earn a lot of money.'", pro: "Describe a direction, not a destination. Show ambition anchored in the work you want to do — not the title or salary you want to have." },
      { q: "What are your academic strengths and weaknesses?", mediocre: "Strengths: listing 5 things. Weaknesses: 'I work too hard' or 'I'm a perfectionist.'", pro: "One genuine strength with evidence. One real weakness — and immediately follow it with what you're actively doing to improve it. That's maturity." },
      { q: "How do you handle a subject you find difficult?", mediocre: "'I just study harder' — vague and unmemorable.", pro: "Describe your actual process: breaking it into smaller parts, seeking help early, using different resources. Concrete steps show self-awareness and resilience." },
    ],
  },
  {
    category: "behavioral",
    label: "Behavioral",
    faqs: [
      { q: "Tell me about a time you failed or made a mistake.", mediocre: "Denying failure: 'I can't think of any big mistakes, I always give my best.'", pro: "Pick a real example. Use CAR: the Challenge, the Action you took, and what you learned from the Result. Showing growth from failure is more impressive than claiming perfection." },
      { q: "Describe a time you worked in a team.", mediocre: "Vague: 'We worked together on a project and it went well.'", pro: "Use STAR: the team goal, your specific role, a conflict or challenge you navigated, and the outcome. Focus on your contribution — not the team's as a whole." },
      { q: "Tell me about a time you showed leadership.", mediocre: "Defaulting to formal titles: 'I was class monitor so I led the class.'", pro: "Leadership isn't a title. Describe a moment you took initiative, solved a problem others avoided, or helped someone else succeed. Those stories are far more compelling." },
      { q: "How do you manage time when you have multiple deadlines?", mediocre: "'I just stay up late and push through.' (Shows poor planning, not dedication.)", pro: "Describe a real system: prioritising by urgency and importance, breaking tasks into daily targets, communicating early if something is at risk. That's what decision-makers want to see." },
      { q: "What would your teachers / classmates say about you?", mediocre: "'They'd say I'm a good student and hardworking.' (Generic — every candidate says this.)", pro: "Pick one specific quality and back it with a story someone else might tell. 'My teacher would say I ask the questions others are afraid to ask — and she'd be right.'" },
    ],
  },
];

const questionBank = [
  {
    category: "Self & Background",
    icon: "👤",
    questions: [
      "Tell me about yourself.",
      "What are your hobbies and interests outside of academics?",
      "What makes you unique compared to other candidates?",
      "Describe yourself in three words — and justify each one.",
      "What do you consider your greatest achievement so far?",
    ],
  },
  {
    category: "Academic & Subject",
    icon: "📖",
    questions: [
      "Why did you choose this stream / subject combination?",
      "Which topic in your syllabus do you find most fascinating and why?",
      "Tell me about a book (academic or otherwise) that changed how you think.",
      "How do you prepare for exams? Walk me through your process.",
      "Is there a subject you struggled with? How did you handle it?",
    ],
  },
  {
    category: "Goals & Motivation",
    icon: "🎯",
    questions: [
      "Why do you want to join this institution?",
      "Where do you see yourself in 5 years?",
      "What career do you want to pursue and why?",
      "What motivates you when the work gets hard?",
      "If you could change one thing about the education system, what would it be?",
    ],
  },
  {
    category: "Behavioral & Situational",
    icon: "🧩",
    questions: [
      "Describe a time you failed. What did you learn?",
      "Tell me about a disagreement you had with a classmate — how did you resolve it?",
      "When have you gone above and beyond what was expected?",
      "Tell me about a time you had to meet a tight deadline.",
      "Have you ever had to change your opinion based on new information? Give an example.",
    ],
  },
  {
    category: "Current Affairs & General Knowledge",
    icon: "🌏",
    questions: [
      "What is one issue in the world today that you care deeply about?",
      "Who is a person — living or historical — you admire most, and why?",
      "What recent development in science, technology, or society excites you?",
      "What is the most important problem India needs to solve in the next decade?",
      "If you could give advice to your 10-year-old self, what would it be?",
    ],
  },
  {
    category: "Closing Questions (Ask These!)",
    icon: "❓",
    questions: [
      "What does success look like for a student in the first year here?",
      "What opportunities exist to work on independent projects or research?",
      "How do the best students here distinguish themselves?",
      "What is one thing you wish every incoming student knew before joining?",
      "Is there anything on my application you'd like me to clarify?",
    ],
  },
];
---

<Layout
  title="Self-Reflection Questions & Answers — Personality Development | Online Tuition Classes"
  description="Practice 15 important self-development questions with surface vs deep example answers. Plus 30+ question bank across behavioural, academic, and situational categories."
  keywords="personality development questions, self-reflection, communication skills, personal growth, self-awareness, confidence building for students"
  ogTitle="Self-Reflection Questions — 15 Q&As With Deep Answers"
  ogDescription="15 self-development questions with side-by-side surface vs deep answers and a 30+ question practice bank. Free personality development resource."
  ogUrl="https://onlinetuitionclasses.com/personality-dev/questions"
  canonical="https://onlinetuitionclasses.com/personality-dev/questions"
>
  <Nav activePage="personality-dev" />

  <section class="ip-sub-hero">
    <div class="ip-container">
      <a href="/personality-dev" class="ip-breadcrumb">← Personality Development Hub</a>
      <p class="ip-eyebrow">Module 3 of 4</p>
      <h1 class="ip-sub-title">Self-Reflection <span class="ip-gradient-text">Questions</span></h1>
      <p class="ip-sub-desc">15 of the most important self-development questions — each showing the surface answer and the deep answer side by side. Plus a 30+ question practice bank.</p>
    </div>
  </section>

  <div class="ip-module-nav-wrap">
    <div class="ip-container">
      <nav class="ip-module-nav">
        <a href="/personality-dev/compare" class="ip-mn-link">⚡ Mindset</a>
        <a href="/personality-dev/frameworks" class="ip-mn-link">🧱 Frameworks</a>
        <a href="/personality-dev/questions" class="ip-mn-link active">💬 Questions</a>
        <a href="/personality-dev/plan" class="ip-mn-link">📅 Plan</a>
      </nav>
    </div>
  </div>

  <!-- ── Q&A SECTION ── -->
  <section class="ip-section" id="qa">
    <div class="ip-container">
      <p class="ip-section-eye reveal">Surface vs deep answers</p>
      <h2 class="ip-section-title reveal">See both sides of every question</h2>
      <p class="ip-section-sub reveal">Click a question to reveal both approaches. Read them together — the difference is always in depth and self-awareness.</p>

      <div class="ip-video-tabs ip-qa-tabs reveal" id="qa-tabs">
        {faqCategories.map((cat, i) => (
          <button class:list={["ip-vtab", i === 0 && "active"]} data-qacat={cat.category}>{cat.label}</button>
        ))}
      </div>

      {faqCategories.map((cat, ci) => (
        <div class:list={["ip-qa-panel", ci === 0 && "active"]} data-qapanel={cat.category}>
          <div class="ip-qa-list">
            {cat.faqs.map((faq, i) => (
              <details class="ip-qa-item" id={`qa-${cat.category}-${i}`}>
                <summary class="ip-qa-q">
                  <span>{faq.q}</span>
                  <span class="ip-qa-chevron">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M6 9l6 6 6-6"/></svg>
                  </span>
                </summary>
                <div class="ip-qa-body">
                  <div class="ip-qa-col ip-qa-bad">
                    <p class="ip-qa-col-label">⚠ Mediocre answer</p>
                    <p class="ip-qa-col-text">{faq.mediocre}</p>
                  </div>
                  <div class="ip-qa-col ip-qa-good">
                    <p class="ip-qa-col-label">✦ Pro answer</p>
                    <p class="ip-qa-col-text">{faq.pro}</p>
                  </div>
                </div>
              </details>
            ))}
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- ── QUESTION BANK ── -->
  <section class="ip-section ip-section-alt" id="question-bank">
    <div class="ip-container">
      <p class="ip-section-eye reveal">Practice bank</p>
      <h2 class="ip-section-title reveal">30+ questions to practise<br />your self-expression</h2>
      <p class="ip-section-sub reveal">Go through each category. For every question, draft your answer using STAR, CAR, or SOAR — then say it aloud twice.</p>
      <div class="ip-qbank-grid">
        {questionBank.map((cat, i) => (
          <div class="ip-qbank-card reveal" style={`transition-delay:${(i % 3) * 0.08}s`}>
            <div class="ip-qbank-header">
              <span class="ip-qbank-icon">{cat.icon}</span>
              <h3 class="ip-qbank-cat">{cat.category}</h3>
            </div>
            <ol class="ip-qbank-list">
              {cat.questions.map((q) => (
                <li class="ip-qbank-q">{q}</li>
              ))}
            </ol>
          </div>
        ))}
      </div>
    </div>
  </section>

  <div class="ip-page-nav">
    <div class="ip-container">
      <a href="/personality-dev/frameworks" class="ip-pnav-back">← Communication Frameworks</a>
      <a href="/personality-dev/plan" class="ip-pnav-next">Next: 14-Day Growth Plan →</a>
    </div>
  </div>

  <Footer />
</Layout>

<script is:inline>
  function initQATabs() {
    var tabs = document.querySelectorAll('[data-qacat]');
    var panels = document.querySelectorAll('[data-qapanel]');
    tabs.forEach(function(tab) {
      tab.addEventListener('click', function() {
        tabs.forEach(function(t) { t.classList.remove('active'); });
        panels.forEach(function(p) { p.classList.remove('active'); });
        tab.classList.add('active');
        var panel = document.querySelector('[data-qapanel="' + tab.getAttribute('data-qacat') + '"]');
        if (panel) panel.classList.add('active');
      });
    });
  }
  initQATabs();
  document.addEventListener('astro:after-swap', initQATabs);
</script>

<style>
  :root {
    --ip-dark: #0a0a0a; --ip-ink: #171717; --ip-muted: #6b7280;
    --ip-purple: #7c3aed; --ip-border: #e5e5e5;
    --ip-gradient: linear-gradient(135deg, #7c3aed 0%, #3b82f6 50%, #06b6d4 100%);
  }
  .ip-container { max-width: 1100px; margin: 0 auto; padding: 0 24px; }
  .ip-section { padding: 80px 0; }
  .ip-section-alt { background: #f8f8f8; }
  .ip-gradient-text { background: var(--ip-gradient); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text; }

  .ip-sub-hero { background: var(--ip-dark); padding: 80px 24px 56px; text-align: center; }
  .ip-breadcrumb { font-size: 0.8rem; color: #6b7280; display: inline-block; margin-bottom: 20px; transition: color 0.2s; }
  .ip-breadcrumb:hover { color: #9ca3af; }
  .ip-eyebrow { font-size: 0.72rem; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--ip-purple); margin-bottom: 12px; }
  .ip-sub-title { font-size: clamp(2rem, 4vw, 3.2rem); font-weight: 600; letter-spacing: -0.04em; color: #fff; line-height: 1.1; margin-bottom: 16px; }
  .ip-sub-desc { font-size: 1rem; color: #9ca3af; max-width: 560px; margin: 0 auto; line-height: 1.7; }

  .ip-module-nav-wrap { background: #fff; border-bottom: 1px solid var(--ip-border); position: sticky; top: 64px; z-index: 40; }
  .ip-module-nav { display: flex; gap: 0; overflow-x: auto; scrollbar-width: none; }
  .ip-module-nav::-webkit-scrollbar { display: none; }
  .ip-mn-link { font-size: 0.82rem; font-weight: 500; color: var(--ip-muted); padding: 14px 20px; white-space: nowrap; border-bottom: 2px solid transparent; transition: color 0.2s, border-color 0.2s; }
  .ip-mn-link:hover { color: var(--ip-ink); }
  .ip-mn-link.active { color: var(--ip-purple); border-bottom-color: var(--ip-purple); font-weight: 600; }

  .ip-section-eye { font-size: 0.75rem; font-weight: 600; letter-spacing: 0.12em; text-transform: uppercase; color: var(--ip-purple); margin-bottom: 12px; display: block; }
  .ip-section-title { font-size: clamp(1.8rem, 3.5vw, 2.4rem); font-weight: 600; letter-spacing: -0.03em; line-height: 1.2; color: var(--ip-ink); margin-bottom: 16px; }
  .ip-section-sub { font-size: 1rem; color: var(--ip-muted); max-width: 580px; line-height: 1.7; margin-bottom: 40px; }

  /* Q&A tabs */
  .ip-video-tabs { display: flex; gap: 8px; margin-bottom: 32px; flex-wrap: wrap; }
  .ip-vtab { font-size: 0.875rem; font-weight: 500; padding: 8px 20px; border-radius: 100px; border: 1.5px solid var(--ip-border); background: transparent; color: var(--ip-muted); cursor: pointer; transition: all 0.2s; }
  .ip-vtab:hover { border-color: var(--ip-purple); color: var(--ip-purple); }
  .ip-vtab.active { background: var(--ip-ink); color: #fff; border-color: var(--ip-ink); }
  .ip-qa-panel { display: none; }
  .ip-qa-panel.active { display: block; }

  .ip-qa-list { display: flex; flex-direction: column; gap: 10px; }
  .ip-qa-item { border: 1px solid var(--ip-border); border-radius: 14px; overflow: hidden; background: #fff; transition: box-shadow 0.2s; }
  .ip-qa-item[open] { box-shadow: 0 4px 20px rgba(0,0,0,0.08); }
  .ip-qa-q { display: flex; align-items: center; justify-content: space-between; padding: 20px 24px; font-size: 1rem; font-weight: 600; color: var(--ip-ink); cursor: pointer; list-style: none; gap: 16px; transition: background 0.15s; }
  .ip-qa-q:hover { background: #f9f9f9; }
  .ip-qa-q::-webkit-details-marker { display: none; }
  .ip-qa-chevron { flex-shrink: 0; color: var(--ip-muted); transition: transform 0.3s; }
  .ip-qa-item[open] .ip-qa-chevron { transform: rotate(180deg); }
  .ip-qa-body { display: grid; grid-template-columns: 1fr 1fr; gap: 1px; background: var(--ip-border); }
  .ip-qa-col { padding: 20px 24px; }
  .ip-qa-bad { background: #fff8f8; }
  .ip-qa-good { background: #f8fff9; }
  .ip-qa-col-label { font-size: 0.72rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; margin-bottom: 10px; }
  .ip-qa-bad .ip-qa-col-label { color: #dc2626; }
  .ip-qa-good .ip-qa-col-label { color: #16a34a; }
  .ip-qa-col-text { font-size: 0.9rem; color: #374151; line-height: 1.6; }
  @media (max-width: 640px) { .ip-qa-body { grid-template-columns: 1fr; } }

  /* Question bank */
  .ip-qbank-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 24px; }
  .ip-qbank-card { background: #fff; border: 1px solid var(--ip-border); border-radius: 16px; padding: 24px; box-shadow: 0 2px 8px rgba(0,0,0,0.04); transition: box-shadow 0.2s, transform 0.2s; }
  .ip-qbank-card:hover { box-shadow: 0 8px 28px rgba(0,0,0,0.1); transform: translateY(-3px); }
  .ip-qbank-header { display: flex; align-items: center; gap: 10px; margin-bottom: 16px; }
  .ip-qbank-icon { font-size: 1.4rem; }
  .ip-qbank-cat { font-size: 0.92rem; font-weight: 600; color: var(--ip-ink); }
  .ip-qbank-list { padding-left: 0; list-style: none; display: flex; flex-direction: column; gap: 10px; counter-reset: qbank; }
  .ip-qbank-q { font-size: 0.85rem; color: #374151; line-height: 1.5; padding-left: 28px; position: relative; counter-increment: qbank; }
  .ip-qbank-q::before { content: counter(qbank); position: absolute; left: 0; top: 0; width: 20px; height: 20px; background: #f3f4f6; border-radius: 50%; font-size: 0.7rem; font-weight: 700; color: var(--ip-muted); display: flex; align-items: center; justify-content: center; line-height: 20px; text-align: center; }

  /* Page nav */
  .ip-page-nav { background: #f8f8f8; border-top: 1px solid var(--ip-border); padding: 24px; }
  .ip-page-nav .ip-container { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 12px; }
  .ip-pnav-back { font-size: 0.875rem; color: var(--ip-muted); font-weight: 500; transition: color 0.2s; }
  .ip-pnav-back:hover { color: var(--ip-ink); }
  .ip-pnav-next { font-size: 0.875rem; font-weight: 600; color: var(--ip-purple); transition: color 0.2s; }
  .ip-pnav-next:hover { color: #6d28d9; }
</style>
