---

<footer class="footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <span class="footer-logo">Online Tuition Classes</span>
      <p class="footer-tagline">Connecting students with verified teachers across India.</p>
    </div>
    <div class="footer-cols">
      <div class="footer-col">
        <span class="footer-col-label">Company</span>
        <a href="/about">About us</a>
        <a href="/contact">Contact</a>
      </div>
      <div class="footer-col">
        <span class="footer-col-label">Legal</span>
        <a href="/privacy-policy">Privacy policy</a>
        <a href="/terms">Terms &amp; conditions</a>
      </div>
      <div class="footer-col">
        <span class="footer-col-label">Students</span>
        <a href="/#how">How it works</a>
        <a href="/#pricing">Pricing</a>
        <a href="/#find">Find a teacher</a>
      </div>
    </div>
  </div>
  <div class="footer-bottom">
    <p>© 2026 Online Tuition Classes. All rights reserved.</p>
  </div>
</footer>

<style>
  .footer {
    background: #171717;
    color: #a3a3a3;
  }

  .footer-inner {
    max-width: 960px;
    margin-inline: auto;
    padding: 64px 24px 48px;
    display: flex;
    gap: 64px;
    flex-wrap: wrap;
  }

  .footer-brand {
    flex: 1;
    min-width: 200px;
  }

  .footer-logo {
    display: block;
    font-weight: 600;
    font-size: 1rem;
    color: #ffffff;
    letter-spacing: -0.02em;
    margin-bottom: 12px;
  }

  .footer-tagline {
    font-size: 0.875rem;
    line-height: 1.6;
    color: #737373;
    max-width: 240px;
  }

  .footer-cols {
    display: flex;
    gap: 48px;
    flex-wrap: wrap;
  }

  .footer-col {
    display: flex;
    flex-direction: column;
    gap: 10px;
    min-width: 120px;
  }

  .footer-col-label {
    font-size: 0.75rem;
    font-weight: 400;
    color: #525252;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-family: ui-monospace, 'SFMono-Regular', Menlo, Monaco, monospace;
    margin-bottom: 2px;
  }

  .footer-col a {
    font-size: 0.875rem;
    color: #a3a3a3;
    transition: color 0.15s;
  }

  .footer-col a:hover { color: #ffffff; }

  .footer-bottom {
    border-top: 1px solid #262626;
    max-width: 960px;
    margin-inline: auto;
    padding: 20px 24px;
    font-size: 0.8rem;
    color: #525252;
  }
</style>
