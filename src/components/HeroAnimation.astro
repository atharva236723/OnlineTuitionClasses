<div class="scene">
  <svg class="svg" viewBox="0 0 480 300" xmlns="http://www.w3.org/2000/svg">

    <!-- ─── BLACKBOARD ─── -->
    <rect x="14"  y="14"  width="168" height="136" rx="7" fill="#152a15"/>
    <rect x="20"  y="20"  width="156" height="122" rx="5" fill="#0c1c0c"/>
    <rect x="14"  y="14"  width="168" height="136" rx="7" fill="none" stroke="#1e3a1e" stroke-width="2.5"/>
    <!-- chalk rail -->
    <rect x="14"  y="146" width="168" height="8"   rx="2" fill="#374151"/>
    <rect x="22"  y="148" width="20"  height="4"   rx="2" fill="#e2e8f0" opacity=".5"/>

    <!-- Board content -->
    <text x="30" y="47" font-family="Georgia,serif" font-size="13" font-style="italic" fill="rgba(255,255,255,.9)" letter-spacing=".5">a² + b² = c²</text>
    <line x1="27" y1="51" x2="116" y2="51" stroke="rgba(255,255,255,.25)" stroke-width="1.2"/>
    <!-- right-angle triangle -->
    <line x1="30" y1="98"  x2="30"  y2="62"  stroke="rgba(255,255,255,.72)" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="30" y1="98"  x2="78"  y2="98"  stroke="rgba(255,255,255,.72)" stroke-width="1.5" stroke-linecap="round"/>
    <line x1="30" y1="62"  x2="78"  y2="98"  stroke="rgba(255,255,255,.72)" stroke-width="1.5" stroke-linecap="round"/>
    <!-- right-angle box -->
    <path d="M30 90 L39 90 L39 98" stroke="rgba(255,255,255,.45)" stroke-width="1" fill="none"/>
    <!-- side labels -->
    <text x="19" y="82"  font-family="Georgia,serif" font-size="9" font-style="italic" fill="rgba(255,255,255,.62)">a</text>
    <text x="50" y="110" font-family="Georgia,serif" font-size="9" font-style="italic" fill="rgba(255,255,255,.62)">b</text>
    <text x="60" y="77"  font-family="Georgia,serif" font-size="9" font-style="italic" fill="rgba(255,255,255,.62)">c</text>
    <!-- secondary formulae -->
    <text x="99" y="64"  font-family="Georgia,serif"          font-size="10" font-style="italic" fill="rgba(255,255,255,.65)">sin θ =</text>
    <text x="99" y="78"  font-family="'Courier New',monospace" font-size="9"                    fill="rgba(255,255,255,.45)">opp / hyp</text>
    <text x="99" y="93"  font-family="Georgia,serif"          font-size="10" font-style="italic" fill="rgba(255,255,255,.65)">cos θ =</text>
    <text x="99" y="107" font-family="'Courier New',monospace" font-size="9"                    fill="rgba(255,255,255,.45)">adj / hyp</text>
    <!-- blinking cursor (text being written) -->
    <rect class="cur" x="101" y="113" width="1.5" height="10" rx=".75" fill="rgba(255,255,255,.9)"/>
    <!-- horizontal divider + footnote -->
    <line x1="27" y1="116" x2="165" y2="116" stroke="rgba(255,255,255,.1)" stroke-width="1"/>
    <text x="27" y="129" font-family="'Courier New',monospace" font-size="7.5" fill="rgba(255,255,255,.35)">∴ c is the hypotenuse</text>
    <text x="27" y="140" font-family="'Courier New',monospace" font-size="7.5" fill="rgba(255,255,255,.35)">   opposite the right angle</text>

    <!-- ─── TEACHER ─── -->
    <g class="g-teacher">
      <!-- floor shadow -->
      <ellipse cx="232" cy="291" rx="24" ry="5" fill="rgba(0,0,0,.25)"/>
      <!-- trouser legs -->
      <path d="M218 217 Q215 251 215 283" stroke="#1e293b" stroke-width="17" stroke-linecap="round" fill="none"/>
      <path d="M234 217 Q237 253 237 283" stroke="#1e293b" stroke-width="17" stroke-linecap="round" fill="none"/>
      <!-- shoes -->
      <ellipse cx="213" cy="283" rx="11" ry="5.5" fill="#0f172a"/>
      <ellipse cx="235" cy="283" rx="11" ry="5.5" fill="#0f172a"/>
      <!-- blazer body -->
      <path d="M206 129 Q203 217 204 221 L256 221 Q257 217 254 129 Z" fill="#334155"/>
      <!-- shirt / collar -->
      <path d="M226 129 L221 147 L226 151 L231 147 Z" fill="#f8fafc"/>
      <!-- lapels -->
      <path d="M221 129 L213 150 L221 154 L226 151 L221 147 Z" fill="#2d3d4f"/>
      <path d="M231 129 L239 150 L231 154 L226 151 L231 147 Z" fill="#2d3d4f"/>
      <!-- belt -->
      <rect x="204" y="213" width="52" height="6" rx="2" fill="#0f172a" opacity=".5"/>
      <!-- left arm – relaxed at side -->
      <path d="M206 142 Q193 170 193 201" stroke="#334155" stroke-width="19" stroke-linecap="round" fill="none"/>
      <circle cx="193" cy="202" r="9" fill="#fcd9a0"/>
      <!-- right arm – reaching to write on board (animated) -->
      <g class="g-chalk-arm">
        <path d="M248 139 Q224 111 196 93" stroke="#334155" stroke-width="17" stroke-linecap="round" fill="none"/>
        <circle cx="194" cy="91"  r="8.5" fill="#fcd9a0"/>
        <!-- chalk stick -->
        <rect x="183" y="79" width="5" height="16" rx="2.5" fill="#e5e7eb" transform="rotate(-40 186 87)"/>
      </g>
      <!-- neck -->
      <rect x="219" y="113" width="16" height="18" rx="5" fill="#fcd9a0"/>
      <!-- head -->
      <circle cx="227" cy="96"  r="22" fill="#fcd9a0"/>
      <circle cx="205" cy="98"  r="7"  fill="#fcd9a0"/>
      <circle cx="249" cy="98"  r="7"  fill="#fcd9a0"/>
      <!-- hair -->
      <path d="M206 89 Q208 73 227 71 Q246 73 248 89" fill="#2d1b0e"/>
      <circle cx="206" cy="91" r="5.5" fill="#2d1b0e"/>
      <circle cx="248" cy="91" r="5.5" fill="#2d1b0e"/>
      <ellipse cx="227" cy="73" rx="11" ry="4" fill="#2d1b0e"/>
      <!-- eyes (looking left toward board) -->
      <ellipse cx="219" cy="95" rx="3.5" ry="4"   fill="#1f2937"/>
      <ellipse cx="232" cy="95" rx="3.5" ry="4"   fill="#1f2937"/>
      <circle  cx="219.8" cy="95" r="1.8"          fill="#111827"/>
      <circle  cx="232.8" cy="95" r="1.8"          fill="#111827"/>
      <circle  cx="220.5" cy="93.5" r="1"          fill="white"/>
      <circle  cx="233.5" cy="93.5" r="1"          fill="white"/>
      <!-- eyebrows (focused) -->
      <path d="M215 88 Q219 85 223 88" stroke="#4a3526" stroke-width="1.8" fill="none" stroke-linecap="round"/>
      <path d="M228 88 Q232 85 236 88" stroke="#4a3526" stroke-width="1.8" fill="none" stroke-linecap="round"/>
      <!-- mouth (concentrated small smile) -->
      <path d="M220 106 Q227 110 234 106" stroke="#9a3412" stroke-width="1.8" fill="none" stroke-linecap="round"/>
    </g>

    <!-- ─── CHAIR ─── -->
    <rect x="342" y="160" width="8"  height="76" rx="3" fill="#374151"/>
    <rect x="400" y="160" width="8"  height="76" rx="3" fill="#374151"/>
    <rect x="340" y="155" width="70" height="9"  rx="4" fill="#4b5563"/>
    <rect x="337" y="224" width="76" height="10" rx="4" fill="#4b5563"/>
    <rect x="342" y="234" width="7"  height="54" rx="3" fill="#374151"/>
    <rect x="401" y="234" width="7"  height="54" rx="3" fill="#374151"/>

    <!-- ─── DESK ─── -->
    <rect x="290" y="198" width="172" height="12" rx="4" fill="#92400e"/>
    <rect x="290" y="205" width="172" height="5"  rx="2" fill="#78350f" opacity=".8"/>
    <rect x="298" y="210" width="9"   height="78" rx="3" fill="#92400e"/>
    <rect x="445" y="210" width="9"   height="78" rx="3" fill="#92400e"/>

    <!-- ─── OPEN NOTEBOOK ─── -->
    <path d="M308 177 Q306 195 308 198 L350 198 L350 174 Z" fill="#f8fafc"/>
    <path d="M394 177 Q396 195 394 198 L350 198 L350 174 Z" fill="#f1f5f9"/>
    <rect x="348" y="174" width="5"   height="24" rx="2" fill="#cbd5e1"/>
    <!-- left page ruled lines -->
    <line x1="315" y1="181" x2="343" y2="181" stroke="#e2e8f0" stroke-width="1"/>
    <line x1="315" y1="185" x2="343" y2="185" stroke="#e2e8f0" stroke-width="1"/>
    <line x1="315" y1="189" x2="343" y2="189" stroke="#e2e8f0" stroke-width="1"/>
    <line x1="315" y1="193" x2="340" y2="193" stroke="#e2e8f0" stroke-width="1"/>
    <!-- right page ruled lines -->
    <line x1="356" y1="181" x2="388" y2="181" stroke="#e2e8f0" stroke-width="1"/>
    <line x1="356" y1="185" x2="388" y2="185" stroke="#e2e8f0" stroke-width="1"/>
    <line x1="356" y1="189" x2="388" y2="189" stroke="#e2e8f0" stroke-width="1"/>
    <line x1="356" y1="193" x2="384" y2="193" stroke="#e2e8f0" stroke-width="1"/>
    <!-- pen resting on desk -->
    <g transform="rotate(-7 413 189)">
      <rect x="397" y="185" width="32" height="4"  rx="2" fill="#1d4ed8"/>
      <circle cx="398" cy="187" r="3"              fill="#1e40af"/>
      <rect x="427" y="185" width="5"  height="4"  rx="1" fill="#93c5fd"/>
    </g>

    <!-- ─── STUDENT ─── -->
    <g class="g-student">
      <!-- torso / hoodie -->
      <path d="M345 133 Q340 198 341 202 L399 202 Q400 198 395 133 Z" fill="#1e40af"/>
      <!-- pocket -->
      <rect x="357" y="172" width="26" height="18" rx="4" fill="#1d4ed8"/>
      <!-- hood seam at collar -->
      <path d="M345 133 Q353 123 370 121 Q387 123 395 133" stroke="#1d4ed8" stroke-width="4" fill="none"/>
      <!-- left arm resting on desk -->
      <path d="M345 149 Q328 172 322 194" stroke="#1e40af" stroke-width="19" stroke-linecap="round" fill="none"/>
      <circle cx="322" cy="195" r="9.5" fill="#fcd9a0"/>
      <!-- right arm writing in notebook (animated) -->
      <g class="g-pen-arm">
        <path d="M395 149 Q411 172 413 191" stroke="#1e40af" stroke-width="17" stroke-linecap="round" fill="none"/>
        <circle cx="414" cy="192" r="8.5" fill="#fcd9a0"/>
        <!-- pen in hand -->
        <rect x="411" y="181" width="3.5" height="15" rx="1.5" fill="#1d4ed8" transform="rotate(12 413 189)"/>
      </g>
      <!-- neck -->
      <rect x="363" y="119" width="14" height="16" rx="4" fill="#fcd9a0"/>
      <!-- head -->
      <g class="g-s-head">
        <circle cx="370" cy="103" r="21" fill="#fcd9a0"/>
        <circle cx="349" cy="105" r="6.5" fill="#fcd9a0"/>
        <circle cx="391" cy="105" r="6.5" fill="#fcd9a0"/>
        <!-- hair (casual teen, slightly longer) -->
        <path d="M350 97 Q352 80 370 78 Q388 80 390 97" fill="#1c0f05"/>
        <circle cx="350" cy="99" r="5.5" fill="#1c0f05"/>
        <circle cx="390" cy="99" r="5.5" fill="#1c0f05"/>
        <ellipse cx="370" cy="80" rx="11" ry="4.5" fill="#1c0f05"/>
        <!-- fringe / casual side hair -->
        <path d="M349 91 Q344 83 347 77" stroke="#1c0f05" stroke-width="8" stroke-linecap="round" fill="none"/>
        <!-- eyes (looking left – toward board) -->
        <ellipse cx="362" cy="101" rx="3.5" ry="4"   fill="#1f2937"/>
        <ellipse cx="376" cy="101" rx="3.5" ry="4"   fill="#1f2937"/>
        <circle  cx="362.5" cy="101" r="1.8"          fill="#111827"/>
        <circle  cx="376.5" cy="101" r="1.8"          fill="#111827"/>
        <circle  cx="363.3" cy="99.5" r="1"           fill="white"/>
        <circle  cx="377.3" cy="99.5" r="1"           fill="white"/>
        <!-- eyebrows (attentive) -->
        <path d="M358 93 Q362 90 366 93" stroke="#3d2410" stroke-width="1.8" fill="none" stroke-linecap="round"/>
        <path d="M372 93 Q376 90 380 93" stroke="#3d2410" stroke-width="1.8" fill="none" stroke-linecap="round"/>
        <!-- focused expression -->
        <path d="M363 112 Q370 116 377 112" stroke="#9a3412" stroke-width="1.8" fill="none" stroke-linecap="round"/>
      </g>
    </g>

    <!-- subtle floor line -->
    <line x1="0" y1="291" x2="480" y2="291" stroke="rgba(255,255,255,.06)" stroke-width="1"/>
  </svg>
</div>

<style>
  .scene {
    width: 100%;
    max-width: 460px;
    margin-inline: auto;
  }

  .svg {
    width: 100%;
    aspect-ratio: 480 / 300;
    overflow: visible;
    animation: gentle-float 7s ease-in-out infinite;
  }

  /* Very slow, subtle overall float */
  @keyframes gentle-float {
    0%, 100% { transform: translateY(0);   }
    50%       { transform: translateY(-8px); }
  }

  /* Teacher chalk arm — small rotation at shoulder simulates writing strokes */
  .g-chalk-arm {
    animation: chalk-write 2.6s ease-in-out infinite;
    transform-box: fill-box;
    transform-origin: right top;
  }
  @keyframes chalk-write {
    0%   { transform: rotate(0deg);   }
    20%  { transform: rotate(-4deg);  }
    45%  { transform: rotate(-7deg);  }
    70%  { transform: rotate(-3deg);  }
    100% { transform: rotate(0deg);   }
  }

  /* Student head — very subtle attentive lean */
  .g-s-head {
    animation: lean 5.5s ease-in-out infinite;
    transform-box: fill-box;
    transform-origin: center bottom;
  }
  @keyframes lean {
    0%, 100% { transform: rotate(0deg);    }
    35%       { transform: rotate(-3.5deg); }
    65%       { transform: rotate(-1.5deg); }
  }

  /* Student pen arm — gentle note-taking oscillation */
  .g-pen-arm {
    animation: note-write 3.2s ease-in-out infinite 0.3s;
    transform-box: fill-box;
    transform-origin: left top;
  }
  @keyframes note-write {
    0%, 100% { transform: translateX(0);    }
    30%       { transform: translateX(-5px); }
    60%       { transform: translateX(-9px); }
  }

  /* Board cursor blinks */
  .cur {
    animation: blink 1.1s step-end infinite;
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
</style>
