---
---

<div class="book-scene">
  <!-- Floating sparkles -->
  <div class="sparks" aria-hidden="true">
    <span class="sp sp-1">∑</span>
    <span class="sp sp-2">⚛</span>
    <span class="sp sp-3">★</span>
    <span class="sp sp-4">✦</span>
    <span class="sp sp-5">π</span>
    <span class="sp sp-6">🧬</span>
    <span class="sp sp-7">◆</span>
    <span class="sp sp-8">∞</span>
  </div>

  <div class="floater">
    <div class="book">

      <!-- Left cover -->
      <div class="book-left">
        <div class="cover-glow"></div>
        <div class="cover-inner">
          <span class="cover-emoji">📚</span>
          <p class="cover-label">Learn<br/>With<br/>Us</p>
          <span class="cover-star">✦</span>
        </div>
      </div>

      <!-- Spine -->
      <div class="spine"></div>

      <!-- Right page — JS-swapped content, fold animation -->
      <div class="book-right">
        <div class="page-fold" id="pageFold">
          <div class="page-inner" id="bookPage"></div>
        </div>
        <!-- Page turn shadow overlay (animates during fold) -->
        <div class="turn-shadow" id="turnShadow"></div>
        <!-- Page curl corner -->
        <div class="page-curl"></div>
      </div>

    </div>
    <div class="book-shadow"></div>
  </div>
</div>

<script is:inline>
(function () {
  /* ── Page definitions ── */
  var pages = [
    {
      bg: '#fff', tagStyle: 'background:#e0f2fe;color:#0369a1', label: 'Welcome!',
      body:
        '<div class="pi-star">✦</div>' +
        '<p class="pi-hl" style="color:#1e3a5f">Your learning<br/>journey starts<br/>here 🚀</p>' +
        '<div class="pi-dots">' +
          '<span style="background:#7c3aed"></span>' +
          '<span style="background:#2563eb;animation-delay:.2s"></span>' +
          '<span style="background:#10b981;animation-delay:.4s"></span>' +
        '</div>'
    },
    {
      bg: '#f8fff9', tagStyle: 'background:#d1fae5;color:#065f46', label: 'Maths',
      body:
        '<p class="pi-eq">a² + b² = c²</p>' +
        '<svg class="pi-tri" viewBox="0 0 90 76" fill="none">' +
          '<polygon points="8,68 82,68 8,8" stroke="#10b981" stroke-width="2.5" fill="rgba(16,185,129,.12)" stroke-linejoin="round"/>' +
          '<text x="0" y="40" font-size="11" fill="#059669" font-style="italic">a</text>' +
          '<text x="42" y="76" font-size="11" fill="#059669" font-style="italic">b</text>' +
          '<text x="50" y="33" font-size="11" fill="#059669" font-style="italic">c</text>' +
          '<rect x="8" y="60" width="8" height="8" stroke="#10b981" stroke-width="1.5" fill="none"/>' +
        '</svg>'
    },
    {
      bg: '#faf8ff', tagStyle: 'background:#ede9fe;color:#5b21b6', label: 'Physics',
      body:
        '<div class="pi-atom">' +
          '<span class="pi-nuc">⚛</span>' +
          '<div class="pi-orb pi-o1"><div class="pi-el" style="background:#7c3aed"></div></div>' +
          '<div class="pi-orb pi-o2"><div class="pi-el" style="background:#2563eb"></div></div>' +
        '</div>' +
        '<p class="pi-formula" style="color:#3730a3">F = ma</p>' +
        '<p class="pi-formula" style="color:#6b7280;font-size:.65rem">E = mc²</p>'
    },
    {
      bg: '#fff8fb', tagStyle: 'background:#ffe4e6;color:#9f1239', label: 'English',
      body:
        '<p class="pi-abc">A B C</p>' +
        '<div class="pi-pills">' +
          '<span style="background:#fce7f3;color:#9d174d">Read</span>' +
          '<span style="background:#ede9fe;color:#5b21b6">Write</span>' +
          '<span style="background:#dbeafe;color:#1e40af">Speak</span>' +
          '<span style="background:#d1fae5;color:#065f46">Learn!</span>' +
        '</div>'
    },
    {
      bg: '#f0fffe', tagStyle: 'background:#ccfbf1;color:#134e4a', label: 'Chemistry',
      body:
        '<div class="pi-molecule">' +
          '<span class="pi-atom-ball" style="background:#dc2626">O</span>' +
          '<span class="pi-bond"></span>' +
          '<span class="pi-atom-ball" style="background:#2563eb">H</span>' +
          '<span class="pi-bond"></span>' +
          '<span class="pi-atom-ball" style="background:#2563eb">H</span>' +
        '</div>' +
        '<p class="pi-formula" style="color:#374151">H₂O · NaCl · CO₂</p>' +
        '<div class="pi-periodic">' +
          '<span>Na</span><span>Cl</span><span>Fe</span><span>Cu</span>' +
        '</div>'
    },
    {
      bg: '#f5f3ff', tagStyle: 'background:#e0e7ff;color:#3730a3', label: 'Biology',
      body:
        '<div class="pi-cell"><div class="pi-cell-body"><div class="pi-nucleus">N</div></div></div>' +
        '<p class="pi-formula" style="color:#4338ca">Cell = Life\'s<br/>building block</p>'
    }
  ];

  var foldEl   = document.getElementById('pageFold');
  var pageEl   = document.getElementById('bookPage');
  var shadowEl = document.getElementById('turnShadow');
  var idx      = 0;
  var busy     = false;

  function render(i) {
    var p = pages[i];
    foldEl.style.background = p.bg;
    pageEl.innerHTML =
      '<span class="pi-tag" style="' + p.tagStyle + '">' + p.label + '</span>' +
      '<div class="pi-body">' + p.body + '</div>' +
      '<div class="pi-lines"><span></span><span></span><span></span></div>';
  }

  function flip(nextIdx) {
    if (busy) return;
    busy = true;

    /* ── Phase 1: fold the page toward the spine (scaleX 1→0) ── */
    /* Show shadow that darkens the right side as page folds left */
    shadowEl.style.transition = 'none';
    shadowEl.style.opacity = '0';
    shadowEl.getBoundingClientRect();

    foldEl.style.transition = 'transform 0.38s cubic-bezier(.4,0,.6,1)';
    foldEl.style.transform  = 'scaleX(0)';

    shadowEl.style.transition = 'opacity 0.38s ease-in';
    shadowEl.style.opacity    = '0.22';

    /* ── Phase 2: at zero-width, swap and unfold ── */
    setTimeout(function () {
      render(nextIdx);

      foldEl.style.transition = 'none';
      foldEl.style.transform  = 'scaleX(0)';
      foldEl.getBoundingClientRect(); // reflow

      shadowEl.style.transition = 'opacity 0.34s ease-out';
      shadowEl.style.opacity    = '0';

      foldEl.style.transition = 'transform 0.34s cubic-bezier(.2,0,.4,1)';
      foldEl.style.transform  = 'scaleX(1)';

      setTimeout(function () { busy = false; }, 360);
    }, 400);
  }

  /* Initial render */
  render(idx);

  /* Auto-cycle */
  setInterval(function () {
    idx = (idx + 1) % pages.length;
    flip(idx);
  }, 3600);
})();
</script>

<style>
  /* ── Scene ── */
  .book-scene {
    position: relative;
    width: 100%;
    max-width: 420px;
    margin-inline: auto;
    height: 280px;
    display: flex;
    align-items: center;
    justify-content: center;
    user-select: none;
  }

  /* ── Sparkles ── */
  .sparks { position: absolute; inset: 0; pointer-events: none; }

  .sp {
    position: absolute;
    font-weight: 700;
    animation: sp-float 5s ease-in-out infinite;
  }

  .sp-1 { top: 5%;  left: 1%;  font-size: 1rem;   color: #f59e0b; animation-duration: 5.2s; animation-delay: 0s; }
  .sp-2 { top: 7%;  right: 3%; font-size: 1.1rem;  color: #7c3aed; animation-duration: 4.8s; animation-delay: .7s; }
  .sp-3 { top: 63%; left: 1%;  font-size: .9rem;   color: #ec4899; animation-duration: 5.5s; animation-delay: 1.3s; }
  .sp-4 { top: 78%; right: 2%; font-size: .85rem;  color: #10b981; animation-duration: 4.4s; animation-delay: .4s; }
  .sp-5 { top: 38%; left: 4%;  font-size: 1rem;    color: #2563eb; animation-duration: 5.0s; animation-delay: 1.9s; }
  .sp-6 { top: 18%; right: 1%; font-size: 1.2rem;  color: #dc2626; animation-duration: 4.6s; animation-delay: 1.0s; }
  .sp-7 { top: 85%; left: 8%;  font-size: .8rem;   color: #f59e0b; animation-duration: 5.3s; animation-delay: 2.2s; }
  .sp-8 { top: 70%; right: 6%; font-size: .9rem;   color: #7c3aed; animation-duration: 4.9s; animation-delay: 1.6s; }

  @keyframes sp-float {
    0%, 100% { transform: translateY(0) rotate(0deg);       opacity: .7; }
    40%       { transform: translateY(-12px) rotate(15deg);  opacity: 1; }
    70%       { transform: translateY(-5px) rotate(-9deg);   opacity: .82; }
  }

  /* ── Floater — vertical bounce only ── */
  .floater {
    position: relative;
    animation: book-float 5.5s ease-in-out infinite;
    will-change: transform;
  }

  @keyframes book-float {
    0%, 100% { transform: translateY(0);     }
    50%       { transform: translateY(-13px); }
  }

  /* ── Book shell ── */
  .book {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    height: 224px;
    border-radius: 5px 8px 8px 5px;
    box-shadow:
      0 1px 3px rgba(0,0,0,.14),
      0 4px 18px rgba(0,0,0,.22),
      0 18px 44px rgba(0,0,0,.16);
  }

  /* ── Left cover ── */
  .book-left {
    width: 110px;
    background: linear-gradient(148deg, #7c3aed 0%, #4f46e5 52%, #2563eb 100%);
    border-radius: 5px 0 0 5px;
    position: relative;
    overflow: hidden;
    flex-shrink: 0;
  }

  .cover-glow {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 30% 28%, rgba(255,255,255,.18) 0%, transparent 52%),
      repeating-linear-gradient(
        132deg,
        rgba(255,255,255,.04) 0px,
        rgba(255,255,255,.04) 1px,
        transparent 1px,
        transparent 20px
      );
  }

  .cover-inner {
    position: relative;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10px;
    padding: 0 12px;
  }

  .cover-emoji { font-size: 2rem; line-height: 1; }

  .cover-label {
    font-size: .95rem;
    font-weight: 700;
    color: #fff;
    text-align: center;
    line-height: 1.35;
  }

  .cover-star {
    font-size: .95rem;
    color: rgba(255,255,255,.6);
    display: block;
    animation: spin-slow 8s linear infinite;
  }

  @keyframes spin-slow { to { transform: rotate(360deg); } }

  /* ── Spine ── */
  .spine {
    width: 13px;
    height: 100%;
    background: linear-gradient(to right, #1e1b4b 0%, #312e81 100%);
    flex-shrink: 0;
    box-shadow: inset -1px 0 4px rgba(0,0,0,.18);
  }

  /* ── Right page ── */
  .book-right {
    width: 142px;
    height: 100%;
    background: #fff;
    border-radius: 0 8px 8px 0;
    position: relative;
    overflow: hidden;
    flex-shrink: 0;
  }

  /* Page fold wrapper — scaleX animates on this */
  .page-fold {
    position: absolute;
    inset: 0;
    background: #fff;
    transform-origin: left center;
    will-change: transform;
    border-radius: 0 8px 8px 0;
  }

  /* Page content sits inside the fold */
  .page-inner {
    position: absolute;
    inset: 0;
    padding: 14px 13px 10px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    border-radius: 0 8px 8px 0;
    overflow: hidden;
  }

  /* Shadow overlay that darkens during fold — simulates paper curl shadow */
  .turn-shadow {
    position: absolute;
    inset: 0;
    background: linear-gradient(to right, rgba(60,40,120,.35) 0%, rgba(0,0,0,.08) 100%);
    opacity: 0;
    pointer-events: none;
    border-radius: 0 8px 8px 0;
    z-index: 5;
  }

  /* Page curl corner */
  .page-curl {
    position: absolute;
    bottom: 0; right: 0;
    width: 0; height: 0;
    border-style: solid;
    border-width: 0 0 20px 20px;
    border-color: transparent transparent #e5e7eb transparent;
    pointer-events: none;
    z-index: 10;
  }

  /* ── Shadow ── */
  .book-shadow {
    width: 210px;
    height: 11px;
    background: radial-gradient(ellipse, rgba(0,0,0,.28) 0%, transparent 70%);
    margin: 9px auto 0;
    animation: shadow-breathe 5.5s ease-in-out infinite;
  }

  @keyframes shadow-breathe {
    0%, 100% { transform: scaleX(1);    opacity: .48; }
    50%       { transform: scaleX(.66); opacity: .22; }
  }

  /* ── JS-injected content (all :global) ── */
  :global(.pi-tag) {
    display: inline-block;
    font-size: .54rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .08em;
    padding: 3px 8px;
    border-radius: 100px;
    align-self: flex-start;
    flex-shrink: 0;
  }

  :global(.pi-body) {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 7px;
    min-height: 0;
  }

  :global(.pi-lines) {
    display: flex;
    flex-direction: column;
    gap: 4px;
    flex-shrink: 0;
  }

  :global(.pi-lines span) {
    display: block;
    height: 1px;
    background: linear-gradient(to right, #e5e7eb 65%, transparent);
  }

  /* Welcome */
  :global(.pi-star) {
    font-size: 1.85rem;
    animation: pi-spin 7s linear infinite;
  }

  @keyframes pi-spin { to { transform: rotate(360deg); } }

  :global(.pi-hl) {
    font-size: .68rem;
    font-weight: 600;
    text-align: center;
    line-height: 1.55;
    margin: 0;
  }

  :global(.pi-dots) { display: flex; gap: 5px; }

  :global(.pi-dots span) {
    display: block;
    width: 7px; height: 7px;
    border-radius: 50%;
    animation: pi-dot 1.2s ease-in-out infinite;
  }

  @keyframes pi-dot {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-5px); }
  }

  /* Maths */
  :global(.pi-eq) {
    font-family: Georgia, serif;
    font-size: .92rem;
    font-style: italic;
    font-weight: 700;
    color: #065f46;
    text-align: center;
    line-height: 1.4;
    margin: 0;
  }

  :global(.pi-tri) {
    width: 86px; height: 72px;
    flex-shrink: 0;
    overflow: visible;
  }

  /* Physics */
  :global(.pi-atom) {
    position: relative;
    width: 76px; height: 76px;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
  }

  :global(.pi-nuc) { font-size: 1.4rem; position: relative; z-index: 2; }

  :global(.pi-orb) {
    position: absolute;
    border: 1.5px solid;
    border-radius: 50%;
  }

  :global(.pi-o1) {
    width: 56px; height: 56px;
    border-color: rgba(124,58,237,.42);
    animation: pi-orb 3s linear infinite;
  }

  :global(.pi-o2) {
    width: 76px; height: 76px;
    border-color: rgba(37,99,235,.3);
    animation: pi-orb 5s linear infinite reverse;
  }

  @keyframes pi-orb { to { transform: rotate(360deg); } }

  :global(.pi-el) {
    position: absolute;
    width: 7px; height: 7px;
    border-radius: 50%;
    top: -3.5px; left: 50%;
    transform: translateX(-50%);
  }

  :global(.pi-formula) {
    font-family: Georgia, serif;
    font-size: .78rem;
    font-style: italic;
    text-align: center;
    line-height: 1.5;
    margin: 0;
  }

  /* English */
  :global(.pi-abc) {
    font-size: 1.5rem;
    font-weight: 800;
    letter-spacing: .1em;
    background: linear-gradient(90deg, #ec4899, #7c3aed, #2563eb);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin: 0;
  }

  :global(.pi-pills) {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    justify-content: center;
  }

  :global(.pi-pills span) {
    font-size: .58rem;
    font-weight: 600;
    padding: 2px 7px;
    border-radius: 100px;
  }

  /* Chemistry */
  :global(.pi-molecule) {
    display: flex; align-items: center; gap: 3px;
  }

  :global(.pi-atom-ball) {
    width: 28px; height: 28px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-size: .7rem; font-weight: 700; color: #fff;
  }

  :global(.pi-bond) {
    width: 10px; height: 3px;
    background: #9ca3af;
    border-radius: 2px;
  }

  :global(.pi-periodic) {
    display: flex; gap: 4px;
  }

  :global(.pi-periodic span) {
    font-size: .58rem;
    font-weight: 700;
    padding: 2px 5px;
    border: 1px solid #e5e7eb;
    border-radius: 4px;
    background: #f9fafb;
    color: #374151;
  }

  /* Biology */
  :global(.pi-cell) {
    display: flex; align-items: center; justify-content: center;
  }

  :global(.pi-cell-body) {
    width: 68px; height: 56px;
    border: 2px solid #6366f1;
    border-radius: 40% 60% 55% 45% / 50% 45% 55% 50%;
    background: rgba(99,102,241,.08);
    display: flex; align-items: center; justify-content: center;
    animation: pi-cell-morph 4s ease-in-out infinite;
  }

  @keyframes pi-cell-morph {
    0%, 100% { border-radius: 40% 60% 55% 45% / 50% 45% 55% 50%; }
    50%       { border-radius: 55% 45% 45% 55% / 45% 55% 45% 55%; }
  }

  :global(.pi-nucleus) {
    width: 22px; height: 22px;
    border-radius: 50%;
    background: rgba(99,102,241,.28);
    border: 1.5px solid #6366f1;
    display: flex; align-items: center; justify-content: center;
    font-size: .58rem; font-weight: 700; color: #4338ca;
  }
</style>
